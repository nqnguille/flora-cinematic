---
// Login compartido de todo el portal de socios (index, carta, cuenta, admin).
// Una sola experiencia visual: video de cultivo a pantalla completa + dos cards
// (marca a la izq., acceso con Google a la der.). Cada página sigue dueña de
// SU lógica de auth (distinto payload/POST-login), pero todas apuntan a los
// mismos ids (#socios-login, #g_id_button, #socios-login-msg) para que este
// componente sea el único lugar donde vive el diseño del login.
interface Props {
  eyebrow?: string
  title: string
  tagline?: string
  authTitle?: string
  authSub?: string
  backHref?: string
  hideNote?: boolean
}
const {
  eyebrow,
  title,
  tagline,
  authTitle,
  authSub,
  backHref = '/',
  hideNote = false,
} = Astro.props
---

<div id="socios-login" class="sl-login">
  <video class="sl-video" src="/hero/socios-login.mp4" poster="/hero/socios-login_poster.jpg" autoplay muted loop playsinline preload="auto" aria-hidden="true"></video>

  <a href={backHref} class="sl-back">← Volver al sitio</a>

  <div class="sl-split">
    <div class="sl-panel">
      <img class="sl-logo" src="/img/flora-logo-cultivamos-conciencia-white.png" alt="Flora — Cultivamos conciencia" width="2000" height="795" />
      {eyebrow && <span class="sl-eyebrow">{eyebrow}</span>}
      <h1 class="sl-title" set:html={title} />
      {tagline && <p class="sl-tagline">{tagline}</p>}

      {authTitle && <div class="sl-divider" aria-hidden="true"></div>}
      {authTitle && <h2 class="sl-auth-title">{authTitle}</h2>}
      {authSub && <p class="sl-sub">{authSub}</p>}
      <div id="g_id_button" class="sl-gbtn"></div>
      <p id="socios-login-msg" class="sl-msg" hidden></p>
      {!hideNote && <div class="sl-note"><slot name="note">Verificamos tu cuenta contra el padrón de socios · no compartimos tus datos.</slot></div>}
    </div>
  </div>
</div>

<style is:global>
  /* ═══════════════════════════════════════════════
     SOCIOS LOGIN — componente único para todo el portal
     Video de cultivo de fondo + dos cards de vidrio.
  ═══════════════════════════════════════════════ */
  .sl-login {
    --sl-cream:  #f4f1f7;
    --sl-muted:  rgba(244, 241, 247, 0.55);
    --sl-violet: #b79de6;
    --sl-green:  #3cb492;

    position: relative; overflow: hidden; isolation: isolate;
    min-height: 100svh;
    padding: 0;
    background: #130d1c;
    font-family: var(--font-ui);
  }
  .sl-login[hidden] { display: none; }

  .sl-video {
    position: absolute; inset: 0; z-index: 0;
    width: 100%; height: 100%; object-fit: cover;
    filter: saturate(1.05) brightness(0.9);
  }

  .sl-back {
    position: absolute; z-index: 3; top: var(--space-s); left: var(--space-s);
    color: rgba(244, 241, 247, 0.75); text-decoration: none; font-size: 0.85rem;
    font-family: var(--font-ui);
    text-shadow: 0 1px 12px rgba(0,0,0,0.6);
    transition: color 0.2s ease;
  }
  .sl-back:hover { color: var(--sl-cream); }

  /* Todo el contenido (marca + acceso) apilado en un único panel pegado al
     borde izquierdo; la mitad derecha de la pantalla queda 100% libre para
     el video */
  .sl-split {
    position: relative; z-index: 2;
    min-height: 100svh;
  }

  .sl-panel {
    position: absolute; top: 0; bottom: 0; left: 0;
    width: 58%;
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    text-align: center;
    gap: 0.7rem;
    padding: clamp(32px, 5vw, 64px);
    background: rgba(19, 13, 28, 0.9);
    -webkit-backdrop-filter: blur(28px) saturate(1.2); backdrop-filter: blur(28px) saturate(1.2);
    color: var(--sl-cream);
  }

  .sl-divider { width: 42px; height: 1px; background: rgba(183, 157, 230, 0.35); margin: 0.5rem 0; }

  .sl-logo { height: clamp(90px, 13vw, 200px); width: auto; margin-bottom: 0.4rem; }
  .sl-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(183, 157, 230, 0.16);
    border: 1px solid rgba(183, 157, 230, 0.4);
    border-radius: 999px; padding: 6px 14px;
    font-size: 0.68rem; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase;
  }

  .sl-title {
    font-family: var(--font-display); font-weight: 500; color: var(--sl-cream);
    font-size: clamp(2.1rem, 4.2vw, 3.3rem); line-height: 1.1; margin: 0;
  }
  .sl-title em { font-style: italic; color: var(--sl-violet); }
  .sl-title em.sl-accent-green { color: var(--sl-green); }
  .sl-tagline { line-height: 1.55; color: var(--sl-muted); font-size: 0.92rem; margin: 0; }

  .sl-auth-title { font-family: var(--font-display); font-weight: 500; font-size: clamp(1.3rem, 2vw, 1.6rem); margin: 0; color: var(--sl-cream); }
  .sl-sub { line-height: 1.55; color: var(--sl-muted); font-size: 0.92rem; margin: 0; }
  .sl-gbtn { margin-top: 0.3rem; }
  .sl-msg { color: var(--sl-violet); font-size: 0.85rem; margin: 0; }
  .sl-note { font-size: 0.78rem; color: rgba(244, 241, 247, 0.4); line-height: 1.5; margin: 0; }
  .sl-note button { background: none; border: none; padding: 0; color: var(--sl-violet); text-decoration: underline; font-size: inherit; font-family: inherit; cursor: pointer; }

  /* Mobile: el panel único ocupa la mitad superior (ancho completo), y el
     video se rota 90° para que el recorte que antes quedaba centro-izquierda
     (donde está la etiqueta en inglés) caiga bajo el panel, no en la mitad
     inferior despejada */
  @media (max-width: 860px) {
    .sl-video {
      inset: auto; top: 50%; left: 50%; right: auto; bottom: auto;
      width: 100vh; height: 100vw;
      transform: translate(-50%, -50%) rotate(90deg);
    }
    .sl-panel {
      left: 0; right: 0; top: 0; bottom: 48%; width: auto; height: auto;
      justify-content: center;
      gap: 0.5rem;
      padding: clamp(44px, 10vw, 56px) clamp(20px, 6vw, 28px) clamp(18px, 4vw, 26px);
    }
    .sl-logo { height: clamp(56px, 16vw, 90px); }
    .sl-title { font-size: clamp(1.6rem, 7vw, 2.2rem); }
  }
</style>
