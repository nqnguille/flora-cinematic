---
// Login compartido de todo el portal de socios (index, carta, cuenta, admin).
// Una sola experiencia visual: video de cultivo a pantalla completa + dos cards
// (marca a la izq., acceso con Google a la der.). Cada página sigue dueña de
// SU lógica de auth (distinto payload/POST-login), pero todas apuntan a los
// mismos ids (#socios-login, #g_id_button, #socios-login-msg) para que este
// componente sea el único lugar donde vive el diseño del login.
interface Props {
  eyebrow?: string
  title: string
  tagline?: string
  authTitle?: string
  authSub?: string
  backHref?: string
  hideNote?: boolean
  joinPrompt?: boolean
}
const {
  eyebrow,
  title,
  tagline,
  authTitle,
  authSub,
  backHref = '/',
  hideNote = false,
  joinPrompt = false,
} = Astro.props

// Imán para curiosos que todavía no son socios: la entrada por Google de
// arriba es para quien YA está en el padrón — esto es la puerta de al lado,
// para quien recién está averiguando. Los dos botones abren el MISMO modal
// (mismos 3 campos), con copy distinto según la intención — "Sí, tengo
// REPROCANN" pide acceso a la carta; "Todavía no" coordina la entrevista
// médica, el primer paso para tramitarlo (ver #sl-solicitud-modal).
---

<div id="socios-login" class="sl-login">
  <video class="sl-video" src="/hero/socios-login.mp4" poster="/hero/socios-login_poster.jpg" autoplay muted loop playsinline preload="auto" aria-hidden="true"></video>

  <a href={backHref} class="sl-back">← Volver al sitio</a>

  <div class="sl-split">
    <div class="sl-panel">
      {eyebrow && <span class="sl-eyebrow">{eyebrow}</span>}
      <img class="sl-logo" src="/img/flora-logo-white.png" alt="Flora" width="1472" height="298" />
      <h1 class="sl-title" set:html={title} />
      {tagline && <p class="sl-tagline">{tagline}</p>}

      {authTitle && <div class="sl-divider" aria-hidden="true"></div>}
      {authTitle && <h2 class="sl-auth-title">{authTitle}</h2>}
      {authSub && <p class="sl-sub">{authSub}</p>}
      <div id="g_id_button" class="sl-gbtn"></div>
      <p id="socios-login-msg" class="sl-msg" hidden></p>
      {!hideNote && <div class="sl-note"><slot name="note">Verificamos tu cuenta contra el padrón de socios · no compartimos tus datos.</slot></div>}

      {joinPrompt && (
        <div class="sl-join">
          <div class="sl-join-divider" aria-hidden="true"></div>
          <p class="sl-join-q">¿Tenés REPROCANN y querés ver nuestra carta?</p>
          <div class="sl-join-btns">
            <button type="button" id="sl-solicitud-open" data-intent="acceso" class="sl-join-btn">Sí, tengo REPROCANN</button>
            <button type="button" id="sl-entrevista-open" data-intent="entrevista" class="sl-join-btn sl-join-btn-ghost">Todavía no</button>
          </div>
        </div>
      )}
    </div>
  </div>

  {joinPrompt && (
    <!-- Un solo modal (mismos 3 campos), reusado por los dos botones de
         arriba con copy distinto según la intención — reemplaza los links
         directos a WhatsApp por un formulario corto que el equipo revisa y
         aprueba a mano desde /socios/admin (pestaña Solicitudes). -->
    <div id="sl-solicitud-modal" class="sl-solicitud-modal" hidden data-lenis-prevent>
      <div class="sl-solicitud-card" role="dialog" aria-modal="true" aria-labelledby="sl-solicitud-title">
        <button type="button" id="sl-solicitud-close" class="sl-solicitud-x" aria-label="Cerrar">✕</button>
        <h2 id="sl-solicitud-title" class="sl-solicitud-title">Solicitar acceso</h2>
        <form id="sl-solicitud-form" class="sl-solicitud-form">
          <label class="sl-solicitud-field">
            <span>Nombre y apellido</span>
            <input type="text" id="sl-sol-name" name="name" autocomplete="name" required />
          </label>
          <label class="sl-solicitud-field">
            <span>Email</span>
            <input type="email" id="sl-sol-email" name="email" autocomplete="email" placeholder="tu@gmail.com" pattern="[^\s@]+@gmail\.com" title="Tiene que ser un email de Gmail (terminado en @gmail.com)" required />
          </label>
          <label class="sl-solicitud-field">
            <span>Celular (WhatsApp)</span>
            <input type="tel" id="sl-sol-phone" name="phone" autocomplete="tel" placeholder="Tu número de WhatsApp" required />
          </label>
          <label class="sl-solicitud-field" id="sl-sol-file-field" hidden>
            <span>Foto o PDF de tu REPROCANN vigente <em>(opcional, agiliza la aprobación)</em></span>
            <input type="file" id="sl-sol-file" name="file" accept="image/jpeg,image/png,image/webp,application/pdf" />
          </label>
          <input type="text" id="sl-sol-website" name="website" class="sl-solicitud-hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <p id="sl-solicitud-msg" class="sl-solicitud-msg" hidden></p>
          <button type="submit" id="sl-solicitud-submit" class="sl-solicitud-submit">Solicitar acceso</button>
        </form>
        <div id="sl-solicitud-ok" class="sl-solicitud-ok" hidden>
          <p id="sl-solicitud-ok-msg">¡Listo! Recibimos tu solicitud — te contactamos por WhatsApp a la brevedad.</p>
          <button type="button" id="sl-solicitud-ok-close" class="sl-solicitud-submit">Cerrar</button>
        </div>
      </div>
    </div>

    <script>
      // Copy por intención: mismo modal, mismos campos, mensaje distinto.
      const SL_COPY = {
        acceso: {
          title: 'Solicitar acceso',
          submit: 'Solicitar acceso',
          ok: '¡Listo! Recibimos tu solicitud — te contactamos por WhatsApp a la brevedad.',
        },
        entrevista: {
          title: 'Coordinar entrevista médica',
          submit: 'Coordinar entrevista',
          ok: '¡Listo! Recibimos tu pedido — te contactamos por WhatsApp para coordinar tu entrevista médica.',
        },
      } as const
      type SlIntent = keyof typeof SL_COPY

      const slModal = document.getElementById('sl-solicitud-modal')
      if (slModal) {
        const openBtns = document.querySelectorAll<HTMLButtonElement>('[data-intent]')
        const closeBtn = document.getElementById('sl-solicitud-close')
        const okCloseBtn = document.getElementById('sl-solicitud-ok-close')
        const form = document.getElementById('sl-solicitud-form') as HTMLFormElement
        const okBlock = document.getElementById('sl-solicitud-ok') as HTMLElement
        const okMsg = document.getElementById('sl-solicitud-ok-msg') as HTMLElement
        const msg = document.getElementById('sl-solicitud-msg') as HTMLElement
        const submitBtn = document.getElementById('sl-solicitud-submit') as HTMLButtonElement
        const titleEl = document.getElementById('sl-solicitud-title') as HTMLElement
        const fileField = document.getElementById('sl-sol-file-field') as HTMLElement
        const fileInput = document.getElementById('sl-sol-file') as HTMLInputElement
        let intent: SlIntent = 'acceso'

        function open(next: SlIntent) {
          intent = next
          const copy = SL_COPY[intent]
          titleEl.textContent = copy.title
          submitBtn.textContent = copy.submit
          // El adjunto de REPROCANN solo tiene sentido si ya dice tenerlo —
          // quien pide la entrevista todavía no tramitó nada que adjuntar.
          fileField.hidden = intent !== 'acceso'
          fileInput.value = ''
          slModal!.hidden = false
          form.hidden = false
          okBlock.hidden = true
          msg.hidden = true
          ;(document.getElementById('sl-sol-name') as HTMLInputElement)?.focus()
        }
        function close() {
          slModal!.hidden = true
        }
        openBtns.forEach((btn) => {
          const btnIntent = (btn.dataset.intent as SlIntent) || 'acceso'
          btn.addEventListener('click', () => open(btnIntent))
        })
        closeBtn?.addEventListener('click', close)
        okCloseBtn?.addEventListener('click', close)
        slModal.addEventListener('click', (e) => { if (e.target === slModal) close() })
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !slModal!.hidden) close() })

        form.addEventListener('submit', async (e) => {
          e.preventDefault()
          msg.hidden = true
          submitBtn.disabled = true
          submitBtn.textContent = 'Enviando…'
          const data = new FormData(form)
          try {
            const res = await fetch('/api/socios/solicitud', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                name: String(data.get('name') || ''),
                email: String(data.get('email') || ''),
                phone: String(data.get('phone') || ''),
                website: String(data.get('website') || ''),
                intent,
              }),
            })
            const result = await res.json().catch(() => ({}))
            if (res.ok && result.ok) {
              // Paso 2, best-effort: si adjuntó archivo, subirlo aparte no
              // bloquea el "listo" — la solicitud ya quedó guardada igual.
              const file = fileInput.files?.[0]
              if (file) {
                try {
                  const fd = new FormData()
                  fd.append('email', String(data.get('email') || ''))
                  fd.append('file', file)
                  await fetch('/api/socios/solicitud-adjunto', { method: 'POST', body: fd })
                } catch { /* no afecta el éxito de la solicitud */ }
              }
              okMsg.textContent = SL_COPY[intent].ok
              form.hidden = true
              okBlock.hidden = false
            } else {
              msg.textContent = result.error || 'No se pudo enviar — probá de nuevo.'
              msg.hidden = false
            }
          } catch {
            msg.textContent = 'Error de red — probá de nuevo.'
            msg.hidden = false
          } finally {
            submitBtn.disabled = false
            submitBtn.textContent = SL_COPY[intent].submit
          }
        })
      }
    </script>
  )}
</div>

<style is:global>
  /* ═══════════════════════════════════════════════
     SOCIOS LOGIN — componente único para todo el portal
     Video de cultivo de fondo + dos cards de vidrio.
  ═══════════════════════════════════════════════ */
  .sl-login {
    --sl-cream:  #f4f1f7;
    --sl-muted:  rgba(244, 241, 247, 0.55);
    --sl-violet: #b79de6;
    --sl-green:  #3cb492;

    position: relative; overflow: hidden; isolation: isolate;
    min-height: 100svh;
    padding: 0;
    background: #130d1c;
    font-family: var(--font-ui);
  }
  .sl-login[hidden] { display: none; }

  .sl-video {
    position: absolute; inset: 0; z-index: 0;
    width: 100%; height: 100%; object-fit: cover;
    filter: saturate(1.05) brightness(0.9);
  }

  .sl-back {
    position: absolute; z-index: 3; top: var(--space-s); left: var(--space-s);
    color: rgba(244, 241, 247, 0.75); text-decoration: none; font-size: 0.85rem;
    font-family: var(--font-ui);
    text-shadow: 0 1px 12px rgba(0,0,0,0.6);
    transition: color 0.2s ease;
  }
  .sl-back:hover { color: var(--sl-cream); }

  /* Todo el contenido (marca + acceso) apilado en un único panel pegado al
     borde izquierdo; la mitad derecha de la pantalla queda 100% libre para
     el video */
  .sl-split {
    position: relative; z-index: 2;
    min-height: 100svh;
  }

  .sl-panel {
    position: absolute; top: 0; bottom: 0; left: 0;
    width: 58%;
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    text-align: center;
    gap: 0.7rem;
    padding: clamp(32px, 5vw, 64px);
    background: rgba(19, 13, 28, 0.9);
    -webkit-backdrop-filter: blur(28px) saturate(1.2); backdrop-filter: blur(28px) saturate(1.2);
    color: var(--sl-cream);
  }

  .sl-divider { width: 42px; height: 1px; background: rgba(183, 157, 230, 0.35); margin: 0.5rem 0; }

  .sl-logo { width: clamp(190px, 24vw, 300px); height: auto; margin-bottom: 0.4rem; }
  /* Misma "tarjeta black" que la card VIP de la home — metal oscuro en vez
     de la pastilla violeta plana, para que el primer texto que se lee ya
     tenga ese aire exclusivo. */
  .sl-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: linear-gradient(155deg, #221c2c 0%, #130f1a 55%, #060409 100%);
    border: 1px solid rgba(255,255,255,0.16);
    border-radius: 999px; padding: 7px 16px;
    font-size: 0.68rem; font-weight: 700; color: rgba(241,236,244,0.85);
    letter-spacing: 0.16em; text-transform: uppercase;
    box-shadow: 0 10px 22px -10px rgba(0,0,0,0.7), inset 0 1px 0 rgba(255,255,255,0.28), inset 0 -1px 2px rgba(0,0,0,0.6);
    text-shadow: 0 1px 2px rgba(0,0,0,0.5);
  }

  .sl-title {
    font-family: var(--font-display); font-weight: 500; color: var(--sl-cream);
    font-size: clamp(2.1rem, 4.2vw, 3.3rem); line-height: 1.1; margin: 0 auto;
  }
  .sl-title em { font-style: italic; color: var(--sl-violet); }
  .sl-title em.sl-accent-green { color: var(--sl-green); }
  .sl-tagline { line-height: 1.55; color: var(--sl-muted); font-size: 0.92rem; margin: 0 auto; }

  .sl-auth-title { font-family: var(--font-display); font-weight: 500; font-size: clamp(1.3rem, 2vw, 1.6rem); margin: 0; color: var(--sl-cream); }
  .sl-sub { line-height: 1.55; color: var(--sl-muted); font-size: 0.92rem; margin: 0 auto; }
  /* Halo pulsante detrás del botón nativo de Google para que resalte como
     la acción principal — no se puede tocar el estilo del botón en sí
     (vive dentro de un iframe de Google), así que el énfasis se agrega
     alrededor, en el wrapper */
  .sl-gbtn {
    position: relative;
    margin-top: 0.3rem;
    padding: 10px;
    display: flex; justify-content: center;
    width: fit-content; margin-left: auto; margin-right: auto;
  }
  /* box-shadow (no radial-gradient) a propósito: un gradiente circular
     centrado en una caja rectangular ancha (el botón es una píldora, no
     un cuadrado) queda más intenso a los costados que arriba/abajo — se
     nota como un halo parejo. box-shadow con blur+spread sigue el
     border-radius de la caja, así que crece igual de grueso en todo el
     contorno, sea cual sea su forma. */
  .sl-gbtn::before {
    content: '';
    position: absolute; inset: 2px; z-index: -1;
    border-radius: 999px;
    animation: sl-gbtn-glow 2.6s ease-in-out infinite;
  }
  @keyframes sl-gbtn-glow {
    0%, 100% { box-shadow: 0 0 10px 1px rgba(60, 180, 146, 0.4); }
    50% { box-shadow: 0 0 16px 4px rgba(60, 180, 146, 0.65); }
  }
  @media (prefers-reduced-motion: reduce) {
    .sl-gbtn::before { animation: none; box-shadow: 0 0 13px 2px rgba(60, 180, 146, 0.5); }
  }
  .sl-msg { color: var(--sl-violet); font-size: 0.85rem; margin: 0; }
  .sl-note { font-size: 0.78rem; color: rgba(244, 241, 247, 0.4); line-height: 1.5; margin: 0 auto; }
  .sl-note button { background: none; border: none; padding: 0; color: var(--sl-violet); text-decoration: underline; font-size: inherit; font-family: inherit; cursor: pointer; }

  /* Imán para curiosos: puerta de al lado del login, para quien todavía no
     es socio. Deliberadamente más chico y separado — la entrada con Google
     sigue siendo la acción principal de la pantalla. */
  .sl-join { display: flex; flex-direction: column; align-items: center; gap: 0.6rem; margin-top: 0.4rem; }
  .sl-join-divider { width: 42px; height: 1px; background: rgba(183, 157, 230, 0.35); }
  .sl-join-q { font-size: 0.82rem; color: var(--sl-muted); margin: 0; }
  .sl-join-btns { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; }
  .sl-join-btn {
    display: inline-flex; align-items: center; font-family: var(--font-ui);
    font-size: 0.78rem; font-weight: 700; text-decoration: none; white-space: nowrap;
    padding: 9px 16px; border-radius: 999px; border: 1px solid rgba(60, 180, 146, 0.5);
    background: rgba(60, 180, 146, 0.14); color: var(--sl-green);
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
  }
  .sl-join-btn:hover { background: rgba(60, 180, 146, 0.24); transform: translateY(-1px); }
  .sl-join-btn-ghost { background: none; border-color: rgba(244, 241, 247, 0.2); color: var(--sl-muted); }
  .sl-join-btn-ghost:hover { border-color: rgba(244, 241, 247, 0.4); background: rgba(244, 241, 247, 0.06); color: var(--sl-cream); }

  /* Modal "Ya tengo REPROCANN" */
  .sl-solicitud-modal {
    position: fixed; inset: 0; z-index: 200; display: flex; align-items: center; justify-content: center;
    padding: 1rem; background: rgba(10, 6, 16, 0.72); backdrop-filter: blur(2px);
  }
  .sl-solicitud-modal[hidden] { display: none; }
  .sl-solicitud-card {
    position: relative; width: 100%; max-width: 380px;
    background: #1b1326; border: 1px solid rgba(183, 157, 230, 0.18); border-radius: 20px;
    padding: clamp(24px, 4vw, 32px); box-shadow: 0 40px 90px -30px rgba(0, 0, 0, 0.9);
  }
  .sl-solicitud-x {
    position: absolute; top: 14px; right: 14px; background: none; border: none;
    color: var(--sl-muted); font-size: 1.1rem; line-height: 1; padding: 6px; cursor: pointer;
  }
  .sl-solicitud-x:hover { color: var(--sl-cream); }
  .sl-solicitud-title { font-family: var(--font-display); font-weight: 500; font-size: 1.4rem; color: var(--sl-cream); margin: 0 0 1.3rem; }
  .sl-solicitud-form { display: flex; flex-direction: column; gap: 0.9rem; }
  .sl-solicitud-form[hidden] { display: none; }
  .sl-solicitud-field { display: flex; flex-direction: column; gap: 0.35rem; font-size: 0.8rem; color: var(--sl-muted); }
  .sl-solicitud-field[hidden] { display: none; }
  .sl-solicitud-field em { font-style: normal; opacity: 0.75; }
  .sl-solicitud-field input[type="file"] {
    font-size: 0.78rem; color: var(--sl-muted);
    background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(244, 241, 247, 0.18);
    border-radius: 10px; padding: 0.55em 0.7em;
  }
  .sl-solicitud-field input:not([type="file"]) {
    font: inherit; font-size: 0.92rem; color: var(--sl-cream); background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(244, 241, 247, 0.18); border-radius: 10px; padding: 0.65em 0.8em;
  }
  .sl-solicitud-field input:focus-visible { outline: 2px solid var(--sl-violet); outline-offset: 1px; border-color: transparent; }
  .sl-solicitud-hp { position: absolute !important; left: -9999px !important; width: 1px; height: 1px; opacity: 0; }
  .sl-solicitud-msg { color: #ff9d9d; font-size: 0.82rem; margin: 0; }
  .sl-solicitud-submit {
    font-family: var(--font-ui); font-size: 0.88rem; font-weight: 700; cursor: pointer;
    padding: 0.75em 1em; border-radius: 999px; border: none;
    background: var(--sl-green); color: #08160f;
    transition: opacity 0.2s ease, transform 0.15s ease;
  }
  .sl-solicitud-submit:hover:not(:disabled) { transform: translateY(-1px); }
  .sl-solicitud-submit:disabled { opacity: 0.6; cursor: default; }
  .sl-solicitud-ok p { font-size: 0.92rem; color: var(--sl-cream); line-height: 1.5; margin: 0 0 1.1rem; }

  /* Mobile: el panel único ocupa la mitad superior (ancho completo), y el
     video se rota 90° para que el recorte que antes quedaba centro-izquierda
     (donde está la etiqueta en inglés) caiga bajo el panel, no en la mitad
     inferior despejada */
  @media (max-width: 860px) {
    .sl-video {
      inset: auto; top: 50%; left: 50%; right: auto; bottom: auto;
      width: 100vh; height: 100vw;
      transform: translate(-50%, -50%) rotate(90deg);
    }
    .sl-panel {
      left: 0; right: 0; top: 0; bottom: 42%; width: auto; height: auto;
      overflow-y: auto;
      /* "safe center": centra igual que antes cuando el contenido entra
         en pantallas altas, pero en pantallas bajas (iPhone SE y
         similares) donde antes el contenido se desbordaba hacia arriba
         y tapaba el link "Volver al sitio", cae a flex-start en vez de
         seguir centrando fuera de los límites del panel */
      justify-content: safe center;
      gap: 1.15rem;
      padding: clamp(52px, 10vw, 56px) clamp(20px, 6vw, 28px) clamp(18px, 4vw, 26px);
    }
    .sl-logo { width: clamp(190px, 52vw, 260px); }
    .sl-title { font-size: clamp(1.5rem, 6.6vw, 2.1rem); }

    /* Título, tagline y nota comparten un ancho de columna parecido
       (centrados) para que el bloque se vea simétrico — solo en mobile,
       donde el panel es angosto; en desktop el título necesita su ancho
       natural para no romper el salto de línea a la altura de "para".
       .sl-gbtn queda afuera: si comparte este ancho forzado, el botón de
       Google (más angosto) queda descentrado dentro de esa caja y el halo
       alrededor se ve parejo solo a los costados, no arriba/abajo. */
    .sl-title, .sl-tagline, .sl-sub {
      width: min(320px, 78%); margin-left: auto; margin-right: auto;
    }
    .sl-note {
      width: min(360px, 88%); margin-left: auto; margin-right: auto;
    }
  }

  /* Pantallas bajas (iPhone SE y similares, ~667px de alto o menos): el
     contenido completo (logo + título + botón + nota + REPROCANN) no
     entra parado a tamaño normal. Se achica un poco todo para que se
     vea entero sin necesidad de scroll dentro del panel. */
  @media (max-width: 860px) and (max-height: 720px) {
    .sl-panel { gap: 0.7rem; padding-top: clamp(48px, 9vw, 52px); }
    .sl-logo { width: clamp(150px, 40vw, 190px); }
    .sl-title { font-size: clamp(1.25rem, 5.6vw, 1.7rem); }
    .sl-tagline, .sl-sub { font-size: 0.85rem; }
    .sl-note { font-size: 0.72rem; }
  }
</style>
