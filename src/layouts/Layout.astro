---
interface Props {
  title?: string
  description?: string
  ogImage?: string
  canonical?: string
}

const {
  title = 'Flora ONG — Cannabis medicinal en Neuquén, Patagonia',
  description = 'Club de cultivo de cannabis medicinal bajo Ley 27.350 y marco REPROCANN. Cultivo propio, aceites con cromatografía y acompañamiento real. Neuquén, Patagonia.',
  ogImage = 'https://floraong.ar/og-image.jpg',
  canonical = 'https://floraong.ar',
} = Astro.props

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "NGO",
  "name": "Flora ONG",
  "alternateName": "Asociación Civil Cann de Cannabis Medicinal",
  "description": "Asociación civil de cultivo solidario de cannabis medicinal bajo Ley 27.350 / REPROCANN. Neuquén, Patagonia.",
  "url": "https://floraong.ar",
  "logo": "https://floraong.ar/favicon.png",
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer support",
    "telephone": "+5492996375723",
    "availableLanguage": "Spanish"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Neuquén",
    "addressRegion": "Neuquén",
    "addressCountry": "AR"
  },
  "areaServed": "AR",
  "foundingDate": "2022",
  "sameAs": [
    "https://www.instagram.com/flora.cultivamosconciencia/",
    "https://www.youtube.com/@FloraCultivamosConciencia"
  ],
  "knowsAbout": [
    "Cannabis medicinal",
    "Cultivo solidario",
    "Ley 27.350",
    "REPROCANN"
  ]
}
---

<!doctype html>
<html lang="es-AR" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#381F56" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Flora ONG" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Flora ONG — Club de cultivo de cannabis medicinal en Neuquén" />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Flora ONG — Club de cultivo de cannabis medicinal en Neuquén" />

    <noscript><style>.page-loader{display:none!important}</style></noscript>

    <!-- Favicon — la O de FLORA con la hoja -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Preconnect fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Fuentes: Cormorant (display editorial) + Hanken Grotesk (UI) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
    <script>
      import '../scripts/main.ts'
    </script>

    <!-- Tracking: visitas + clics de CTA → dashboard central gates-analytics (project flora-ong).
         Para medir un botón/link, agregale data-cta="etiqueta". -->
    <script is:inline>
      (function () {
        var ENDPOINT = 'https://gates-analytics.nqnguille.workers.dev/event';
        var PROJECT = 'flora-ong';
        function gid(p) {
          try {
            var s = p === 'visitor' ? localStorage : sessionStorage;
            var k = 'floraong_' + p + '_id';
            var v = s.getItem(k);
            if (!v) { v = p + '-' + (crypto.randomUUID ? crypto.randomUUID() : (Date.now() + '-' + Math.random().toString(16).slice(2))); s.setItem(k, v); }
            return v;
          } catch (e) { return p + '-unknown'; }
        }
        function send(event, key) {
          try {
            var body = JSON.stringify({ project: PROJECT, gate: 'sitio', event: event, key: key || '', visitor_id: gid('visitor'), session_id: gid('session'), path: location.pathname, lang: document.documentElement.lang || 'es' });
            // text/plain = CORS-safelisted: el beacon dispara cross-origin sin preflight; el central igual parsea JSON.
            if (navigator.sendBeacon) navigator.sendBeacon(ENDPOINT, new Blob([body], { type: 'text/plain' }));
            else fetch(ENDPOINT, { method: 'POST', headers: { 'Content-Type': 'text/plain' }, body: body, keepalive: true });
          } catch (e) {}
        }
        // Vista de página (una vez por sesión + path)
        try {
          var vk = 'floraong_view_' + location.pathname;
          if (sessionStorage.getItem(vk) !== '1') { sessionStorage.setItem(vk, '1'); send('view'); }
        } catch (e) { send('view'); }
        // Clics en CTAs marcados con data-cta
        document.addEventListener('click', function (e) {
          var el = e.target && e.target.closest ? e.target.closest('[data-cta]') : null;
          if (!el) return;
          send('click', el.getAttribute('data-cta') || (el.textContent || '').trim().slice(0, 40) || 'cta');
        }, true);
      })();
    </script>
  </body>
</html>
