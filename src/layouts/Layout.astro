---
interface Props {
  title?: string
  description?: string
  ogImage?: string
  canonical?: string
}

const {
  title = 'Flora ONG — Cannabis medicinal en Neuquén, Patagonia',
  description = 'Club de cultivo de cannabis medicinal bajo Ley 27.350 y marco REPROCANN. Acceso continuo, trazabilidad por lote, sin intermediarios. Neuquén, Patagonia.',
  ogImage = 'https://flora.pages.dev/og-image.jpg',
  canonical = 'https://flora.pages.dev',
} = Astro.props

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "NGO",
  "name": "Flora ONG",
  "alternateName": "Flora Club de Cultivo",
  "description": "Club de cultivo de cannabis medicinal bajo Ley 27.350 / REPROCANN. Membresías de cultivo compartido en Neuquén, Patagonia.",
  "url": "https://flora.pages.dev",
  "logo": "https://flora.pages.dev/favicon.svg",
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer support",
    "availableLanguage": "Spanish"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Neuquén",
    "addressRegion": "Neuquén",
    "addressCountry": "AR"
  },
  "areaServed": "AR",
  "foundingDate": "2022",
  "knowsAbout": [
    "Cannabis medicinal",
    "Cultivo compartido",
    "Ley 27.350",
    "REPROCANN"
  ]
}
---

<!doctype html>
<html lang="es-AR" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#1C2B1C" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Flora ONG" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Flora ONG — Club de cultivo de cannabis medicinal en Neuquén" />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Flora ONG — Club de cultivo de cannabis medicinal en Neuquén" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Preconnect fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Fuentes: Cormorant (display editorial) + Hanken Grotesk (UI) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
    <script>
      import '../scripts/main.ts'
    </script>
  </body>
</html>
