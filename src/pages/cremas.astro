---
import CatalogoShell from '../components/CatalogoShell.astro'
import { cremas } from '../lib/productos'
---

<CatalogoShell
  title="Cremas de cannabis medicinal | Flora ONG"
  description="Crema tópica de cannabis medicinal para alivio localizado, formulada con extracto de nuestro propio cultivo."
  categoria="cremas"
>
  <section class="fl-section" aria-label="Cremas">
    <div class="fl-wrap">
      <div class="fl-spec">
        <div class="fl-spec-head">
          <span class="fl-eyebrow">Nuestras cremas</span>
          <h1 class="fl-spec-title">Alivio localizado, <em>sin humo.</em></h1>
          <p class="fl-spec-sub">
            La crema aplica el extracto directamente donde lo necesitás. Formulada con
            el mismo cultivo medido por cromatografía que nuestros aceites, para uso
            diario y sin efecto psicoactivo.
          </p>
        </div>

        <div class="fl-spec-grid td-grid-1">
          {cremas.map((c) => (
            <article class="fl-spec-card fl-oil-card" style="--oil:#0A503C">
              <div class="fl-oil-photo" data-id={c.id}>
                <img src={c.img} alt={`${c.nombre} Flora, ${c.presentacion}`} loading="lazy" width="600" height="750" />
                <span class="fl-oil-badge">{c.presentacion}</span>
              </div>
              <div class="fl-oil-body">
                <h2 class="fl-oil-title">{c.nombre}</h2>
                <p class="fl-oil-desc">{c.desc}</p>

                <div class="fl-oil-para">
                  <span class="fl-oil-para-label">Puede acompañar en</span>
                  <ul class="fl-oil-para-list">
                    {c.para.map((p) => <li>{p}</li>)}
                  </ul>
                </div>

                <div class="td-buy td-onlight" data-buy={c.id} hidden>
                  <span class="td-buy-label">Reservar</span>
                  <div class="td-buy-row">
                    <span class="td-precio" data-id={c.id}></span>
                    <div class="td-slot" data-id={c.id}></div>
                  </div>
                </div>

                <div class="fl-oil-actions">
                  <a class="fl-oil-btn" href={c.href} target="_blank" rel="noopener noreferrer">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.4 1.3 4.9L2 22l5.3-1.4c1.4.8 3 1.2 4.7 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2zm0 18.2c-1.5 0-3-.4-4.3-1.2l-.3-.2-3.1.8.8-3-.2-.3C4 13.8 3.5 12.4 3.5 12 3.5 7.3 7.3 3.5 12 3.5S20.5 7.3 20.5 12 16.7 20.2 12 20.2zm4.5-5.8c-.3-.1-1.7-.8-1.9-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.5-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1.1 2.8 1.2 3c.1.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.3.2-1.4-.1-.1-.3-.2-.6-.3z"/></svg>
                    Consultar por la crema
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</CatalogoShell>
