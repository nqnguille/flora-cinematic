---
import CatalogoShell from '../components/CatalogoShell.astro'
import { extracciones } from '../lib/productos'

const iconoCartucho = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M10 3.5h4v3h-4z"/><path d="M9.5 6.5h5a1 1 0 0 1 1 1V19a1.5 1.5 0 0 1-1.5 1.5h-4A1.5 1.5 0 0 1 8.5 19V7.5a1 1 0 0 1 1-1Z"/><path d="M8.5 11h7"/></svg>`
const iconoBateria = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="5" width="8" height="16" rx="2"/><path d="M10.5 3h3"/><path d="m12.8 9-2 4h2.4l-2 4"/></svg>`
---

<CatalogoShell
  title="Extracciones — cartuchos y baterías 510 | Flora ONG"
  description="Cartuchos 510 de THC y CBD y baterías recargables. Uso discreto y dosificado, con extracto de nuestro cultivo."
  categoria="extracciones"
>
  <section class="fl-section" aria-label="Extracciones">
    <div class="fl-wrap">
      <div class="fl-spec">
        <div class="fl-spec-head">
          <span class="fl-eyebrow">Nuestras extracciones</span>
          <h1 class="fl-spec-title">Discreto, dosificado, <em>al toque.</em></h1>
          <p class="fl-spec-sub">
            Cartuchos rosca 510 con extracto de nuestro cultivo, en perfiles de THC y CBD,
            y la batería universal para usarlos. La forma más práctica de llevar tu
            tratamiento encima.
          </p>
        </div>

        <div class="fl-spec-grid td-ext-grid">
          {extracciones.map((x) => (
            <article class="fl-spec-card fl-oil-card" style={`--oil:${x.color}`}>
              <div class="fl-oil-photo">
                {x.img
                  ? <img src={x.img} alt={`${x.nombre} ${x.detalle} Flora`} loading="lazy" width="600" height="750" />
                  : <span class="td-ext-visual" style={`color:${x.color}`} set:html={x.id === 'bateria-510' ? iconoBateria : iconoCartucho} />}
                {(x.detalle === 'THC' || x.detalle === 'CBD') && <span class="fl-oil-badge">{x.detalle}</span>}
              </div>

              <div class="fl-oil-body">
                <h2 class="fl-oil-title">{x.nombre} · {x.detalle}</h2>
                <p class="fl-oil-desc">{x.desc}</p>

                <div class="td-buy td-onlight" data-buy={x.id} hidden>
                  <span class="td-buy-label">Reservar</span>
                  <div class="td-buy-row">
                    <span class="td-precio" data-id={x.id}></span>
                    <div class="td-slot" data-id={x.id}></div>
                  </div>
                </div>

                <div class="fl-oil-actions">
                  <a class="fl-oil-btn" href={x.href} target="_blank" rel="noopener noreferrer">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.4 1.3 4.9L2 22l5.3-1.4c1.4.8 3 1.2 4.7 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2zm0 18.2c-1.5 0-3-.4-4.3-1.2l-.3-.2-3.1.8.8-3-.2-.3C4 13.8 3.5 12.4 3.5 12 3.5 7.3 7.3 3.5 12 3.5S20.5 7.3 20.5 12 16.7 20.2 12 20.2zm4.5-5.8c-.3-.1-1.7-.8-1.9-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.5-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1.1 2.8 1.2 3c.1.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.3.2-1.4-.1-.1-.3-.2-.6-.3z"/></svg>
                    {x.id === 'bateria-510' ? 'Consultar por la batería' : 'Consultar por este cartucho'}
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</CatalogoShell>
