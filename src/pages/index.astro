]

const steps = [
  {
    num: '01',
    title: 'Completás el formulario de ingreso',
    desc: 'Dos minutos. Nos contás tu situación, si tenés REPROCANN o si estás en trámite. Sin papeles físicos por ahora.',
  },
  {
    num: '02',
    title: 'Revisamos tu solicitud',
    desc: 'El equipo de Flora la revisa en 24 a 48 horas hábiles. Te avisamos por WhatsApp cuando está aprobada.',
  },
  {
    num: '03',
    title: 'Elegís tu membresía',
    desc: 'Una vez adentro, elegís el plan que se ajusta a tu uso y lo podés cambiar cuando quieras.',
  },
  {
    num: '04',
    title: 'Accedés al cultivo compartido',
    desc: 'Recibís tu parte del cultivo del mes, dentro del marco legal del club, con acceso directo y acompañado.',
  },
]

// Programa de YouTube — "Espacio libre de prejuicios"
const ytChannel = 'https://www.youtube.com/@FloraCultivamosConciencia'
const episodes = [
  { id: 'lqiDznxJHgE', title: 'Dolor crónico: ¿THC o CBD?', dur: '25:07' },
  { id: '69kQ-XoVmuU', title: 'Ansiedad y estrés', dur: '29:41' },
]

// Instagram — slider en vivo. El feed lo sirve Behold (behold.so): JSON con
// imágenes hosteadas estables + CORS, refresco automático del token. Si no
// responde, se muestran estas tarjetas de respaldo y el botón al perfil.
const igHandle = '@flora.cultivamosconciencia'
const igProfile = 'https://www.instagram.com/flora.cultivamosconciencia/'
const igFeedUrl = 'https://feeds.behold.so/BdL7J34neXVcfDDQ3Qe2'
const igFallback = [
  { caption: 'Efecto séquito: por qué la planta entera funciona mejor que un cannabinoide aislado.' },
  { caption: 'Cómo elegir tu aceite: quimiotipo, relación CBD:THC y para qué sirve cada uno.' },
  { caption: 'Punto de corte: cuándo se cosecha y por qué cambia el efecto final.' },
  { caption: 'REPROCANN al día: qué cambió en la última resolución y cómo te afecta.' },
  { caption: 'Derribando mitos: lo que se dice del THC y lo que dice la evidencia.' },
