---

<Layout
  title="Flora ONG — Club de cultivo de cannabis medicinal en Neuquén"
  description="Club de cultivo bajo Ley 27.350 / REPROCANN. Acceso mensual a cultivo propio y aceites con cromatografía, con acompañamiento real. Neuquén, Patagonia, Argentina."
>

  <!-- Skip to content para navegación por teclado -->
  <a class="skip-link" href="#inicio">Ir al contenido principal</a>

  <!-- Page loader -->
  <div class="page-loader" role="status" aria-label="Cargando Flora ONG">
    <span class="loader-logo">Flora</span>
    <span class="loader-tagline">Cannabis medicinal</span>
    <div class="loader-progress" aria-hidden="true"></div>
  </div>

  <!-- Scroll progress bar -->
  <div class="scroll-progress" aria-hidden="true" role="progressbar" aria-valuemin="0" aria-valuemax="100"></div>

  <!-- Nav fija -->
  <nav class="site-nav" aria-label="Navegación principal">
    <a href="#inicio" class="nav-logo" aria-label="Flora ONG — inicio">Flora</a>

    <!-- Desktop links -->
    <ul class="nav-links" role="list">
      <li><a href="#perfiles">Para qué</a></li>
      <li><a href="#flora">Por qué Flora</a></li>
      <li><a href="#productos">Productos</a></li>
      <li><a href="#legalidad">Legalidad</a></li>
      <li><a href="#membresias">Membresías</a></li>
      <li><a href="#programa">Programa</a></li>
      <li>
        <a href={waAsociarse} class="nav-cta" target="_blank" rel="noopener noreferrer">
          Asociarme
        </a>
      </li>
    </ul>

    <!-- Hamburguesa — solo mobile -->
    <button
      class="nav-hamburger"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-drawer"
    >
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
    </button>
  </nav>

  <!-- Drawer mobile -->
  <div class="mobile-drawer" id="mobile-drawer" role="dialog" aria-modal="true" aria-label="Menú de navegación" hidden>
    <div class="drawer-backdrop"></div>
    <nav class="drawer-panel" aria-label="Navegación mobile">
      <button class="drawer-close" aria-label="Cerrar menú">
        <span aria-hidden="true">✕</span>
      </button>
      <ul role="list">
        <li><a href="#nosotros">Nosotros</a></li>
        <li><a href="#perfiles">Para qué sirve</a></li>
        <li><a href="#flora">Por qué Flora</a></li>
        <li><a href="#productos">Productos</a></li>
        <li><a href="#legalidad">Legalidad</a></li>
        <li><a href="#membresias">Membresías</a></li>
        <li><a href="#como-funciona">Cómo funciona</a></li>
        <li><a href="#programa">Programa</a></li>
        <li>
          <a href={waAsociarse} class="drawer-cta" target="_blank" rel="noopener noreferrer">
            Asociarme por WhatsApp
          </a>
        </li>
      </ul>
    </nav>
  </div>

  <!-- ══════════════════════════════════════════ -->
  <!-- WELCOME — relato de bienvenida (scroll-story) -->
  <!-- ══════════════════════════════════════════ -->
  <section class="welcome" id="inicio" aria-label="Bienvenida a Flora">
    <div class="welcome-stage">

      <!-- Fondos en video que evolucionan — decorativos -->
      <div class="welcome-bg" aria-hidden="true">
        <video class="welcome-img" data-bg="0" src="/welcome/01-llegada.mp4" poster="/welcome/01-llegada_poster.jpg" muted loop playsinline preload="auto" width="1600" height="900"></video>
        <video class="welcome-img" data-bg="1" src="/welcome/02-recibida.mp4" poster="/welcome/02-recibida_poster.jpg" muted loop playsinline preload="none" width="1600" height="900"></video>
        <video class="welcome-img" data-bg="2" src="/welcome/03-acompanamiento.mp4" poster="/welcome/03-acompanamiento_poster.jpg" muted loop playsinline preload="none" width="1600" height="900"></video>
        <video class="welcome-img" data-bg="3" src="/welcome/04-calidad.mp4" poster="/welcome/04-calidad_poster.jpg" muted loop playsinline preload="none" width="1600" height="900"></video>
        <video class="welcome-img" data-bg="4" src="/welcome/05-flora.mp4" poster="/welcome/05-flora_poster.jpg" muted loop playsinline preload="none" width="1600" height="900"></video>
        <div class="welcome-scrim"></div>
      </div>

      <!-- Relato -->
      <div class="welcome-content">
        <div class="welcome-lines">
          <p class="welcome-line" data-line="0">Qué bueno que llegaste.</p>
          <p class="welcome-line" data-line="1">Acá no hay estigmas.</p>
          <p class="welcome-line" data-line="2">Solo acompañamiento,</p>
          <p class="welcome-line" data-line="3">calidad y acceso legal.</p>
          <p class="welcome-line welcome-line-final" data-line="4">Bienvenido a <em>Flora</em>.</p>
        </div>

        <div class="welcome-outro">
          <span class="welcome-badge">Ley 27.350 · REPROCANN · Neuquén, Patagonia</span>
          <div class="welcome-ctas">
            <a href={waAsociarse} class="btn-primary" target="_blank" rel="noopener noreferrer">
              Quiero asociarme
            </a>
            <a href="#perfiles" class="btn-secondary">Conocer Flora</a>
          </div>
        </div>
      </div>

      <!-- Indicador de scroll -->
      <div class="welcome-cue" aria-hidden="true">
        <span class="welcome-cue-label">deslizá</span>
        <span class="welcome-cue-line"></span>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- MANIFIESTO — escena documental (reveal, sin pin) -->
  <!-- ══════════════════════════════════════════ -->
  <section class="scene manifiesto" id="manifiesto" aria-label="Nuestro manifiesto">

    <!-- Plano sostenido: una sola still documental + scrim del welcome -->
    <div class="scene-bg" aria-hidden="true">
      <img
        class="scene-img"
        src="/hero/cannabis-hero-poster.jpg"
        alt=""
        loading="lazy"
        decoding="async"
        width="1280"
        height="720"
      />
      <div class="scene-scrim"></div>
    </div>

    <div class="scene-content manifiesto-content">
      <span class="eyebrow reveal">Nuestro manifiesto</span>

      <h2 class="manifiesto-title reveal" data-reveal-delay="80">
        Cultivamos conciencia,<br><em>planta por planta.</em>
      </h2>

      <p class="manifiesto-sub reveal" data-reveal-delay="160">
        Cultivo propio y acompañamiento real, dentro del marco de la Ley&nbsp;27.350
        y el REPROCANN.
      </p>

      <span class="scene-legal reveal" data-reveal-delay="240">
        Neuquén, Patagonia · Asociación civil · Est. 2022
      </span>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- STATS                                      -->
  <!-- ══════════════════════════════════════════ -->
  <section class="stats-section" id="nosotros" aria-label="Flora en números">
    <div class="stats-inner">
      <div class="stats-head">
        <span class="eyebrow on-light reveal">Flora en números</span>
        <h2 class="section-title reveal" data-reveal-delay="80">Una comunidad<br><em>que ya está.</em></h2>
      </div>

      <div class="stats-grid">
        <div class="stat-item reveal">
          <span class="stat-number">200<span class="stat-plus">+</span></span>
          <span class="stat-label">Asociados activos</span>
        </div>
        <div class="stat-item reveal" data-reveal-delay="80">
          <span class="stat-number">3<span class="stat-unit"> años</span></span>
          <span class="stat-label">Cultivando, desde 2022</span>
        </div>
        <div class="stat-item stat-anchor reveal" data-reveal-delay="160">
          <span class="stat-number">I·II·III</span>
          <span class="stat-label">Quimiotipos verificados por HPLC</span>
        </div>
      </div>

      <span class="stats-badge reveal" data-reveal-delay="220">Ley nacional 27.350 · REPROCANN</span>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- PERFILES — ¿Por qué llegaste a Flora?      -->
  <!-- ══════════════════════════════════════════ -->
  <section class="perfiles-section" id="perfiles" aria-label="Por qué llegaste a Flora">
    <div class="perfiles-inner">
      <div class="perfiles-head">
        <span class="eyebrow reveal">¿Por qué llegaste?</span>
        <h2 class="section-title on-dark reveal" data-reveal-delay="80">Cada camino<br><em>tiene su planta.</em></h2>
        <p class="perfiles-lead reveal" data-reveal-delay="140">
          El cannabis medicinal abarca muchos caminos. El equipo orienta el tuyo
          según tu situación. Contanos qué te trae y avanzamos desde ahí.
        </p>
      </div>

      <div class="ed-list" role="list">
        {perfiles.map((p, i) => (
          <article class="ed-row reveal" role="listitem" data-reveal-delay={i * 80}>
            <span class="ed-num" aria-hidden="true">0{i + 1}</span>
            <div class="ed-body">
              <span class="ed-kicker">{p.tag}</span>
              <h3 class="ed-title">{p.title}</h3>
              <p class="ed-desc">{p.desc}</p>
              <a class="ed-cta" href={p.href} target="_blank" rel="noopener noreferrer">
                {p.cta} <span aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- POR QUÉ FLORA — BENTO                      -->
  <!-- ══════════════════════════════════════════ -->
  <section class="why-section" id="flora" aria-label="Por qué Flora">
    <div class="why-inner">

      <div class="why-head">
        <span class="eyebrow on-light reveal">Por qué Flora</span>
        <h2 class="why-lead reveal" data-reveal-delay="80">
          Sabés <em>exactamente</em> qué recibís, de la planta a tu mano.
        </h2>
        <p class="why-sub reveal" data-reveal-delay="140">
          Cultivo propio, marco legal y el equipo acompañando cada paso, dentro de la Ley&nbsp;27.350 y el REPROCANN.
        </p>
      </div>

      <div class="ed-list" role="list">
        <article class="ed-row reveal" role="listitem">
          <span class="ed-num" aria-hidden="true">01</span>
          <div class="ed-body">
            <h3 class="ed-title">Cultivo propio</h3>
            <p class="ed-desc">Cultivamos nuestras plantas en sala controlada, sin pesticidas. Vos accedés a tu parte como socio de la asociación.</p>
          </div>
        </article>

        <article class="ed-row is-anchor reveal" role="listitem" data-reveal-delay="80">
          <span class="ed-num" aria-hidden="true">02</span>
          <div class="ed-body">
            <span class="ed-kicker">El dato verificable</span>
            <h3 class="ed-title">Aceites con cromatografía</h3>
            <p class="ed-desc">Nuestros tres aceites —Q1, Q2 y Q3— tienen análisis HPLC que informa su concentración real de CBD, THC y CBG. El único dato que se puede comprobar, por escrito.</p>
          </div>
        </article>

        <article class="ed-row reveal" role="listitem">
          <span class="ed-num" aria-hidden="true">03</span>
          <div class="ed-body">
            <h3 class="ed-title">Marco legal vigente</h3>
            <p class="ed-desc">Operamos dentro de la Ley 27.350 y el REPROCANN. Tu acceso es como socio de la asociación, con todo en regla.</p>
          </div>
        </article>

        <article class="ed-row reveal" role="listitem">
          <span class="ed-num" aria-hidden="true">04</span>
          <div class="ed-body">
            <h3 class="ed-title">Acompañamiento real</h3>
            <p class="ed-desc">Respondemos por WhatsApp. Una persona del equipo, no un bot, porque tus preguntas merecen respuestas.</p>
          </div>
        </article>

        <article class="ed-row reveal" role="listitem">
          <span class="ed-num" aria-hidden="true">05</span>
          <div class="ed-body">
            <h3 class="ed-title">Educación que acompaña</h3>
            <p class="ed-desc">Te explicamos cada cannabinoide, cada vía de consumo y cada paso. Cultivamos conciencia.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- PRODUCTOS — Flores / Aceites / Crema       -->
  <!-- ══════════════════════════════════════════ -->
  <section class="productos-section" id="productos" aria-label="Nuestros productos">
    <div class="productos-inner">
      <div class="productos-head">
        <span class="eyebrow reveal">Nuestros productos</span>
        <h2 class="section-title on-dark reveal" data-reveal-delay="80">Tres formas<br><em>de acceder.</em></h2>
        <p class="productos-lead reveal" data-reveal-delay="140">
          Flor de cultivo propio, aceites sublinguales con cromatografía y crema
          tópica. Todo con el acompañamiento del equipo.
        </p>
      </div>

      <!-- Selector de formato -->
      <div class="prod-tabs" role="tablist" aria-label="Formatos disponibles">
        <button class="prod-tab is-active" role="tab" id="tab-flores" aria-controls="panel-flores" aria-selected="true" tabindex="0" data-tab="flores">
          <span class="prod-tab-name">Flores</span>
          <span class="prod-tab-sub">Membresía mensual</span>
        </button>
        <button class="prod-tab" role="tab" id="tab-aceites" aria-controls="panel-aceites" aria-selected="false" tabindex="-1" data-tab="aceites">
          <span class="prod-tab-name">Aceites</span>
          <span class="prod-tab-sub">Q1 · Q2 · Q3</span>
        </button>
        <button class="prod-tab" role="tab" id="tab-cremas" aria-controls="panel-cremas" aria-selected="false" tabindex="-1" data-tab="cremas">
          <span class="prod-tab-name">Crema</span>
          <span class="prod-tab-sub">50cc · 100cc</span>
        </button>
      </div>

      <!-- Panel: Flores -->
      <div class="prod-panel is-active" role="tabpanel" id="panel-flores" aria-labelledby="tab-flores" data-panel="flores">
        <p class="prod-panel-lead">
          Flor seca de cultivo propio. Cada lote con perfil completo de cannabinoides
          y terpenos. Se accede por membresía mensual, sin contratos.
        </p>
        <div class="prod-flores-cta">
          <div>
            <span class="prod-flores-eyebrow">Cuatro planes</span>
            <p class="prod-flores-text">Semilla 10g · Raíz 20g · Cosecha 30g · Tierra 40g por mes.</p>
          </div>
          <a class="prod-link" href="#membresias">Ver planes de flores ↓</a>
        </div>
      </div>

      <!-- Panel: Aceites -->
      <div class="prod-panel" role="tabpanel" id="panel-aceites" aria-labelledby="tab-aceites" data-panel="aceites" hidden>
        <p class="prod-panel-lead">
          Extractos sublinguales de producción propia. Tres quimiotipos con distinta
          relación CBD:THC, cada uno con su análisis de cromatografía.
        </p>
        <div class="prod-cards">
          {aceites.map((a) => (
            <article class="prod-card">
              <span class="prod-card-eyebrow">Aceite medicinal</span>
              <span class="prod-card-big">{a.codigo}</span>
              <span class="prod-card-sub">{a.sub}</span>
              <p class="prod-card-desc">{a.desc}</p>
              <dl class="prod-perfil" aria-label={`Perfil de cannabinoides de ${a.codigo} en mg/mL`}>
                {a.perfil.map((p) => (
                  <div class="prod-perfil-item">
                    <dt>{p.k}</dt>
                    <dd>{p.v}</dd>
                  </div>
                ))}
              </dl>
              <div class="prod-tags">
                {a.usos.map((u) => <span class="prod-tag-pill">{u}</span>)}
              </div>
              <a class="prod-card-cta" href={a.href} target="_blank" rel="noopener noreferrer">
                Consultar {a.codigo} →
              </a>
            </article>
          ))}
        </div>
        <p class="prod-foot">Valores en mg/mL de la última cromatografía (HPLC-UV · IACA Laboratorios · junio 2026). Disponibilidad por consulta.</p>
      </div>

      <!-- Panel: Crema -->
      <div class="prod-panel" role="tabpanel" id="panel-cremas" aria-labelledby="tab-cremas" data-panel="cremas" hidden>
        <p class="prod-panel-lead">
          Formulación tópica antiinflamatoria de uso externo. Una fórmula, dos
          presentaciones. Para dolor localizado, articulaciones y recuperación muscular.
        </p>
        <div class="prod-cards prod-cards-2">
          {cremas.map((c) => (
            <article class="prod-card">
              <span class="prod-card-eyebrow">Presentación</span>
              <span class="prod-card-big">{c.presentacion}</span>
              <span class="prod-card-sub">{c.sub}</span>
              <p class="prod-card-desc">{c.desc}</p>
              <a class="prod-card-cta" href={c.href} target="_blank" rel="noopener noreferrer">
                Consultar {c.presentacion} →
              </a>
            </article>
          ))}
        </div>
        <p class="prod-foot">Uso externo. No requiere REPROCANN. Disponibilidad por consulta.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- LEGALIDAD — Marco legal                    -->
  <!-- ══════════════════════════════════════════ -->
  <section class="legal-section" id="legalidad" aria-label="Marco legal">
    <div class="legal-inner">

      <div class="legal-head">
        <span class="eyebrow on-light reveal">Marco legal</span>
        <h2 class="section-title reveal" data-reveal-delay="80">Operamos dentro<br><em>de la ley.</em></h2>
        <p class="legal-lead reveal" data-reveal-delay="140">
          Flora es una asociación civil de cultivo compartido. El acceso es como socio,
          dentro de la Ley 27.350 y el marco REPROCANN. Con todo por escrito.
        </p>
      </div>

      <div class="legal-body">
        <div class="ed-list" role="list">
          {legales.map((l, i) => (
            <article class="ed-row reveal" role="listitem" data-reveal-delay={i * 70}>
              <span class="ed-num" aria-hidden="true">0{i + 1}</span>
              <div class="ed-body">
                <h3 class="ed-title">{l.titulo}</h3>
                <p class="ed-desc">{l.desc}</p>
              </div>
            </article>
          ))}
        </div>

        <aside class="legal-aside reveal" aria-label="Registro y consulta">
          <span class="eyebrow">Registro habilitado · REPROCANN</span>
          <p class="legal-aside-text">
            ¿Tenés dudas sobre tu situación o tu trámite? Te orientamos sin compromiso,
            con una persona del equipo.
          </p>
          <a class="legal-aside-cta ed-cta" href={waLegal} target="_blank" rel="noopener noreferrer">
            Consultar por WhatsApp <span aria-hidden="true">→</span>
          </a>
        </aside>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- MEMBRESÍAS — grilla estática (escena ink)   -->
  <!-- ══════════════════════════════════════════ -->
  <section class="membresias-section" id="membresias" aria-label="Membresías">
    <div class="membresias-inner">
      <div class="membresias-head">
        <span class="eyebrow reveal">Membresías</span>
        <h2 class="section-title reveal" data-reveal-delay="80">Elegí cómo<br><em>acceder.</em></h2>
      </div>

      <div class="membresias-grid" role="list">
        {memberships.map((m, i) => (
          <article
            class={m.featured ? 'plan-card featured reveal' : 'plan-card reveal'}
            role="listitem"
            aria-label={`Membresía ${m.name}: ${m.grams} gramos por mes`}
            data-reveal-delay={120 + i * 80}
          >
            {m.badge && <span class="plan-badge">{m.badge}</span>}
            <h3 class="plan-name">{m.name}</h3>
            <div class="plan-grams" aria-label={`${m.grams} gramos`}>
              {m.grams}<span class="plan-grams-unit">g</span>
            </div>
            <p class="plan-unit">por mes · cultivo compartido</p>
            <ul class="plan-features" aria-label="Características incluidas">
              {m.features.map((f) => <li>{f}</li>)}
            </ul>
            <a
              href={m.waLink}
              class="plan-cta"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Consultar membresía ${m.name} por WhatsApp`}
            >
              Consultar por WhatsApp
            </a>
          </article>
        ))}
      </div>

      <p class="membresias-legal reveal">
        Cada membresía es tu parte de un cultivo colectivo, dentro del marco de la Ley&nbsp;27.350.
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- CÓMO FUNCIONA                              -->
  <!-- ══════════════════════════════════════════ -->
  <section class="steps-section" id="como-funciona" aria-label="Cómo funciona">
    <div class="steps-inner">

      <div class="steps-head">
        <span class="eyebrow on-light reveal">Proceso</span>
        <h2 class="section-title reveal" data-reveal-delay="80">Cuatro pasos<br><em>y estás adentro.</em></h2>
      </div>

      <ol class="ed-list" aria-label="Pasos para asociarse">
        {steps.map((step, i) => (
          <li class="ed-row reveal" data-reveal-delay={i * 70}>
            <span class="ed-num" aria-hidden="true">{step.num}</span>
            <div class="ed-body">
              <h3 class="ed-title">{step.title}</h3>
              <p class="ed-desc">{step.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- PROGRAMA — Espacio libre de prejuicios     -->
  <!-- ══════════════════════════════════════════ -->
  <section class="programa-section" id="programa" aria-label="Programa Espacio libre de prejuicios">
    <div class="programa-inner">
      <div class="programa-head">
        <span class="eyebrow reveal">Programa en YouTube</span>
        <h2 class="section-title on-dark reveal" data-reveal-delay="80">Espacio libre<br><em>de prejuicios.</em></h2>
        <p class="programa-lead reveal" data-reveal-delay="140">
          Conversaciones sin vueltas sobre cannabis medicinal: acceso, legalidad y
          bienestar. Para sumar información a la conversación.
        </p>
        <a class="programa-cta reveal" data-reveal-delay="200" href={ytChannel} target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
          </svg>
          Ver el canal
        </a>
      </div>

      <ul class="programa-episodes" role="list">
        {episodes.map((ep, i) => (
          <li class="episode-card reveal" data-reveal-delay={i * 90}>
            <button
              class="yt-facade"
              data-id={ep.id}
              data-title={ep.title}
              aria-label={`Reproducir episodio: ${ep.title}`}
            >
              <img
                class="yt-thumb"
                src={`https://i.ytimg.com/vi/${ep.id}/hqdefault.jpg`}
                alt={`Miniatura del episodio ${ep.title}`}
                loading="lazy"
                width="480"
                height="360"
              />
              <span class="yt-play" aria-hidden="true">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </span>
              <span class="yt-dur" aria-hidden="true">{ep.dur}</span>
            </button>
            <div class="episode-meta">
              <span class="episode-eyebrow">Episodio 0{i + 1}</span>
              <h3>{ep.title}</h3>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- INSTAGRAM — slider en vivo                 -->
  <!-- ══════════════════════════════════════════ -->
  <section class="ig-section" id="instagram" aria-label="Flora en Instagram">
    <div class="ig-inner">
      <div class="ig-head">
        <div class="ig-head-text">
          <span class="eyebrow reveal">Comunidad</span>
          <h2 class="section-title on-dark reveal" data-reveal-delay="80">Lo último<br><em>en Instagram.</em></h2>
          <p class="ig-lead reveal" data-reveal-delay="140">
            Educación, cultivo y comunidad, día a día. Esto se actualiza solo con
            nuestros últimos posteos.
          </p>
        </div>
        <a class="ig-cta" href={igProfile} target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
          </svg>
          {igHandle}
        </a>
      </div>

      <div class="ig-slider" data-feed={igFeedUrl} data-profile={igProfile}>
        <button class="ig-nav ig-prev" type="button" aria-label="Posteos anteriores">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>

        <ul class="ig-track" role="list" aria-live="polite">
          {igFallback.map((p) => (
            <li class="ig-card is-fallback" role="listitem">
              <a class="ig-card-link" href={igProfile} target="_blank" rel="noopener noreferrer">
                <span class="ig-card-media" aria-hidden="true">
                  <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                  </svg>
                </span>
                <span class="ig-card-body">
                  <span class="ig-card-caption">{p.caption}</span>
                  <span class="ig-card-cue">Ver en Instagram →</span>
                </span>
              </a>
            </li>
          ))}
        </ul>

        <button class="ig-nav ig-next" type="button" aria-label="Posteos siguientes">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- FOOTER                                     -->
  <!-- ══════════════════════════════════════════ -->
  <footer class="footer" id="contacto">
    <div class="footer-cta-band">
      <h3 class="footer-closer reveal">Empezá <em>hoy</em><br>tu acceso legal.</h3>
      <a href={waFooter} class="btn-primary reveal" data-reveal-delay="80" target="_blank" rel="noopener noreferrer" aria-label="Asociarme a Flora por WhatsApp">
        Asociarme por WhatsApp
      </a>
    </div>

    <div class="footer-grid">
      <div class="footer-brand">
        <h4>Flora ONG</h4>
        <p>
          Club de cultivo de cannabis medicinal. Legal bajo Ley 27.350.
          Neuquén, Patagonia.
        </p>
      </div>

      <nav class="footer-col" aria-label="Navegación del sitio">
        <h5>Navegación</h5>
        <ul>
          <li><a href="#nosotros">Nosotros</a></li>
          <li><a href="#perfiles">Para qué sirve</a></li>
          <li><a href="#flora">Por qué Flora</a></li>
          <li><a href="#productos">Productos</a></li>
          <li><a href="#legalidad">Legalidad</a></li>
          <li><a href="#membresias">Membresías</a></li>
          <li><a href="#como-funciona">Cómo funciona</a></li>
        </ul>
      </nav>

      <nav class="footer-col" aria-label="Información legal">
        <h5>Legal</h5>
        <ul>
          <li><a href="https://www.argentina.gob.ar/normativa/nacional/ley-27350-273801" target="_blank" rel="noopener noreferrer">Ley 27.350</a></li>
          <li><a href="https://www.argentina.gob.ar/salud/cannabis-medicinal/reprocann" target="_blank" rel="noopener noreferrer">REPROCANN</a></li>
          <li><a href="#legalidad">Marco legal</a></li>
          <li><a href="#como-funciona">Cómo asociarte</a></li>
        </ul>
      </nav>
    </div>

    <div class="footer-bottom">
      <p>© 2026 Flora ONG · Neuquén, Patagonia</p>
      <p>Cultivamos conciencia</p>
    </div>
  </footer>

  <!-- WhatsApp flotante — oculto en el hero, aparece al navegar -->
  <a
    class="wa-float"
    href={waAsociarse}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Escribinos por WhatsApp"
  >
    <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor" aria-hidden="true">
      <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.477-.911zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
    </svg>
  </a>
</Layout>
