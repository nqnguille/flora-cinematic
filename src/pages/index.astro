  <script>
    // Modal clínico/educativo del módulo "Estamos para acompañarte".
    (function () {
      const dataEl = document.getElementById('fl-perfiles-data')
      const modal = document.getElementById('fl-perfil-modal')
      if (!dataEl || !modal) return

      let perfiles = []
      try { perfiles = JSON.parse(dataEl.textContent || '[]') } catch (e) { return }
      const byId = new Map(perfiles.map((p) => [p.id, p]))

      const el = (id) => document.getElementById(id)
      let lastFocus = null

      function open(id) {
        const p = byId.get(id)
        if (!p) return
        lastFocus = document.activeElement
        el('fl-perfil-modal-tag').textContent = p.tag
        el('fl-perfil-modal-title').textContent = p.title
        el('fl-perfil-modal-busca').textContent = p.busca
        el('fl-perfil-modal-estudia').textContent = p.estudia
        el('fl-perfil-modal-nopromete').textContent = p.noPromete
        const ul = el('fl-perfil-modal-evalua')
        ul.innerHTML = ''
        ;(p.evalua || []).forEach((item) => {
          const li = document.createElement('li')
          li.textContent = item
          ul.appendChild(li)
        })
        const cta = el('fl-perfil-modal-cta')
        cta.href = p.href
        cta.setAttribute('data-cta', 'Perfil modal · ' + p.tag)
        el('fl-perfil-modal-cta-label').textContent = p.cta
        modal.hidden = false
        document.documentElement.style.overflow = 'hidden'
        const closeBtn = modal.querySelector('.fl-perfil-modal-x')
        if (closeBtn) closeBtn.focus()
      }

      function close() {
        modal.hidden = true
        document.documentElement.style.overflow = ''
        if (lastFocus && lastFocus.focus) lastFocus.focus()
      }

      // Delegación: el carrusel clona las tarjetas, así que escuchamos en el documento.
      document.addEventListener('click', (e) => {
        const opener = e.target.closest('[data-perfil-open]')
        if (opener) {
          e.preventDefault()
          open(opener.getAttribute('data-perfil-open'))
          return
        }
        if (e.target.closest('[data-perfil-close]')) {
          close()
        }
      })

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.hidden) close()
      })
    })()
  </script>
