// 3 copias seguidas para el loop infinito del carrusel autodeslizante
// (mismo truco que la carta de socios): el ancho de UNA copia es el punto
// de reinicio, así nunca se ve una costura ni un final.
const perfilesLoop = [...perfiles, ...perfiles, ...perfiles]

// Aceites: ficha técnica compartida en src/lib/productos.ts

const waAsociarse = `${WA}?text=Hola%20Flora%2C%20quiero%20asociarme%20a%20Flora.%20%C2%BFQu%C3%A9%20necesito%20para%20empezar%3F`

// Programa de YouTube — "Espacio libre de prejuicios"
const ytChannel = 'https://www.youtube.com/@FloraCultivamosConciencia'
const episodes = [
  { id: 'lqiDznxJHgE', title: 'Dolor crónico: ¿THC o CBD?', dur: '25:07' },
  { id: '69kQ-XoVmuU', title: 'Ansiedad y estrés', dur: '29:41' },
]

// Preguntas frecuentes (acordeón + datos estructurados FAQPage para SEO)
const faqs = [
  {
    q: '¿Necesito el REPROCANN para asociarme?',
    a: 'Sí, pero es mucho más sencillo de lo que parece. Si todavía no lo tenés, te guiamos paso a paso: coordinamos la consulta con un profesional y te acompañamos hasta que tu inscripción esté lista.',
  },
  {
    q: '¿Tengo que cultivar yo?',
    a: 'No. Justamente esa es una de las ventajas de ser parte de Flora. Nosotros nos ocupamos del cultivo y vos recibís mensualmente la parte que te corresponde como socio.',
  },
  {
    q: '¿Cómo se define lo que recibo cada mes?',
    a: 'La cantidad y el formato —flores, aceites u otro— dependen de tu tratamiento, siempre bajo indicación médica y según la disponibilidad del cultivo. Los aportes y planes se consultan directamente por WhatsApp.',
  },
  {
    q: '¿Es legal?',
    a: 'Sí. Flora funciona como Asociación Civil Cann de Cannabis Medicinal (I.G.J. N.º 1994128), dentro del marco de la Ley 27.350 y el REPROCANN. Todo el proceso se realiza de forma legal, transparente y con la documentación correspondiente para cada socio.',
  },
  {
    q: 'Nunca consumí cannabis, ¿puedo igual?',
    a: 'Sí, por supuesto. Muchas personas llegan a Flora sin experiencia previa. El profesional que te atiende define el perfil y la dosis con la que empezás, según tu caso.',
