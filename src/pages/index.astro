      'Acompañamiento directo del equipo',
    ],
    featured: false,
    waLink: `${WA}?text=Hola%20Flora%2C%20me%20interesa%20la%20membres%C3%ADa%20Cosecha%20(30g).%20%C2%BFPueden%20darme%20m%C3%A1s%20informaci%C3%B3n%3F`,
  },
  {
    name: 'Tierra',
    grams: '40',
    features: [
      'Acceso mensual a tu parte del cultivo',
      'Acceso a todas las variedades del club',
      'Acceso a los aceites con cromatografía (Q1·Q2·Q3)',
