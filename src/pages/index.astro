---
import Layout from '../layouts/Layout.astro'
import '../styles/global.css'

const WA = 'https://wa.me/5492996375723'

const waAsociarse = `${WA}?text=Hola%20Flora%2C%20quiero%20asociarme%20al%20club.%20%C2%BFQu%C3%A9%20necesito%20para%20empezar%3F`
const waFooter = waAsociarse

const memberships = [
  {
    name: 'Semilla',
    grams: '10',
    features: [
      'Acceso mensual garantizado',
      'Variedad rotativa de temporada',
      'Genética documentada',
      'Sin compraventa — marco Ley 27.350',
    ],
    featured: false,
    waLink: `${WA}?text=Hola%20Flora%2C%20me%20interesa%20la%20membres%C3%ADa%20Semilla%20(10g).%20%C2%BFPueden%20darme%20m%C3%A1s%20informaci%C3%B3n%3F`,
  },
  {
    name: 'Raíz',
    grams: '20',
    features: [
      'Acceso mensual garantizado',
      'Elección de variedad disponible',
      'Informe de cannabinoides por lote',
      'Acompañamiento por WhatsApp',
      'Sin compraventa — marco Ley 27.350',
    ],
    featured: true,
    badge: 'El más elegido',
    waLink: `${WA}?text=Hola%20Flora%2C%20me%20interesa%20la%20membres%C3%ADa%20Ra%C3%ADz%20(20g).%20%C2%BFPueden%20darme%20m%C3%A1s%20informaci%C3%B3n%3F`,
  },
  {
    name: 'Cosecha',
    grams: '30',
    features: [
      'Acceso mensual garantizado',
      'Prioridad en variedades nuevas',
      'Informe completo de cannabinoides',
      'Acompañamiento directo del equipo',
      'Sin compraventa — marco Ley 27.350',
    ],
    featured: false,
    waLink: `${WA}?text=Hola%20Flora%2C%20me%20interesa%20la%20membres%C3%ADa%20Cosecha%20(30g).%20%C2%BFPueden%20darme%20m%C3%A1s%20informaci%C3%B3n%3F`,
  },
  {
    name: 'Tierra',
    grams: '40',
    features: [
      'Acceso mensual garantizado',
      'Acceso a toda la genética del club',
      'Informe completo + historial de lotes',
      'Acompañamiento prioritario 24h',
      'Invitaciones a ciclos de formación',
      'Sin compraventa — marco Ley 27.350',
    ],
    featured: false,
    waLink: `${WA}?text=Hola%20Flora%2C%20me%20interesa%20la%20membres%C3%ADa%20Tierra%20(40g).%20%C2%BFPueden%20darme%20m%C3%A1s%20informaci%C3%B3n%3F`,
  },
]

const steps = [
  {
    num: '01',
    title: 'Completás el formulario de ingreso',
    desc: 'Dos minutos. Nos contás tu situación, si tenés REPROCANN o si estás en trámite. Sin papeles físicos por ahora.',
  },
  {
    num: '02',
    title: 'Revisamos tu solicitud',
    desc: 'El equipo de Flora la revisa en 24 a 48 horas hábiles. Te avisamos por WhatsApp cuando está aprobada.',
  },
  {
    num: '03',
    title: 'Elegís tu membresía',
    desc: 'Una vez adentro, elegís el plan que se ajusta a tu uso y lo podés cambiar cuando quieras.',
  },
  {
    num: '04',
    title: 'Accedés al cultivo compartido',
    desc: 'Recibís tu parte del cultivo del mes. Todo dentro del marco legal del club. Sin intermediarios, sin grises.',
  },
]

// Programa de YouTube — "Espacio libre de prejuicios"
const ytChannel = 'https://www.youtube.com/@FloraCultivamosConciencia'
const episodes = [
  { id: 'lqiDznxJHgE', title: 'Dolor crónico: ¿THC o CBD?', dur: '25:07' },
  { id: '69kQ-XoVmuU', title: 'Ansiedad y estrés', dur: '29:41' },
]
---

<Layout
  title="Flora ONG — Club de cultivo de cannabis medicinal en Neuquén"
  description="Club de cultivo bajo Ley 27.350 / REPROCANN. Acceso mensual con trazabilidad por lote, sin intermediarios. Neuquén, Patagonia, Argentina."
>

  <!-- Skip to content para navegación por teclado -->
  <a class="skip-link" href="#inicio">Ir al contenido principal</a>

  <!-- Page loader -->
  <div class="page-loader" role="status" aria-label="Cargando Flora ONG">
    <span class="loader-logo">Flora</span>
    <span class="loader-tagline">Cannabis medicinal</span>
    <div class="loader-progress" aria-hidden="true"></div>
  </div>

  <!-- Scroll progress bar -->
  <div class="scroll-progress" aria-hidden="true" role="progressbar" aria-valuemin="0" aria-valuemax="100"></div>

  <!-- Nav fija -->
  <nav class="site-nav" aria-label="Navegación principal">
    <a href="#inicio" class="nav-logo" aria-label="Flora ONG — inicio">Flora</a>

    <!-- Desktop links -->
    <ul class="nav-links" role="list">
      <li><a href="#nosotros">Nosotros</a></li>
      <li><a href="#flora">Por qué Flora</a></li>
      <li><a href="#membresias">Membresías</a></li>
      <li><a href="#como-funciona">Cómo funciona</a></li>
      <li><a href="#programa">Programa</a></li>
      <li>
        <a href={waAsociarse} class="nav-cta" target="_blank" rel="noopener noreferrer">
          Asociarme
        </a>
      </li>
    </ul>

    <!-- Hamburguesa — solo mobile -->
    <button
      class="nav-hamburger"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-drawer"
    >
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
    </button>
  </nav>

  <!-- Drawer mobile -->
  <div class="mobile-drawer" id="mobile-drawer" role="dialog" aria-modal="true" aria-label="Menú de navegación" hidden>
    <div class="drawer-backdrop"></div>
    <nav class="drawer-panel" aria-label="Navegación mobile">
      <button class="drawer-close" aria-label="Cerrar menú">
        <span aria-hidden="true">✕</span>
      </button>
      <ul role="list">
        <li><a href="#nosotros">Nosotros</a></li>
        <li><a href="#flora">Por qué Flora</a></li>
        <li><a href="#membresias">Membresías</a></li>
        <li><a href="#como-funciona">Cómo funciona</a></li>
        <li><a href="#programa">Programa</a></li>
        <li>
          <a href={waAsociarse} class="drawer-cta" target="_blank" rel="noopener noreferrer">
            Asociarme por WhatsApp
          </a>
        </li>
      </ul>
    </nav>
  </div>

  <!-- ══════════════════════════════════════════ -->
  <!-- HERO                                       -->
  <!-- ══════════════════════════════════════════ -->
  <section class="hero" id="inicio" aria-label="Inicio">

    <!-- Fondo de video — decorativo. Poster local = imagen LCP y fallback reduced-motion -->
    <div class="hero-visual" aria-hidden="true">
      <img
        src="/hero/cannabis-hero-poster.jpg"
        alt=""
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1280"
        height="720"
        id="hero-img"
      />
      <video
        id="hero-video"
        class="hero-video"
        muted
        loop
        playsinline
        preload="none"
        poster="/hero/cannabis-hero-poster.jpg"
      >
        <source src="/hero/cannabis-hero-720.webm" type="video/webm" />
        <source src="/hero/cannabis-hero-720.mp4" type="video/mp4" />
      </video>
    </div>

    <!-- Viñeta -->
    <div class="hero-vignette" aria-hidden="true"></div>

    <!-- Partículas -->
    <div class="hero-particles" aria-hidden="true"></div>

    <!-- Número de año decorativo -->
    <span class="hero-year" aria-hidden="true">Est. 2022</span>

    <!-- Contenido principal -->
    <div class="hero-content">
      <div class="hero-eyebrow">
        <span class="hero-badge">Ley 27.350 · REPROCANN</span>
        <span class="hero-badge-sep" aria-hidden="true"></span>
        <span class="hero-badge-location">Neuquén, Patagonia</span>
      </div>

      <h1 class="hero-title split-words">
        Cultivamos<br>lo que la ley<br><em class="accent-word">te permite.</em>
      </h1>

      <div class="hero-bottom">
        <p class="hero-subtext">
          Acceso continuo. Trazabilidad por lote.<br>Sin intermediarios. Con la ley a favor.
        </p>

        <div class="hero-ctas">
          <a href={waAsociarse} class="btn-primary" target="_blank" rel="noopener noreferrer">
            Quiero asociarme
          </a>
          <a href="#membresias" class="btn-secondary">Ver membresías</a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator" aria-hidden="true">
      <div class="scroll-line"></div>
      <span class="scroll-label">scroll</span>
    </div>

    <!-- Ticker -->
    <div class="hero-ticker" aria-hidden="true">
      <div class="ticker-track">
        <span>CULTIVAMOS CONCIENCIA &nbsp;·&nbsp; CANNABIS MEDICINAL &nbsp;·&nbsp; NEUQUÉN ARGENTINA &nbsp;·&nbsp; LEY 27.350 &nbsp;·&nbsp; REPROCANN &nbsp;·&nbsp; TRAZABILIDAD POR LOTE &nbsp;·&nbsp; </span>
        <span>CULTIVAMOS CONCIENCIA &nbsp;·&nbsp; CANNABIS MEDICINAL &nbsp;·&nbsp; NEUQUÉN ARGENTINA &nbsp;·&nbsp; LEY 27.350 &nbsp;·&nbsp; REPROCANN &nbsp;·&nbsp; TRAZABILIDAD POR LOTE &nbsp;·&nbsp; </span>
        <span>CULTIVAMOS CONCIENCIA &nbsp;·&nbsp; CANNABIS MEDICINAL &nbsp;·&nbsp; NEUQUÉN ARGENTINA &nbsp;·&nbsp; LEY 27.350 &nbsp;·&nbsp; REPROCANN &nbsp;·&nbsp; TRAZABILIDAD POR LOTE &nbsp;·&nbsp; </span>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- STATS                                      -->
  <!-- ══════════════════════════════════════════ -->
  <section class="stats-section" id="nosotros" aria-label="Flora en números">
    <div class="stats-grid">
      <div class="stat-item">
        <span class="stat-number count-up" data-target="200" data-suffix="+">200+</span>
        <span class="stat-label">Asociados</span>
      </div>
      <div class="stat-item">
        <span class="stat-number count-up" data-target="3" data-suffix=" años">3 años</span>
        <span class="stat-label">Activos</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">Todo el país</span>
        <span class="stat-label">Alcance</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">100%</span>
        <span class="stat-label">Legal</span>
      </div>
    </div>
    <div class="stats-separator"></div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- POR QUÉ FLORA — BENTO                      -->
  <!-- ══════════════════════════════════════════ -->
  <section class="why-section" id="flora" aria-label="Por qué Flora">
    <div class="why-inner">

      <div class="section-header">
        <div>
          <span class="section-label on-light">Por qué Flora</span>
          <h2 class="section-title split-words">Sabés lo que<br><em>recibís.</em></h2>
        </div>
        <p class="section-tagline">
          Un club de cultivo no es un negocio. Es una forma legal de organizarse para acceder a lo que la ley ya permite.
        </p>
      </div>

      <div class="why-bento" role="list">

        <!-- Celda statement editorial grande -->
        <div class="bento-statement" role="listitem">
          <div>
            <p class="bento-statement-text">
              Flora existe para que ese acceso sea real, documentado y sin intermediarios.
            </p>
          </div>
          <div>
            <p class="bento-statement-sub">
              Cada lote tiene trazabilidad desde la genética hasta la entrega.
            </p>
            <div class="bento-law-badge" aria-label="Marco legal">
              <span>Ley 27.350 · REPROCANN</span>
            </div>
          </div>
        </div>

        <!-- Grilla de razones -->
        <div class="bento-items" role="list">
          <div class="bento-item" role="listitem">
            <span class="bento-item-num">01</span>
            <h3 class="bento-item-title">Trazabilidad completa</h3>
            <p class="bento-item-desc">Variedad, genética y perfil de cannabinoides. Todo por escrito, por lote, disponible para cada asociado.</p>
          </div>

          <div class="bento-item" role="listitem">
            <span class="bento-item-num">02</span>
            <h3 class="bento-item-title">Análisis de laboratorio</h3>
            <p class="bento-item-desc">Concentración real, no estimada. Resultados por escrito antes de recibir tu parte del cultivo.</p>
          </div>

          <div class="bento-item" role="listitem">
            <span class="bento-item-num">03</span>
            <h3 class="bento-item-title">Marco legal vigente</h3>
            <p class="bento-item-desc">Operamos bajo Ley 27.350 y marco REPROCANN. Sin compraventa, sin grises, sin riesgo para vos.</p>
          </div>

          <div class="bento-item" role="listitem">
            <span class="bento-item-num">04</span>
            <h3 class="bento-item-title">Acompañamiento real</h3>
            <p class="bento-item-desc">Respondemos por WhatsApp. Una persona del equipo, no un bot. Porque tus preguntas merecen respuestas.</p>
          </div>

          <div class="bento-item" role="listitem">
            <span class="bento-item-num">05</span>
            <h3 class="bento-item-title">Genética documentada</h3>
            <p class="bento-item-desc">Cada variedad tiene su historia. Sabés qué recibís antes de recibirlo. Sin sorpresas, sin incertidumbre.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- MEMBRESÍAS — HORIZONTAL SCROLL             -->
  <!-- ══════════════════════════════════════════ -->
  <section class="horizontal-section" id="membresias" aria-label="Membresías">
    <div class="horizontal-inner">
      <div class="horizontal-header">
        <span class="section-label on-dark">Membresías</span>
        <h2 class="split-words">Elegí cómo<br>acceder.</h2>
        <div class="horizontal-scroll-hint" aria-hidden="true">
          <span class="hint-arrow"></span>
          <span>deslizá</span>
        </div>
      </div>

      <div class="cards-track-wrapper" aria-label="Planes disponibles">
        <div class="cards-track" role="list">
          {memberships.map((m) => (
            <div
              class={m.featured ? 'membresia-card featured' : 'membresia-card'}
              role="listitem"
              aria-label={`Membresía ${m.name}: ${m.grams} gramos por mes`}
            >
              {m.badge && <span class="card-badge" aria-label="Plan más popular">{m.badge}</span>}
              <h3 class="card-title">{m.name}</h3>
              <div class="card-grams" aria-label={`${m.grams} gramos`}>
                {m.grams}<span class="card-grams-unit">g</span>
              </div>
              <p class="card-unit">por mes · cultivo compartido</p>
              <ul class="card-features" aria-label="Características incluidas">
                {m.features.map((f) => <li>{f}</li>)}
              </ul>
              <a
                href={m.waLink}
                class="card-cta"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Consultar membresía ${m.name} por WhatsApp`}
              >
                Consultar por WhatsApp
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- CÓMO FUNCIONA                              -->
  <!-- ══════════════════════════════════════════ -->
  <section class="steps-section" id="como-funciona" aria-label="Cómo funciona">
    <div class="steps-inner">

      <div class="section-header">
        <div>
          <span class="section-label on-light">Proceso</span>
          <h2 class="section-title split-words">Cuatro pasos.<br><em>Sin grises.</em></h2>
        </div>
      </div>

      <div class="steps-list-wrap">
        <div class="step-connector" aria-hidden="true">
          <div class="step-line"></div>
        </div>
      <ol class="steps-list" aria-label="Pasos para asociarse">
        {steps.map((step) => (
          <li class="step-item">
            <div class="step-num-wrap" aria-hidden="true">
              <span class="step-num">{step.num}</span>
            </div>
            <div class="step-content">
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
            </div>
          </li>
        ))}
      </ol>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- PROGRAMA — Espacio libre de prejuicios     -->
  <!-- ══════════════════════════════════════════ -->
  <section class="programa-section" id="programa" aria-label="Programa Espacio libre de prejuicios">
    <div class="programa-inner">
      <div class="programa-head">
        <span class="section-label">Programa en YouTube</span>
        <h2 class="split-words">Espacio libre<br>de prejuicios.</h2>
        <p class="programa-lead">
          Conversaciones sin vueltas sobre cannabis medicinal: acceso, legalidad y
          bienestar. Para informarte antes de opinar.
        </p>
        <a class="programa-cta" href={ytChannel} target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
          </svg>
          Ver el canal
        </a>
      </div>

      <ul class="programa-episodes" role="list">
        {episodes.map((ep) => (
          <li class="episode-card clip-reveal">
            <button
              class="yt-facade"
              data-id={ep.id}
              data-title={ep.title}
              aria-label={`Reproducir episodio: ${ep.title}`}
            >
              <img
                class="yt-thumb"
                src={`https://i.ytimg.com/vi/${ep.id}/hqdefault.jpg`}
                alt={`Miniatura del episodio ${ep.title}`}
                loading="lazy"
                width="480"
                height="360"
              />
              <span class="yt-play" aria-hidden="true">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </span>
              <span class="yt-dur" aria-hidden="true">{ep.dur}</span>
            </button>
            <div class="episode-meta">
              <span class="episode-eyebrow">Episodio</span>
              <h3>{ep.title}</h3>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- FOOTER                                     -->
  <!-- ══════════════════════════════════════════ -->
  <footer class="footer" id="contacto">
    <div class="footer-cta-band">
      <h3>¿Listo para empezar?</h3>
      <a href={waFooter} class="btn-primary" target="_blank" rel="noopener noreferrer" aria-label="Asociarme a Flora por WhatsApp">
        Asociarme por WhatsApp
      </a>
    </div>

    <div class="footer-grid">
      <div class="footer-brand">
        <h4>Flora ONG</h4>
        <p>
          Club de cultivo de cannabis medicinal. Legal bajo Ley 27.350.
          Neuquén, Patagonia.
        </p>
      </div>

      <nav class="footer-col" aria-label="Navegación del sitio">
        <h5>Navegación</h5>
        <ul>
          <li><a href="#nosotros">Nosotros</a></li>
          <li><a href="#flora">Por qué Flora</a></li>
          <li><a href="#membresias">Membresías</a></li>
          <li><a href="#como-funciona">Cómo funciona</a></li>
        </ul>
      </nav>

      <nav class="footer-col" aria-label="Información legal">
        <h5>Legal</h5>
        <ul>
          <li><a href="#">Ley 27.350</a></li>
          <li><a href="#">REPROCANN</a></li>
          <li><a href="#">Estatuto ONG</a></li>
          <li><a href="#">Términos de uso</a></li>
        </ul>
      </nav>
    </div>

    <div class="footer-bottom">
      <p>© 2026 Flora ONG · Neuquén, Patagonia</p>
      <p>Cultivamos conciencia</p>
    </div>
  </footer>
</Layout>
