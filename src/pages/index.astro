---

<Layout
  title="Flora — Tramitá tu REPROCANN y accedé a cannabis medicinal | Neuquén"
  description="¿Cómo se tramita el REPROCANN? El primer paso es una entrevista médica. Asociación civil de cultivo de cannabis medicinal en Neuquén, bajo Ley 27.350. Material vegetal y aceites con análisis de laboratorio."
>

  <!-- Skip to content para navegación por teclado -->
  <a class="skip-link" href="#inicio">Ir al contenido principal</a>

  <!-- Page loader -->
  <div class="page-loader" role="status" aria-live="polite" aria-busy="true">
    <div class="loader-ring" aria-hidden="true">
      <img class="loader-ring-track" src="/img/loader-ring.png" alt="" />
      <img class="loader-ring-fill" src="/img/loader-ring.png" alt="" />
      <img class="loader-leaf" src="/img/loader-leaf.png" alt="" />
    </div>
    <div class="loader-cue">
      <div class="loader-gate-ask">
        <p class="loader-gate-question">¿Sos mayor de 18 años?</p>
        <div class="loader-gate-actions">
          <button type="button" class="loader-gate-yes">Sí, soy mayor</button>
          <a class="loader-gate-no" href="/verificacion-edad">No</a>
        </div>
      </div>
      <div class="loader-slide-cue" aria-hidden="true">
        <span class="loader-cue-label">Deslizá para comenzar</span>
        <svg class="loader-cue-mouse" viewBox="0 0 24 38">
          <rect x="1.5" y="1.5" width="21" height="35" rx="10.5" />
          <circle class="loader-cue-wheel" cx="12" cy="11" r="2.4" />
        </svg>
      </div>
    </div>
    <span class="sr-only loader-sr-msg">Cargando Flora ONG…</span>
  </div>

  <!-- Scroll progress bar -->
  <div class="scroll-progress" aria-hidden="true" role="progressbar" aria-valuemin="0" aria-valuemax="100"></div>

  <!-- Nav fija -->
  <link rel="stylesheet" href="/socios/tienda.css" />

  <nav class="site-nav" aria-label="Navegación principal">
    <a href="#inicio" class="nav-logo" aria-label="Flora ONG — inicio">
      <img class="nav-logo-img nav-logo-white" src="/img/flora-logo-white.png" alt="Flora" width="1472" height="298" />
      <img class="nav-logo-img nav-logo-violet" src="/img/flora-logo.png" alt="" width="1472" height="298" aria-hidden="true" />
    </a>

    <!-- Desktop links -->
    <ul class="nav-links" role="list">
      <li><a href="#perfiles">Cómo ayudamos</a></li>
      <li><a href="#entrevista">REPROCANN</a></li>
      <li><a href="#productos">Productos</a></li>
      <li><a href="#acceso">Ser socio</a></li>
      <li><a href="#legalidad">Legalidad</a></li>
      <li>
        <a href="/socios/" class="nav-socios">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4.5" y="10.5" width="15" height="9.5" rx="2"/><path d="M8 10.5V7a4 4 0 0 1 8 0v3.5"/></svg>
          Acceso socios
        </a>
      </li>
      <li>
        <a href={waAsociarse} class="nav-cta nav-cta--publico" target="_blank" rel="noopener noreferrer">
          Asociarme
        </a>
        <a href="/socios/cuenta/" class="nav-hola" data-socio-hola hidden title="Mi cuenta">
          <img class="nav-hola-foto" data-socio-foto alt="" width="22" height="22" hidden />
          <span>¡Hola, <b data-socio-nombre></b>!</span>
        </a>
        <a href="/socios/carta/" class="nav-cta nav-cta--carta"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:14px;height:14px"><circle cx="9" cy="20" r="1.6"/><circle cx="17.5" cy="20" r="1.6"/><path d="M3 3.5h2.2l2.4 12h10.2l2.2-8.5H6"/></svg> Carrito <span class="nav-carrito-n" data-carrito-n hidden></span></a>
      </li>
    </ul>

    <!-- Mobile: Asociarme (conversión) + Acceso socios compacto, siempre visibles -->
    <a href={waAsociarse} class="nav-cta nav-cta--mobile nav-cta--publico" target="_blank" rel="noopener noreferrer">Asociarme</a>
    <a href="/socios/cuenta/" class="nav-hola nav-hola--mobile" data-socio-hola hidden>¡Hola, <b data-socio-nombre></b>!</a>
    <a href="/socios/carta/" class="nav-cta nav-cta--mobile nav-cta--carta"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:14px;height:14px"><circle cx="9" cy="20" r="1.6"/><circle cx="17.5" cy="20" r="1.6"/><path d="M3 3.5h2.2l2.4 12h10.2l2.2-8.5H6"/></svg> Carrito <span class="nav-carrito-n" data-carrito-n hidden></span></a>
    <a href="/socios/" class="nav-socios nav-socios--mobile" aria-label="Acceso socios">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4.5" y="10.5" width="15" height="9.5" rx="2"/><path d="M8 10.5V7a4 4 0 0 1 8 0v3.5"/></svg>
    </a>

    <!-- Hamburguesa — solo mobile -->
    <button
      class="nav-hamburger"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-drawer"
    >
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
    </button>
  </nav>

  <!-- Drawer mobile -->
  <div class="mobile-drawer" id="mobile-drawer" role="dialog" aria-modal="true" aria-label="Menú de navegación" hidden>
    <div class="drawer-backdrop"></div>
    <nav class="drawer-panel" aria-label="Navegación mobile">
      <button class="drawer-close" aria-label="Cerrar menú">
