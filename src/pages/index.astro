---
import Layout from '../layouts/Layout.astro'
import '../styles/global.css'

const WA = 'https://wa.me/5492996375723'
const wa = (t: string) => `${WA}?text=${encodeURIComponent(t)}`

// ¿Por qué llegaste a Flora? — abordajes por necesidad
const perfiles = [
  {
    tag: 'Dolor & inflamación',
    title: 'Para quienes buscan otra forma de tratar el dolor.',
    desc: 'El CBD y el THC pueden acompañar el dolor crónico, articular o muscular, y la forma en que percibís el dolor.',
    cta: 'Hablar sobre dolor',
    href: wa('Hola Flora, me interesa asociarme a Flora para manejo del dolor crónico 🌿'),
    img: '/img/perfil-dolor.jpg',
  },
  {
    tag: 'Sueño & descanso',
    title: 'Para quienes buscan recuperar el descanso.',
    desc: 'El THC en dosis justas y ciertos cannabinoides pueden ayudarte a conciliar y sostener el sueño, para el insomnio y la mente que no para.',
    cta: 'Hablar sobre sueño',
    href: wa('Hola Flora, me interesa asociarme a Flora para mejorar mi sueño 🌿'),
    img: '/img/perfil-sueno.jpg',
  },
  {
    tag: 'Bienestar & ansiedad',
    title: 'Para quienes buscan equilibrio, todos los días.',
    desc: 'El CBD acompaña la ansiedad y el estrés de la rutina sin alterarte, pensado para el día y como una práctica de bienestar.',
    cta: 'Hablar sobre bienestar',
    href: wa('Hola Flora, me interesa asociarme a Flora para bienestar y ansiedad 🌿'),
    img: '/img/perfil-ansiedad.jpg',
  },
]

// Nuestros productos — 3 formatos (Flores / Aceites / Crema)
// Perfiles de cannabinoides según la última cromatografía (HPLC-UV, IACA
// Laboratorios, extracción 02/06/2026). Valores en mg/mL.
const aceites = [
  {
    codigo: 'Q1',
    sub: 'Quimiotipo I · THC predominante',
    desc: 'Perfil de THC alto con presencia de CBG. Pensado para uso nocturno y dolor intenso, siempre con el equipo orientando la dosis.',
    perfil: [
      { k: 'CBD', v: '21,8' },
      { k: 'THC', v: '51,0' },
      { k: 'CBG', v: '6,9' },
    ],
    usos: ['Uso nocturno', 'Dolor intenso', 'Descanso'],
    href: wa('Hola Flora, me interesa el aceite Q1 🌿'),
    pdf: '/analisis/Q1.pdf',
  },
  {
    codigo: 'Q2',
    sub: 'Quimiotipo II · CBD:THC balanceado',
    desc: 'Relación equilibrada entre CBD y THC. Acompaña el día y la noche. El elegido por quienes ya tienen su tratamiento calibrado.',
    perfil: [
      { k: 'CBD', v: '23,9' },
      { k: 'THC', v: '17,0' },
      { k: 'CBG', v: '1,3' },
    ],
    usos: ['Día y noche', 'Dolor moderado', 'Uso continuo'],
    href: wa('Hola Flora, me interesa el aceite Q2 🌿'),
    pdf: '/analisis/Q2.pdf',
  },
  {
    codigo: 'Q3',
    sub: 'Quimiotipo III · CBD predominante',
    desc: 'CBD alto y THC casi nulo, de efecto suave. Ideal para el día, la ansiedad y para empezar con un perfil liviano.',
    perfil: [
      { k: 'CBD', v: '32,6' },
      { k: 'THC', v: '1,2' },
      { k: 'CBG', v: '0,3' },
    ],
    usos: ['Uso diurno', 'Ansiedad', 'Inicio suave'],
    href: wa('Hola Flora, me interesa el aceite Q3 🌿'),
    pdf: '/analisis/Q3.pdf',
  },
]
const cremas = [
  {
    presentacion: '50 cc',
    sub: 'Presentación personal',
    desc: 'Para uso localizado y tratamientos puntuales. Fácil de llevar, ideal para incorporar la fórmula.',
    href: wa('Hola Flora, me interesa la crema 50cc 🌿'),
  },
  {
    presentacion: '100 cc',
    sub: 'Presentación completa',
    desc: 'Para uso continuo y zonas de mayor extensión. La opción de quienes ya sumaron la crema a su rutina.',
    href: wa('Hola Flora, me interesa la crema 100cc 🌿'),
  },
]

// Iconos de línea para los paneles gateway de Perfiles (dolor / sueño / ansiedad)
const perfilIconsSvg = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h4l2 5 4-12 2 7h6"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h11a3 3 0 1 0-3-3M3 16h15a3 3 0 1 1-3 3M3 12h18"/></svg>`,
]

// Iconos de los productos (flores / aceites / cremas) para sus paneles gateway
const productIconsSvg = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V11M12 11c3.5-.4 6-3 6-7-3.5.4-6 3-6 7zM12 13C8.5 12.6 6 10 6 6c3.5.4 6 3 6 7z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3s6 6.5 6 11a6 6 0 0 1-12 0c0-4.5 6-11 6-11z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 10h14v8a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2z"/><rect x="4" y="5.5" width="16" height="4.5" rx="1"/></svg>`,
]

const waAsociarse = `${WA}?text=Hola%20Flora%2C%20quiero%20asociarme%20a%20Flora.%20%C2%BFQu%C3%A9%20necesito%20para%20empezar%3F`
const waFooter = waAsociarse
const waLegal = `${WA}?text=Hola%20Flora%2C%20tengo%20una%20consulta%20sobre%20mi%20situaci%C3%B3n%20legal%20(Ley%2027.350%20%2F%20REPROCANN).%20%C2%BFMe%20orientan%3F`

// Marco legal — los instrumentos bajo los que funciona la ONG (la entidad va en el lead)
const legales = [
  {
    titulo: 'Ley 27.350',
    desc: 'El marco nacional que regula el acceso al cannabis con fines medicinales en Argentina.',
  },
  {
    titulo: 'REPROCANN',
    desc: 'Cada socio se inscribe en el registro del programa; ahí queda amparado su acceso.',
  },
  {
    titulo: 'Decreto 883/2020',
    desc: 'Reglamenta el funcionamiento del programa y el cultivo solidario entre personas asociadas.',
  },
]

// Acceso a material vegetal — cultivo solidario. Lo único que varía es la cantidad
// (gramos por mes). Mismo acompañamiento y variedades para todos. Sugerimos empezar
// por la cantidad más baja (10 g).
const accesoAmounts = [
  { g: '10', wa: wa('Hola Flora, quiero acceder al material vegetal: 10 g por mes. ¿Me orientan para empezar?') },
  { g: '20', wa: wa('Hola Flora, quiero acceder al material vegetal: 20 g por mes. ¿Me orientan?') },
  { g: '30', wa: wa('Hola Flora, quiero acceder al material vegetal: 30 g por mes. ¿Me orientan?') },
  { g: '40', wa: wa('Hola Flora, quiero acceder al material vegetal: 40 g por mes. ¿Me orientan?') },
]

const steps = [
  {
    num: '01',
    title: 'Completás el formulario de ingreso',
    desc: 'Dos minutos. Nos contás tu situación, si tenés REPROCANN o si estás en trámite. Sin papeles físicos por ahora.',
  },
  {
    num: '02',
    title: 'Revisamos tu solicitud',
    desc: 'El equipo de Flora la revisa en 24 a 48 horas hábiles. Te avisamos por WhatsApp cuando está aprobada.',
  },
  {
    num: '03',
    title: 'Elegís tu nivel de acceso',
    desc: 'Una vez adentro, elegís el nivel que se ajusta a lo que necesitás. Lo podés cambiar cuando quieras.',
  },
  {
    num: '04',
    title: 'Accedés al cultivo compartido',
    desc: 'Recibís tu parte del cultivo del mes, dentro del marco legal del club, con acceso directo y acompañado.',
  },
]

// Programa de YouTube — "Espacio libre de prejuicios"
const ytChannel = 'https://www.youtube.com/@FloraCultivamosConciencia'
const episodes = [
  { id: 'lqiDznxJHgE', title: 'Dolor crónico: ¿THC o CBD?', dur: '25:07' },
  { id: '69kQ-XoVmuU', title: 'Ansiedad y estrés', dur: '29:41' },
]

// Preguntas frecuentes (acordeón + datos estructurados FAQPage para SEO)
const faqs = [
  {
    q: '¿Necesito el REPROCANN para asociarme?',
    a: 'El REPROCANN es lo que habilita el acceso legal. Si todavía no lo tenés, el primer paso es una entrevista médica: un profesional evalúa tu caso y, si corresponde, te inscribe. Te acompañamos en todo el trámite.',
  },
  {
    q: '¿Tengo que cultivar yo?',
    a: 'No hace falta. Cultivamos la parte que le corresponde a cada socio que no puede hacerlo en su casa, y vos accedés a esa parte todos los meses.',
  },
  {
    q: '¿Cuánto es el aporte?',
    a: 'Es un aporte mensual que sostiene el cultivo. Arranca en $170.000 y varía según la cantidad. Te sugerimos empezar por la más baja.',
  },
  {
    q: '¿Es legal?',
    a: 'Sí. Funcionamos como Asociación Civil Cann de Cannabis Medicinal (I.G.J. N° 1994128), dentro de la Ley 27.350 y el REPROCANN, con cada socio inscripto y todo por escrito.',
  },
  {
    q: 'Nunca consumí cannabis, ¿puedo igual?',
    a: 'Sí. Mucha gente llega sin experiencia previa. El profesional y el equipo te orientan sobre cómo empezar, con perfiles suaves y dosis bajas.',
  },
  {
    q: '¿A qué productos accedo?',
    a: 'A las flores, por el aporte mensual; a los aceites y las cremas, por consulta. Cada aceite tiene su análisis de laboratorio para descargar.',
  },
  {
    q: '¿Dónde están y cómo coordino?',
    a: 'Estamos en Neuquén, Patagonia. Cada caso lo coordinamos por WhatsApp, paso a paso.',
  },
  {
    q: '¿Cómo doy el primer paso?',
    a: 'Escribinos por WhatsApp y coordinamos tu entrevista médica. Desde ahí avanzamos juntos.',
  },
]

// Instagram — slider en vivo. El feed lo sirve Behold (behold.so): JSON con
// imágenes hosteadas estables + CORS, refresco automático del token. Si no
// responde, se muestran estas tarjetas de respaldo y el botón al perfil.
const igHandle = '@flora.cultivamosconciencia'
const igProfile = 'https://www.instagram.com/flora.cultivamosconciencia/'
const igFeedUrl = 'https://feeds.behold.so/BdL7J34neXVcfDDQ3Qe2'
const igFallback = [
  { caption: 'Efecto séquito: por qué se estudia la planta entera frente a un cannabinoide aislado.' },
  { caption: 'Cómo elegir tu aceite: quimiotipo, relación CBD:THC y para qué sirve cada uno.' },
  { caption: 'Punto de corte: cuándo se cosecha y por qué cambia el efecto final.' },
  { caption: 'REPROCANN al día: qué cambió en la última resolución y cómo te afecta.' },
  { caption: 'Derribando mitos: lo que se dice del THC y lo que dice la evidencia.' },
]
---

<Layout
  title="Flora — Tramitá tu REPROCANN y accedé a cannabis medicinal | Neuquén"
  description="¿Cómo se tramita el REPROCANN? El primer paso es una entrevista médica. Asociación civil de cultivo de cannabis medicinal en Neuquén, bajo Ley 27.350. Material vegetal y aceites con análisis de laboratorio."
>

  <!-- Skip to content para navegación por teclado -->
  <a class="skip-link" href="#inicio">Ir al contenido principal</a>

  <!-- Page loader -->
  <div class="page-loader" role="status" aria-label="Cargando Flora ONG">
    <span class="loader-logo">Flora</span>
    <span class="loader-tagline">Cannabis medicinal</span>
    <div class="loader-progress" aria-hidden="true"></div>
  </div>

  <!-- Scroll progress bar -->
  <div class="scroll-progress" aria-hidden="true" role="progressbar" aria-valuemin="0" aria-valuemax="100"></div>

  <!-- Nav fija -->
  <nav class="site-nav" aria-label="Navegación principal">
    <a href="#inicio" class="nav-logo" aria-label="Flora ONG — inicio">
      <img class="nav-logo-img" src="/img/flora-logo-white.png" alt="Flora" width="1472" height="298" />
    </a>

    <!-- Desktop links -->
    <ul class="nav-links" role="list">
      <li><a href="#perfiles">En qué te ayuda</a></li>
      <li><a href="#productos">Productos</a></li>
      <li><a href="#acceso">Acceso</a></li>
      <li><a href="#entrevista">REPROCANN</a></li>
      <li><a href="#legalidad">Legalidad</a></li>
      <li>
        <a href={waAsociarse} class="nav-cta" target="_blank" rel="noopener noreferrer">
          Asociarme
        </a>
      </li>
    </ul>

    <!-- Hamburguesa — solo mobile -->
    <button
      class="nav-hamburger"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-drawer"
    >
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
    </button>
  </nav>

  <!-- Drawer mobile -->
  <div class="mobile-drawer" id="mobile-drawer" role="dialog" aria-modal="true" aria-label="Menú de navegación" hidden>
    <div class="drawer-backdrop"></div>
    <nav class="drawer-panel" aria-label="Navegación mobile">
      <button class="drawer-close" aria-label="Cerrar menú">
        <span aria-hidden="true">✕</span>
      </button>
      <ul role="list">
        <li><a href="#perfiles">En qué te ayuda</a></li>
        <li><a href="#productos">Productos</a></li>
        <li><a href="#acceso">Acceso</a></li>
        <li><a href="#entrevista">REPROCANN</a></li>
        <li><a href="#legalidad">Legalidad</a></li>
        <li><a href="#programa">Programa</a></li>
        <li><a href="#instagram">Instagram</a></li>
        <li>
          <a href={waAsociarse} class="drawer-cta" target="_blank" rel="noopener noreferrer">
            Asociarme por WhatsApp
          </a>
        </li>
      </ul>
    </nav>
  </div>

  <!-- ══════════════════════════════════════════ -->
  <!-- WELCOME — relato de bienvenida (scroll-story) -->
  <!-- ══════════════════════════════════════════ -->
  <section class="welcome" id="inicio" aria-label="Bienvenida a Flora">
    <div class="welcome-stage">

      <!-- Fondos en video que evolucionan — decorativos -->
      <div class="welcome-bg" aria-hidden="true">
        <video class="welcome-img" data-bg="0" src="/welcome/01-llegada.mp4" poster="/welcome/01-llegada_poster.jpg" muted loop playsinline preload="auto" width="1600" height="900"></video>
        <video class="welcome-img" data-bg="1" src="/welcome/02-recibida.mp4" poster="/welcome/02-recibida_poster.jpg" muted loop playsinline preload="none" width="1600" height="900"></video>
        <video class="welcome-img" data-bg="2" src="/welcome/03-acompanamiento.mp4" poster="/welcome/03-acompanamiento_poster.jpg" muted loop playsinline preload="none" width="1600" height="900"></video>
        <video class="welcome-img" data-bg="3" src="/welcome/04-calidad.mp4" poster="/welcome/04-calidad_poster.jpg" muted loop playsinline preload="none" width="1600" height="900"></video>
        <video class="welcome-img" data-bg="4" src="/welcome/05-flora.mp4" poster="/welcome/05-flora_poster.jpg" muted loop playsinline preload="none" width="1600" height="900"></video>
        <div class="welcome-scrim"></div>
      </div>

      <!-- Relato -->
      <div class="welcome-content">
        <div class="welcome-lines">
          <p class="welcome-line" data-line="0">Qué bueno que llegaste.</p>
          <p class="welcome-line" data-line="1">Acá no hay estigmas.</p>
          <p class="welcome-line" data-line="2">Solo acompañamiento,</p>
          <p class="welcome-line" data-line="3">calidad y acceso legal.</p>
          <p class="welcome-line welcome-line-final" data-line="4">
            <span>Bienvenido a</span>
            <img class="welcome-line-logo" src="/img/flora-logo-white.png" alt="Flora" width="1472" height="298" />
          </p>
        </div>

        <div class="welcome-outro">
          <span class="welcome-badge">Ley 27.350 · REPROCANN · Neuquén, Patagonia</span>
          <div class="welcome-ctas">
            <a href={waAsociarse} class="btn-primary" target="_blank" rel="noopener noreferrer">
              Quiero asociarme
            </a>
            <a href="#perfiles" class="btn-secondary">Conocer Flora</a>
          </div>
        </div>
      </div>

      <!-- Indicador de scroll -->
      <div class="welcome-cue" aria-hidden="true">
        <span class="welcome-cue-label">deslizá</span>
        <span class="welcome-cue-line"></span>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- NECESIDADES — ¿En qué te puede ayudar?     -->
  <!-- ══════════════════════════════════════════ -->
  <section class="fl-section fl-perfiles" id="perfiles" aria-label="¿En qué te puede ayudar?">
    <div class="fl-wrap">
      <header class="fl-head">
        <span class="fl-eyebrow">¿En qué te puede ayudar?</span>
        <h2 class="fl-title">Cada camino<br><em>tiene su planta.</em></h2>
        <p class="fl-lead">
          El cannabis medicinal abarca muchos caminos. El equipo orienta el tuyo
          según tu situación. Pasá el mouse por cada abordaje y descubrí cuál es el tuyo.
        </p>
      </header>

      <div class="fl-gateway" role="list">
        {perfiles.map((p, i) => (
          <a
            class={`fl-panel fl-panel-${i + 1}`}
            href={p.href}
            target="_blank"
            rel="noopener noreferrer"
            role="listitem"
            aria-label={`${p.tag}: ${p.title}`}
          >
            <img class="fl-panel-img" src={p.img} alt="" loading="lazy" width="1400" height="1750" />
            <span class="fl-panel-icon" aria-hidden="true" set:html={perfilIconsSvg[i]} />
            <span class="fl-panel-body">
              <span class="fl-panel-tag">{p.tag}</span>
              <span class="fl-panel-title">{p.title}</span>
              <span class="fl-panel-desc">{p.desc}</span>
              <span class="fl-panel-cta">{p.cta} <span aria-hidden="true">→</span></span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- PRODUCTOS — Flores / Aceites / Crema       -->
  <!-- ══════════════════════════════════════════ -->
  <section class="fl-section fl-access" id="productos" aria-label="Qué hacemos y cómo accedés">
    <div class="fl-wrap">
      <header class="fl-head">
        <span class="fl-eyebrow">Nuestros productos</span>
        <h2 class="fl-title">De la planta, <em>a tu mano.</em></h2>
        <p class="fl-lead">
          Todo de cultivo propio. Cada formato lo consultás directo por WhatsApp.
        </p>
      </header>

      <div class="fl-gateway fl-prod-gateway" role="list">
        <a class="fl-panel fl-panel-1" href="#acceso" role="listitem" aria-label="Flores">
          <img class="fl-panel-img" src="/img/prod-flores.jpg" alt="" loading="lazy" width="1400" height="1750" />
          <span class="fl-panel-icon" aria-hidden="true" set:html={productIconsSvg[0]} />
          <span class="fl-panel-body">
            <span class="fl-panel-title">Flores</span>
            <span class="fl-panel-desc">Tu parte del cultivo del mes, en flor. La elegís según lo que necesites.</span>
            <span class="fl-panel-cta">Cómo acceder <span aria-hidden="true">→</span></span>
          </span>
        </a>

        <a class="fl-panel fl-panel-2" href={wa('Hola Flora, quiero consultar por los aceites medicinales 🌿')} target="_blank" rel="noopener noreferrer" role="listitem" aria-label="Aceites">
          <img class="fl-panel-img" src="/img/prod-aceites.jpg" alt="" loading="lazy" width="1400" height="1750" />
          <span class="fl-panel-icon" aria-hidden="true" set:html={productIconsSvg[1]} />
          <span class="fl-panel-body">
            <span class="fl-panel-title">Aceites</span>
            <span class="fl-panel-desc">Tres extractos sublinguales —Q1, Q2 y Q3—, uno para cada perfil. Vemos juntos cuál te conviene.</span>
            <span class="fl-panel-cta">Pedir un aceite <span aria-hidden="true">→</span></span>
          </span>
        </a>

        <a class="fl-panel fl-panel-3" href={wa('Hola Flora, quiero consultar por las cremas 🌿')} target="_blank" rel="noopener noreferrer" role="listitem" aria-label="Cremas">
          <img class="fl-panel-img" src="/img/prod-cremas.jpg" alt="" loading="lazy" width="1400" height="1750" />
          <span class="fl-panel-icon" aria-hidden="true" set:html={productIconsSvg[2]} />
          <span class="fl-panel-body">
            <span class="fl-panel-title">Cremas</span>
            <span class="fl-panel-desc">Fórmula tópica en 50 y 100 cc, para dolor localizado. De acceso libre, sin trámite de REPROCANN.</span>
            <span class="fl-panel-cta">Pedir la crema <span aria-hidden="true">→</span></span>
          </span>
        </a>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- REPROCANN — hook: el primer paso (entrevista médica) -->
  <!-- ══════════════════════════════════════════ -->
  <section class="fl-section fl-reprocann" id="entrevista" aria-label="Cómo tramitar tu REPROCANN">
    <div class="fl-wrap fl-reprocann-wrap">
      <span class="fl-eyebrow on-dark">Tu REPROCANN</span>
      <h2 class="fl-title">¿Cómo se tramita el <em>REPROCANN?</em></h2>
      <p class="fl-reprocann-lead">
        El primer paso es una entrevista con un profesional de la salud: evalúa tu caso
        y, si corresponde, te inscribe en el REPROCANN. Es también lo que te habilita a
        asociarte a Flora.
      </p>
      <a class="fl-reprocann-cta" href={wa('Hola Flora, quiero coordinar una entrevista médica para tramitar mi REPROCANN y empezar a asociarme 🌿')} target="_blank" rel="noopener noreferrer">
        Pedir mi entrevista médica <span aria-hidden="true">→</span>
      </a>
      <p class="fl-reprocann-note">Sin compromiso. Te orientamos en cada paso del trámite.</p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- ACCESO A MATERIAL VEGETAL — cultivo solidario -->
  <!-- ══════════════════════════════════════════ -->
  <section class="fl-section fl-acceso" id="acceso" aria-label="Acceso a material vegetal">
    <div class="fl-wrap">
      <div class="fl-acceso-intro">
        <span class="fl-eyebrow">Acceso a material vegetal</span>
        <h2 class="fl-title">Cultivamos lo que <em>la ley te permite.</em></h2>
        <p class="fl-acceso-story">
          Hay personas que necesitan cannabis y no pueden cultivarlo en casa.
          Lo hacemos nosotros, y tu aporte mensual mantiene viva cada planta.
        </p>
      </div>

      <div class="fl-acceso-picker">
        <span class="fl-acceso-q">¿Cuánto necesitás por mes?</span>

        <div class="fl-amounts" role="group" aria-label="Cantidad de material vegetal por mes">
          {accesoAmounts.map((a, i) => (
            <button
              type="button"
              class={i === 0 ? 'fl-amount is-active' : 'fl-amount'}
              data-g={a.g}
              data-wa={a.wa}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              {a.g}<span>g</span>
            </button>
          ))}
        </div>

        <p class="fl-acceso-detail">
          <span data-acceso-amount>10</span>&nbsp;g por mes ·
          mismo cuidado y variedades para todos.
        </p>

        <a class="fl-acceso-cta" data-acceso-cta href={accesoAmounts[0].wa} target="_blank" rel="noopener noreferrer">
          Quiero acceder <span aria-hidden="true">→</span>
        </a>

        <p class="fl-acceso-note">
          El aporte arranca en <strong>$170.000</strong> por mes y sube con la cantidad;
          lo vemos con vos. Te sugerimos empezar por la más baja.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- LEGALIDAD — Marco legal                    -->
  <!-- ══════════════════════════════════════════ -->
  <section class="fl-section fl-legal" id="legalidad" aria-label="Marco legal">
    <div class="fl-wrap">
      <header class="fl-head">
        <span class="fl-eyebrow">Respaldo legal</span>
        <h2 class="fl-title">Con todo <em>en regla.</em></h2>
        <p class="fl-lead">
          Detrás de Flora hay una entidad registrada: la Asociación Civil Cann de Cannabis
          Medicinal, con personería jurídica reconocida por la Inspección General de Justicia
          (I.G.J. N° 1994128). Todo asentado y por escrito.
        </p>
      </header>

      <div class="fl-legal-body">
        <ol class="fl-ed-list" role="list">
          {legales.map((l, i) => (
            <li class="fl-ed-row" role="listitem">
              <span class="fl-ed-num" aria-hidden="true">0{i + 1}</span>
              <div class="fl-ed-body">
                <h3 class="fl-ed-title">{l.titulo}</h3>
                <p class="fl-ed-desc">{l.desc}</p>
              </div>
            </li>
          ))}
        </ol>

        <aside class="fl-legal-aside" aria-label="Registro y consulta">
          <span class="fl-eyebrow">Registro habilitado · REPROCANN</span>
          <p class="fl-legal-aside-text">
            ¿Querés ver cómo encaja tu caso en este marco legal? Lo revisamos con vos,
            sin vueltas.
          </p>
          <a class="fl-card-cta" href={waLegal} target="_blank" rel="noopener noreferrer">
            Consultar por WhatsApp <span aria-hidden="true">→</span>
          </a>
        </aside>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- PROGRAMA — Espacio libre de prejuicios     -->
  <!-- ══════════════════════════════════════════ -->
  <section class="fl-section fl-channel" id="programa" aria-label="Nuestro canal de YouTube">
    <!-- Decoración YouTube -->
    <span class="fl-channel-deco fl-channel-deco-1" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8zM9.5 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg></span>
    <span class="fl-channel-deco fl-channel-deco-2" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>

    <div class="fl-wrap">
      <!-- Header tipo página de canal -->
      <div class="fl-channel-head">
        <span class="fl-channel-avatar">
          <img src="/favicon.png" alt="" width="512" height="512" />
        </span>
        <div class="fl-channel-id">
          <span class="fl-channel-kicker">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8zM9.5 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
            Podcast en YouTube
          </span>
          <h2 class="fl-channel-name">Espacio libre <em>de prejuicios.</em></h2>
          <span class="fl-channel-handle">@FloraCultivamosConciencia · {episodes.length} episodios</span>
        </div>
        <a class="fl-channel-sub" href={`${ytChannel}?sub_confirmation=1`} target="_blank" rel="noopener noreferrer">
          Suscribirte
        </a>
      </div>

      <p class="fl-channel-lead">
        Conversaciones sin vueltas sobre cannabis medicinal. Dale play acá o entrá al canal.
      </p>

      <!-- Episodios estilo YouTube -->
      <ul class="fl-channel-eps" role="list">
        {episodes.map((ep, i) => (
          <li class="fl-ep">
            <button
              class="yt-facade fl-ep-thumb"
              data-id={ep.id}
              data-title={ep.title}
              aria-label={`Reproducir: ${ep.title}`}
            >
              <img
                class="yt-thumb"
                src={`https://i.ytimg.com/vi/${ep.id}/hqdefault.jpg`}
                alt={`Miniatura del episodio ${ep.title}`}
                loading="lazy"
                width="480"
                height="360"
              />
              <span class="fl-ep-play" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </span>
              <span class="yt-dur" aria-hidden="true">{ep.dur}</span>
            </button>
            <div class="fl-ep-meta">
              <h3 class="fl-ep-title">{ep.title}</h3>
              <span class="fl-ep-sub">Episodio {String(i + 1).padStart(2, '0')} · {ep.dur}</span>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- INSTAGRAM — slider en vivo                 -->
  <!-- ══════════════════════════════════════════ -->
  <section class="fl-section ig-section" id="instagram" aria-label="Flora en Instagram">
    <div class="fl-wrap ig-inner">
      <div class="ig-head">
        <div class="ig-head-text">
          <span class="fl-eyebrow">Comunidad</span>
          <h2 class="fl-title">Lo último <em>en Instagram.</em></h2>
          <p class="fl-lead">
            Educación, cultivo y comunidad, día a día. Esto se actualiza solo con
            nuestros últimos posteos.
          </p>
        </div>
        <a class="ig-cta" href={igProfile} target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
          </svg>
          {igHandle}
        </a>
      </div>

      <div class="ig-slider" data-feed={igFeedUrl} data-profile={igProfile}>
        <button class="ig-nav ig-prev" type="button" aria-label="Posteos anteriores">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>

        <ul class="ig-track" role="list" aria-live="polite">
          {igFallback.map((p) => (
            <li class="ig-card is-fallback" role="listitem">
              <a class="ig-card-link" href={igProfile} target="_blank" rel="noopener noreferrer">
                <span class="ig-card-media" aria-hidden="true">
                  <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                  </svg>
                </span>
                <span class="ig-card-body">
                  <span class="ig-card-caption">{p.caption}</span>
                  <span class="ig-card-cue">Ver en Instagram →</span>
                </span>
              </a>
            </li>
          ))}
        </ul>

        <button class="ig-nav ig-next" type="button" aria-label="Posteos siguientes">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- ANÁLISIS DE LABORATORIO — al fondo          -->
  <!-- ══════════════════════════════════════════ -->
  <section class="fl-section fl-analisis" id="analisis" aria-label="Análisis de laboratorio">
    <div class="fl-wrap">
      <div class="fl-spec">
        <div class="fl-spec-head">
          <span class="fl-eyebrow">Análisis de laboratorio</span>
          <h2 class="fl-spec-title">Lo que medimos, <em>lo publicamos.</em></h2>
          <p class="fl-spec-sub">
            Cannabinoides del último lote, medidos en mg/mL por cromatografía
            (HPLC-UV · IACA Laboratorios · extracción 02/06/2026). Descargá el informe
            de cada aceite acá abajo.
          </p>
        </div>
        <div class="fl-spec-grid">
          {aceites.map((a) => (
            <article class="fl-spec-card">
              <span class="fl-spec-code">{a.codigo}</span>
              <span class="fl-spec-sublabel">{a.sub}</span>
              <dl class="fl-spec-vals" aria-label={`Perfil de ${a.codigo} en mg/mL`}>
                {a.perfil.map((p) => (
                  <div><dt>{p.k}</dt><dd>{p.v}<i>mg/mL</i></dd></div>
                ))}
              </dl>
              <a class="fl-card-cta" href={a.pdf} download>
                Descargar análisis <span aria-hidden="true">↓</span>
              </a>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- FAQ — preguntas frecuentes (acordeón)       -->
  <!-- ══════════════════════════════════════════ -->
  <section class="fl-section fl-faq" id="faq" aria-label="Preguntas frecuentes">
    <div class="fl-wrap fl-faq-wrap">
      <header class="fl-head">
        <span class="fl-eyebrow">Preguntas frecuentes</span>
        <h2 class="fl-title">Lo que <em>más nos preguntan.</em></h2>
      </header>

      <div class="fl-faq-list">
        {faqs.map((f) => (
          <details class="fl-faq-item">
            <summary class="fl-faq-q">
              <span>{f.q}</span>
              <span class="fl-faq-icon" aria-hidden="true"></span>
            </summary>
            <div class="fl-faq-a"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })} />

  <!-- ══════════════════════════════════════════ -->
  <!-- FOOTER                                     -->
  <!-- ══════════════════════════════════════════ -->
