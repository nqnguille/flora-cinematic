// ¿Por qué llegaste a Flora? — abordajes por necesidad
const perfiles = [
  {
    tag: 'Dolor & inflamación',
    title: 'Para quienes buscan una alternativa real.',
    desc: 'Variedades con alto CBD y terpenos antiinflamatorios como el beta-cariofileno. Para acompañar el dolor crónico, articular o muscular en tu día a día.',
    cta: 'Hablar sobre dolor',
    href: wa('Hola Flora, me interesa el club para manejo del dolor crónico 🌿'),
