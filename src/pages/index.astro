  <!-- INSTAGRAM — slider en vivo                 -->
  <!-- ══════════════════════════════════════════ -->
  <section class="fl-section ig-section" id="instagram" aria-label="Flora en Instagram">
    <div class="fl-wrap ig-inner">
      <div class="ig-head">
        <div class="ig-head-text">
          <span class="fl-eyebrow">Comunidad</span>
          <h2 class="fl-title">Lo último <em>en Instagram.</em></h2>
          <p class="fl-lead">
            Educación, cultivo y vínculo, día a día. Esto se actualiza solo con
            nuestros últimos posteos.
          </p>
        </div>
        <a class="ig-cta" href={igProfile} target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
          </svg>
          {igHandle}
        </a>
      </div>

      <div class="ig-slider" data-feed={igFeedUrl} data-profile={igProfile}>
        <button class="ig-nav ig-prev" type="button" aria-label="Posteos anteriores">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>

        <ul class="ig-track" role="list" aria-live="polite">
          {igFallback.map((p) => (
            <li class="ig-card is-fallback" role="listitem">
              <a class="ig-card-link" href={igProfile} target="_blank" rel="noopener noreferrer">
                <span class="ig-card-media" aria-hidden="true">
                  <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                  </svg>
                </span>
                <span class="ig-card-body">
                  <span class="ig-card-caption">{p.caption}</span>
                  <span class="ig-card-cue">Ver en Instagram →</span>
                </span>
              </a>
            </li>
          ))}
        </ul>

        <button class="ig-nav ig-next" type="button" aria-label="Posteos siguientes">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- FAQ — preguntas frecuentes (acordeón)       -->
  <!-- ══════════════════════════════════════════ -->
  <section class="fl-section fl-faq" id="faq" aria-label="Preguntas frecuentes">
    <div class="fl-wrap fl-faq-wrap">
      <header class="fl-head">
        <span class="fl-eyebrow">Preguntas frecuentes</span>
        <h2 class="fl-title">Lo que <em>más nos preguntan.</em></h2>
      </header>

      <div class="fl-faq-list">
        {faqs.map((f) => (
          <details class="fl-faq-item">
            <summary class="fl-faq-q">
              <span>{f.q}</span>
              <span class="fl-faq-icon" aria-hidden="true"></span>
            </summary>
            <div class="fl-faq-a"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })} />

  <!-- ══════════════════════════════════════════ -->
  <!-- FOOTER                                     -->
  <!-- ══════════════════════════════════════════ -->
  <footer class="fl-footer" id="contacto">
    <div class="fl-wrap">
      <div class="fl-footer-cta">
        <h3 class="fl-footer-closer">Empezá hoy, <em>en regla</em> y acompañado.</h3>
        <a href={waFooter} class="fl-footer-btn" target="_blank" rel="noopener noreferrer" aria-label="Asociarme a Flora por WhatsApp">
          Escribirnos para asociarme <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="fl-footer-grid">
        <div class="fl-footer-brand">
          <img class="fl-footer-logo-img" src="/img/flora-logo-white.png" alt="Flora" width="1472" height="298" />
          <p>
            Asociación Civil Cann de Cannabis Medicinal · I.G.J. 1994128.
            Ley 27.350 · REPROCANN. Neuquén, Patagonia.
          </p>
        </div>

        <nav class="fl-footer-col" aria-label="Navegación del sitio">
          <h4>Navegación</h4>
          <ul>
            <li><a href="#perfiles">Cómo ayudamos</a></li>
            <li><a href="#entrevista">REPROCANN</a></li>
            <li><a href="#productos">Productos</a></li>
            <li><a href="#acceso">Ser socio</a></li>
            <li><a href="#legalidad">Legalidad</a></li>
            <li><a href="#faq">Preguntas frecuentes</a></li>
          </ul>
        </nav>

        <nav class="fl-footer-col" aria-label="Legal y comunidad">
          <h4>Más</h4>
          <ul>
            <li><a href="https://www.argentina.gob.ar/normativa/nacional/ley-27350-273801" target="_blank" rel="noopener noreferrer">Ley 27.350</a></li>
            <li><a href="https://www.argentina.gob.ar/salud/cannabis-medicinal/reprocann" target="_blank" rel="noopener noreferrer">REPROCANN</a></li>
            <li><a href="#programa">Programa</a></li>
            <li><a href={igProfile} target="_blank" rel="noopener noreferrer">Instagram</a></li>
          </ul>
        </nav>
      </div>

      <div class="fl-footer-bottom">
        <p>© 2026 Flora · Asociación civil · Neuquén, Patagonia</p>
        <p>Cultivamos conciencia</p>
      </div>
    </div>
  </footer>

  <!-- WhatsApp flotante — oculto en el hero, aparece al navegar -->
  <a
    class="wa-float"
    href={waAsociarse}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Escribinos por WhatsApp"
  >
