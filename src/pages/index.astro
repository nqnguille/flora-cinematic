  {
    codigo: 'Q3',
    sub: 'Quimiotipo III · CBD predominante',
    desc: 'CBD alto y THC casi nulo, de efecto suave. Ideal para el día, la ansiedad y para empezar con un perfil liviano.',
    perfil: [
      { k: 'CBD', v: '32,6' },
      { k: 'THC', v: '1,2' },
      { k: 'CBG', v: '0,3' },
    ],
    usos: ['Uso diurno', 'Ansiedad', 'Inicio suave'],
    href: wa('Hola Flora, me interesa el aceite Q3 🌿'),
  },
]
const cremas = [
  {
    presentacion: '50 cc',
    sub: 'Presentación personal',
    desc: 'Para uso localizado y tratamientos puntuales. Fácil de llevar, ideal para incorporar la fórmula.',
    href: wa('Hola Flora, me interesa la crema 50cc 🌿'),
  },
  {
    presentacion: '100 cc',
    sub: 'Presentación completa',
    desc: 'Para uso continuo y zonas de mayor extensión. La opción de quienes ya sumaron la crema a su rutina.',
    href: wa('Hola Flora, me interesa la crema 100cc 🌿'),
  },
]

const waAsociarse = `${WA}?text=Hola%20Flora%2C%20quiero%20asociarme%20al%20club.%20%C2%BFQu%C3%A9%20necesito%20para%20empezar%3F`
const waFooter = waAsociarse
const waLegal = `${WA}?text=Hola%20Flora%2C%20tengo%20una%20consulta%20sobre%20mi%20situaci%C3%B3n%20legal%20(Ley%2027.350%20%2F%20REPROCANN).%20%C2%BFMe%20orientan%3F`

// Marco legal — pilares verificables (Ley 27.350 / REPROCANN)
const legales = [
  {
    titulo: 'Ley 27.350 vigente',
    desc: 'El marco nacional que regula el acceso al cannabis con fines medicinales en Argentina.',
  },
  {
    titulo: 'Cada asociado, con REPROCANN',
    desc: 'El cultivo se ampara en la inscripción de cada socio en el registro del programa.',
  },
  {
    titulo: 'Asociación civil de cultivo compartido',
    desc: 'Te sumás como socio del club de cultivo compartido. El acceso es por membresía a la asociación.',
  },
