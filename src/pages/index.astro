          <dl class="fl-credencial-data">
            <div><dt>CUIT</dt><dd>30-71827609-4</dd></div>
            <div><dt>Personería jurídica</dt><dd>I.G.J. N° 1994128</dd></div>
          </dl>
        </div>
        <div class="fl-credencial-sello">
