      { k: 'CBD', v: '21,8' },
      { k: 'THC', v: '51,0' },
      { k: 'CBG', v: '6,9' },
    ],
    usos: ['Uso nocturno', 'Dolor intenso', 'Descanso'],
    href: wa('Hola Flora, me interesa el aceite Q1 🌿'),
  },
  {
    codigo: 'Q2',
    sub: 'Quimiotipo II · CBD:THC balanceado',
    desc: 'Relación equilibrada entre CBD y THC. Acompaña el día y la noche. El elegido por quienes ya tienen su tratamiento calibrado.',
    perfil: [
      { k: 'CBD', v: '23,9' },
      { k: 'THC', v: '17,0' },
      { k: 'CBG', v: '1,3' },
    ],
    usos: ['Día y noche', 'Dolor moderado', 'Uso continuo'],
    href: wa('Hola Flora, me interesa el aceite Q2 🌿'),
  },
  {
    codigo: 'Q3',
    sub: 'Quimiotipo III · CBD predominante',
    desc: 'CBD alto y THC casi nulo. Sin efecto psicoactivo: ideal para el día, la ansiedad y para empezar con un perfil suave.',
    perfil: [
      { k: 'CBD', v: '32,6' },
      { k: 'THC', v: '1,2' },
      { k: 'CBG', v: '0,3' },
    ],
    usos: ['Uso diurno', 'Ansiedad', 'Inicio suave'],
    href: wa('Hola Flora, me interesa el aceite Q3 🌿'),
  },
]
const cremas = [
  {
    presentacion: '50 cc',
    sub: 'Presentación personal',
    desc: 'Para uso localizado y tratamientos puntuales. Fácil de llevar, ideal para incorporar la fórmula.',
    href: wa('Hola Flora, me interesa la crema 50cc 🌿'),
  },
  {
    presentacion: '100 cc',
    sub: 'Presentación completa',
    desc: 'Para uso continuo y zonas de mayor extensión. La opción de quienes ya sumaron la crema a su rutina.',
    href: wa('Hola Flora, me interesa la crema 100cc 🌿'),
  },
]

const waAsociarse = `${WA}?text=Hola%20Flora%2C%20quiero%20asociarme%20al%20club.%20%C2%BFQu%C3%A9%20necesito%20para%20empezar%3F`
const waFooter = waAsociarse
const waLegal = `${WA}?text=Hola%20Flora%2C%20tengo%20una%20consulta%20sobre%20mi%20situaci%C3%B3n%20legal%20(Ley%2027.350%20%2F%20REPROCANN).%20%C2%BFMe%20orientan%3F`

// Marco legal — pilares verificables (Ley 27.350 / REPROCANN)
const legales = [
  {
    titulo: 'Ley 27.350 vigente',
    desc: 'El marco nacional que regula el acceso al cannabis con fines medicinales en Argentina.',
  },
  {
    titulo: 'Cada asociado, con REPROCANN',
    desc: 'El cultivo se ampara en la inscripción de cada socio en el registro del programa.',
  },
  {
    titulo: 'Asociación civil, sin compraventa',
    desc: 'Te sumás como socio del club de cultivo compartido. El acceso es por membresía, no por venta.',
  },
  {
    titulo: 'Decreto 883/2020',
    desc: 'Reglamenta el autocultivo y el cultivo solidario entre personas asociadas.',
  },
]

const memberships = [
  {
    name: 'Semilla',
    grams: '10',
    features: [
      'Acceso mensual a tu parte del cultivo',
      'Variedad rotativa de temporada',
      'Cultivo propio, sin pesticidas',
      'Sin compraventa — marco Ley 27.350',
    ],
    featured: false,
    waLink: `${WA}?text=Hola%20Flora%2C%20me%20interesa%20la%20membres%C3%ADa%20Semilla%20(10g).%20%C2%BFPueden%20darme%20m%C3%A1s%20informaci%C3%B3n%3F`,
  },
  {
    name: 'Raíz',
    grams: '20',
    features: [
      'Acceso mensual a tu parte del cultivo',
      'Elección de variedad disponible',
      'Orientación para elegir tu variedad',
      'Acompañamiento por WhatsApp',
      'Sin compraventa — marco Ley 27.350',
    ],
    featured: true,
    badge: 'El más elegido',
    waLink: `${WA}?text=Hola%20Flora%2C%20me%20interesa%20la%20membres%C3%ADa%20Ra%C3%ADz%20(20g).%20%C2%BFPueden%20darme%20m%C3%A1s%20informaci%C3%B3n%3F`,
  },
  {
    name: 'Cosecha',
    grams: '30',
    features: [
      'Acceso mensual a tu parte del cultivo',
      'Prioridad en variedades nuevas',
      'Sesión de orientación inicial',
      'Acompañamiento directo del equipo',
      'Sin compraventa — marco Ley 27.350',
    ],
    featured: false,
    waLink: `${WA}?text=Hola%20Flora%2C%20me%20interesa%20la%20membres%C3%ADa%20Cosecha%20(30g).%20%C2%BFPueden%20darme%20m%C3%A1s%20informaci%C3%B3n%3F`,
  },
  {
    name: 'Tierra',
    grams: '40',
    features: [
      'Acceso mensual a tu parte del cultivo',
      'Acceso a todas las variedades del club',
      'Acceso a los aceites con cromatografía (Q1·Q2·Q3)',
      'Acompañamiento prioritario 24h',
      'Invitaciones a ciclos de formación',
      'Sin compraventa — marco Ley 27.350',
    ],
    featured: false,
    waLink: `${WA}?text=Hola%20Flora%2C%20me%20interesa%20la%20membres%C3%ADa%20Tierra%20(40g).%20%C2%BFPueden%20darme%20m%C3%A1s%20informaci%C3%B3n%3F`,
  },
]

const steps = [
  {
    num: '01',
    title: 'Completás el formulario de ingreso',
    desc: 'Dos minutos. Nos contás tu situación, si tenés REPROCANN o si estás en trámite. Sin papeles físicos por ahora.',
  },
  {
    num: '02',
    title: 'Revisamos tu solicitud',
    desc: 'El equipo de Flora la revisa en 24 a 48 horas hábiles. Te avisamos por WhatsApp cuando está aprobada.',
  },
  {
    num: '03',
    title: 'Elegís tu membresía',
    desc: 'Una vez adentro, elegís el plan que se ajusta a tu uso y lo podés cambiar cuando quieras.',
  },
  {
    num: '04',
    title: 'Accedés al cultivo compartido',
    desc: 'Recibís tu parte del cultivo del mes. Todo dentro del marco legal del club. Sin intermediarios, sin grises.',
  },
]

// Programa de YouTube — "Espacio libre de prejuicios"
const ytChannel = 'https://www.youtube.com/@FloraCultivamosConciencia'
const episodes = [
  { id: 'lqiDznxJHgE', title: 'Dolor crónico: ¿THC o CBD?', dur: '25:07' },
  { id: '69kQ-XoVmuU', title: 'Ansiedad y estrés', dur: '29:41' },
]

// Instagram — slider en vivo. El feed lo sirve Behold (behold.so): JSON con
// imágenes hosteadas estables + CORS, refresco automático del token. Si no
// responde, se muestran estas tarjetas de respaldo y el botón al perfil.
const igHandle = '@flora.cultivamosconciencia'
const igProfile = 'https://www.instagram.com/flora.cultivamosconciencia/'
const igFeedUrl = 'https://feeds.behold.so/BdL7J34neXVcfDDQ3Qe2'
const igFallback = [
  { caption: 'Efecto séquito: por qué la planta entera funciona mejor que un cannabinoide aislado.' },
  { caption: 'Cómo elegir tu aceite: quimiotipo, relación CBD:THC y para qué sirve cada uno.' },
  { caption: 'Punto de corte: cuándo se cosecha y por qué cambia el efecto final.' },
  { caption: 'REPROCANN al día: qué cambió en la última resolución y cómo te afecta.' },
  { caption: 'Derribando mitos: lo que se dice del THC y lo que dice la evidencia.' },
]
---

<Layout
  title="Flora ONG — Club de cultivo de cannabis medicinal en Neuquén"
  description="Club de cultivo bajo Ley 27.350 / REPROCANN. Acceso mensual a cultivo propio y aceites con cromatografía, sin intermediarios. Neuquén, Patagonia, Argentina."
>

  <!-- Skip to content para navegación por teclado -->
  <a class="skip-link" href="#inicio">Ir al contenido principal</a>

  <!-- Page loader -->
  <div class="page-loader" role="status" aria-label="Cargando Flora ONG">
    <span class="loader-logo">Flora</span>
    <span class="loader-tagline">Cannabis medicinal</span>
    <div class="loader-progress" aria-hidden="true"></div>
  </div>

  <!-- Scroll progress bar -->
  <div class="scroll-progress" aria-hidden="true" role="progressbar" aria-valuemin="0" aria-valuemax="100"></div>

  <!-- Nav fija -->
  <nav class="site-nav" aria-label="Navegación principal">
    <a href="#inicio" class="nav-logo" aria-label="Flora ONG — inicio">Flora</a>

    <!-- Desktop links -->
    <ul class="nav-links" role="list">
      <li><a href="#perfiles">Para qué</a></li>
      <li><a href="#flora">Por qué Flora</a></li>
      <li><a href="#productos">Productos</a></li>
      <li><a href="#legalidad">Legalidad</a></li>
      <li><a href="#membresias">Membresías</a></li>
      <li><a href="#programa">Programa</a></li>
      <li>
        <a href={waAsociarse} class="nav-cta" target="_blank" rel="noopener noreferrer">
          Asociarme
        </a>
      </li>
    </ul>

    <!-- Hamburguesa — solo mobile -->
    <button
      class="nav-hamburger"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-drawer"
    >
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
    </button>
  </nav>

  <!-- Drawer mobile -->
  <div class="mobile-drawer" id="mobile-drawer" role="dialog" aria-modal="true" aria-label="Menú de navegación" hidden>
    <div class="drawer-backdrop"></div>
    <nav class="drawer-panel" aria-label="Navegación mobile">
      <button class="drawer-close" aria-label="Cerrar menú">
        <span aria-hidden="true">✕</span>
      </button>
      <ul role="list">
        <li><a href="#nosotros">Nosotros</a></li>
        <li><a href="#perfiles">Para qué sirve</a></li>
        <li><a href="#flora">Por qué Flora</a></li>
        <li><a href="#productos">Productos</a></li>
        <li><a href="#legalidad">Legalidad</a></li>
        <li><a href="#membresias">Membresías</a></li>
        <li><a href="#como-funciona">Cómo funciona</a></li>
        <li><a href="#programa">Programa</a></li>
        <li>
          <a href={waAsociarse} class="drawer-cta" target="_blank" rel="noopener noreferrer">
            Asociarme por WhatsApp
          </a>
        </li>
      </ul>
    </nav>
  </div>

  <!-- ══════════════════════════════════════════ -->
  <!-- HERO                                       -->
  <!-- ══════════════════════════════════════════ -->
  <section class="hero" id="inicio" aria-label="Inicio">

    <!-- Fondo de video — decorativo. Poster local = imagen LCP y fallback reduced-motion -->
    <div class="hero-visual" aria-hidden="true">
      <img
        src="/hero/cannabis-hero-poster.jpg"
        alt=""
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1280"
        height="720"
        id="hero-img"
      />
      <video
        id="hero-video"
        class="hero-video"
        muted
        loop
        playsinline
        preload="none"
        poster="/hero/cannabis-hero-poster.jpg"
      >
        <source src="/hero/cannabis-hero-720.webm" type="video/webm" />
        <source src="/hero/cannabis-hero-720.mp4" type="video/mp4" />
      </video>
    </div>

    <!-- Viñeta -->
    <div class="hero-vignette" aria-hidden="true"></div>

    <!-- Partículas -->
    <div class="hero-particles" aria-hidden="true"></div>

    <!-- Número de año decorativo -->
    <span class="hero-year" aria-hidden="true">Est. 2022</span>

    <!-- Contenido principal -->
    <div class="hero-content">
      <div class="hero-eyebrow">
        <span class="hero-badge">Ley 27.350 · REPROCANN</span>
        <span class="hero-badge-sep" aria-hidden="true"></span>
        <span class="hero-badge-location">Neuquén, Patagonia</span>
      </div>

      <h1 class="hero-title split-words">
        Cultivamos<br>lo que la ley<br><em class="accent-word">te permite.</em>
      </h1>

      <div class="hero-bottom">
        <p class="hero-subtext">
          Cultivo propio y acompañamiento real.<br>Sin intermediarios. Con la ley a favor.
        </p>

        <div class="hero-ctas">
          <a href={waAsociarse} class="btn-primary" target="_blank" rel="noopener noreferrer">
            Quiero asociarme
          </a>
          <a href="#membresias" class="btn-secondary">Ver membresías</a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator" aria-hidden="true">
      <div class="scroll-line"></div>
      <span class="scroll-label">scroll</span>
    </div>

    <!-- Ticker -->
    <div class="hero-ticker" aria-hidden="true">
      <div class="ticker-track">
        <span>CULTIVAMOS CONCIENCIA &nbsp;·&nbsp; CANNABIS MEDICINAL &nbsp;·&nbsp; NEUQUÉN ARGENTINA &nbsp;·&nbsp; LEY 27.350 &nbsp;·&nbsp; REPROCANN &nbsp;·&nbsp; CULTIVO PROPIO &nbsp;·&nbsp; </span>
        <span>CULTIVAMOS CONCIENCIA &nbsp;·&nbsp; CANNABIS MEDICINAL &nbsp;·&nbsp; NEUQUÉN ARGENTINA &nbsp;·&nbsp; LEY 27.350 &nbsp;·&nbsp; REPROCANN &nbsp;·&nbsp; CULTIVO PROPIO &nbsp;·&nbsp; </span>
        <span>CULTIVAMOS CONCIENCIA &nbsp;·&nbsp; CANNABIS MEDICINAL &nbsp;·&nbsp; NEUQUÉN ARGENTINA &nbsp;·&nbsp; LEY 27.350 &nbsp;·&nbsp; REPROCANN &nbsp;·&nbsp; CULTIVO PROPIO &nbsp;·&nbsp; </span>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- STATS                                      -->
  <!-- ══════════════════════════════════════════ -->
  <section class="stats-section" id="nosotros" aria-label="Flora en números">
    <div class="stats-grid">
      <div class="stat-item">
        <span class="stat-number count-up" data-target="200" data-suffix="+">200+</span>
        <span class="stat-label">Asociados</span>
      </div>
      <div class="stat-item">
        <span class="stat-number count-up" data-target="3" data-suffix=" años">3 años</span>
        <span class="stat-label">Activos</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">Todo el país</span>
        <span class="stat-label">Alcance</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">27.350</span>
        <span class="stat-label">Ley nacional</span>
      </div>
    </div>
    <div class="stats-separator"></div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- PERFILES — ¿Por qué llegaste a Flora?      -->
  <!-- ══════════════════════════════════════════ -->
  <section class="perfiles-section" id="perfiles" aria-label="Por qué llegaste a Flora">
    <div class="perfiles-inner">
      <div class="perfiles-head">
        <h2 class="split-words">¿Por qué llegaste<br><em>a Flora?</em></h2>
        <p class="perfiles-lead">
          El cannabis medicinal abarca muchos caminos. El equipo orienta el tuyo
          según tu situación. Decinos qué te trae y avanzamos desde ahí.
        </p>
      </div>

      <div class="perfiles-grid" role="list">
        {perfiles.map((p) => (
          <article class="perfil-card fade-in" role="listitem">
            <span class="perfil-tag">{p.tag}</span>
            <h3 class="perfil-title">{p.title}</h3>
            <p class="perfil-desc">{p.desc}</p>
            <a class="perfil-cta" href={p.href} target="_blank" rel="noopener noreferrer">
              {p.cta} <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- POR QUÉ FLORA — BENTO                      -->
  <!-- ══════════════════════════════════════════ -->
  <section class="why-section" id="flora" aria-label="Por qué Flora">
    <div class="why-inner">

      <div class="section-header">
        <div>
          <span class="section-label on-light">Por qué Flora</span>
          <h2 class="section-title split-words">Sabés lo que<br><em>recibís.</em></h2>
        </div>
        <p class="section-tagline">
          Un club de cultivo es una forma legal de organizarse para acceder a lo que la ley ya permite.
        </p>
      </div>

      <div class="why-bento" role="list">

        <!-- Celda statement editorial grande -->
        <div class="bento-statement" role="listitem">
          <div>
            <p class="bento-statement-text">
              Flora existe para que ese acceso sea real, documentado y sin intermediarios.
            </p>
          </div>
          <div>
            <p class="bento-statement-sub">
              Cultivo propio, marco legal y el equipo acompañando cada paso.
            </p>
            <div class="bento-law-badge" aria-label="Marco legal">
              <span>Ley 27.350 · REPROCANN</span>
            </div>
          </div>
        </div>

        <!-- Grilla de razones -->
        <div class="bento-items" role="list">
          <div class="bento-item" role="listitem">
            <span class="bento-item-num">01</span>
            <h3 class="bento-item-title">Cultivo propio</h3>
            <p class="bento-item-desc">Cultivamos nuestras plantas en sala controlada, sin pesticidas. Vos accedés a tu parte como socio del club.</p>
          </div>

          <div class="bento-item" role="listitem">
            <span class="bento-item-num">02</span>
            <h3 class="bento-item-title">Aceites con cromatografía</h3>
            <p class="bento-item-desc">Nuestros tres aceites —Q1, Q2 y Q3— tienen análisis HPLC que informa su concentración real de CBD, THC y CBG.</p>
          </div>

          <div class="bento-item" role="listitem">
            <span class="bento-item-num">03</span>
            <h3 class="bento-item-title">Marco legal vigente</h3>
            <p class="bento-item-desc">Operamos bajo Ley 27.350 y marco REPROCANN. Sin compraventa, sin grises, sin riesgo para vos.</p>
          </div>

          <div class="bento-item" role="listitem">
            <span class="bento-item-num">04</span>
            <h3 class="bento-item-title">Acompañamiento real</h3>
            <p class="bento-item-desc">Respondemos por WhatsApp. Una persona del equipo, no un bot. Porque tus preguntas merecen respuestas.</p>
          </div>

          <div class="bento-item" role="listitem">
            <span class="bento-item-num">05</span>
            <h3 class="bento-item-title">Educación, no estigma</h3>
            <p class="bento-item-desc">Te explicamos cada cannabinoide, cada vía de consumo y cada paso. Cultivamos conciencia, no consumo a ciegas.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- PRODUCTOS — Flores / Aceites / Crema       -->
  <!-- ══════════════════════════════════════════ -->
  <section class="productos-section" id="productos" aria-label="Nuestros productos">
    <div class="productos-inner">
      <div class="productos-head">
        <span class="section-label on-dark">Nuestros productos</span>
        <h2 class="split-words">Tres formas<br><em>de acceder.</em></h2>
        <p class="productos-lead">
          Flor de cultivo propio, aceites sublinguales con cromatografía y crema
          tópica. Todo con el acompañamiento del equipo.
        </p>
      </div>

      <!-- Selector de formato -->
      <div class="prod-tabs" role="tablist" aria-label="Formatos disponibles">
        <button class="prod-tab is-active" role="tab" aria-selected="true" data-tab="flores">
          <span class="prod-tab-name">Flores</span>
          <span class="prod-tab-sub">Membresía mensual</span>
        </button>
        <button class="prod-tab" role="tab" aria-selected="false" data-tab="aceites">
          <span class="prod-tab-name">Aceites</span>
          <span class="prod-tab-sub">Q1 · Q2 · Q3</span>
        </button>
        <button class="prod-tab" role="tab" aria-selected="false" data-tab="cremas">
          <span class="prod-tab-name">Crema</span>
          <span class="prod-tab-sub">50cc · 100cc</span>
        </button>
      </div>

      <!-- Panel: Flores -->
      <div class="prod-panel is-active" role="tabpanel" data-panel="flores">
        <p class="prod-panel-lead">
          Flor seca de cultivo propio. Cada lote con perfil completo de cannabinoides
          y terpenos. Se accede por membresía mensual, sin contratos.
        </p>
        <div class="prod-flores-cta">
          <div>
            <span class="prod-flores-eyebrow">Cuatro planes</span>
            <p class="prod-flores-text">Semilla 10g · Raíz 20g · Cosecha 30g · Tierra 40g por mes.</p>
          </div>
          <a class="prod-link" href="#membresias">Ver planes de flores ↓</a>
        </div>
      </div>

      <!-- Panel: Aceites -->
      <div class="prod-panel" role="tabpanel" data-panel="aceites" hidden>
        <p class="prod-panel-lead">
          Extractos sublinguales de producción propia. Tres quimiotipos con distinta
          relación CBD:THC, cada uno con su análisis de cromatografía.
        </p>
        <div class="prod-cards">
          {aceites.map((a) => (
            <article class="prod-card">
              <span class="prod-card-eyebrow">Aceite medicinal</span>
              <span class="prod-card-big">{a.codigo}</span>
              <span class="prod-card-sub">{a.sub}</span>
              <p class="prod-card-desc">{a.desc}</p>
              <dl class="prod-perfil" aria-label={`Perfil de cannabinoides de ${a.codigo} en mg/mL`}>
                {a.perfil.map((p) => (
                  <div class="prod-perfil-item">
                    <dt>{p.k}</dt>
                    <dd>{p.v}</dd>
                  </div>
                ))}
              </dl>
              <div class="prod-tags">
                {a.usos.map((u) => <span class="prod-tag-pill">{u}</span>)}
              </div>
              <a class="prod-card-cta" href={a.href} target="_blank" rel="noopener noreferrer">
                Consultar {a.codigo} →
              </a>
            </article>
          ))}
        </div>
        <p class="prod-foot">Valores en mg/mL de la última cromatografía (HPLC-UV · IACA Laboratorios · junio 2026). Disponibilidad por consulta.</p>
      </div>

      <!-- Panel: Crema -->
      <div class="prod-panel" role="tabpanel" data-panel="cremas" hidden>
        <p class="prod-panel-lead">
          Formulación tópica antiinflamatoria de uso externo. Una fórmula, dos
          presentaciones. Para dolor localizado, articulaciones y recuperación muscular.
        </p>
        <div class="prod-cards prod-cards-2">
          {cremas.map((c) => (
            <article class="prod-card">
              <span class="prod-card-eyebrow">Presentación</span>
              <span class="prod-card-big">{c.presentacion}</span>
              <span class="prod-card-sub">{c.sub}</span>
              <p class="prod-card-desc">{c.desc}</p>
              <a class="prod-card-cta" href={c.href} target="_blank" rel="noopener noreferrer">
                Consultar {c.presentacion} →
              </a>
            </article>
          ))}
        </div>
        <p class="prod-foot">Uso externo. No requiere REPROCANN. Disponibilidad por consulta.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- LEGALIDAD — Marco legal                    -->
  <!-- ══════════════════════════════════════════ -->
  <section class="legal-section" id="legalidad" aria-label="Marco legal">
    <div class="legal-inner">

      <div class="legal-head">
        <span class="section-label on-light">Marco legal</span>
        <h2 class="section-title split-words">Operamos dentro<br><em>de la ley.</em></h2>
        <p class="legal-lead">
          Flora es una asociación civil de cultivo compartido. El acceso es como socio,
          dentro de la Ley 27.350 y el marco REPROCANN. Con todo por escrito.
        </p>
      </div>

      <div class="legal-body">
        <ul class="legal-list" role="list">
          {legales.map((l) => (
            <li class="legal-item fade-in" role="listitem">
              <span class="legal-check" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </span>
              <div class="legal-item-text">
                <h3>{l.titulo}</h3>
                <p>{l.desc}</p>
              </div>
            </li>
          ))}
        </ul>

        <aside class="legal-aside fade-in" aria-label="Registro y consulta">
          <div class="legal-badge">
            <span class="legal-badge-mark" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                <polyline points="9 12 11 14 15 10" />
              </svg>
            </span>
            <div>
              <span class="legal-badge-eyebrow">Registro habilitado</span>
              <span class="legal-badge-name">REPROCANN</span>
            </div>
          </div>
          <p class="legal-aside-text">
            ¿Tenés dudas sobre tu situación o tu trámite? Te orientamos sin compromiso,
            con una persona del equipo.
          </p>
          <a class="legal-aside-cta" href={waLegal} target="_blank" rel="noopener noreferrer">
            Consultar por WhatsApp →
          </a>
        </aside>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- MEMBRESÍAS — HORIZONTAL SCROLL             -->
  <!-- ══════════════════════════════════════════ -->
  <section class="horizontal-section" id="membresias" aria-label="Membresías">
    <div class="horizontal-inner">
      <div class="horizontal-header">
        <span class="section-label on-dark">Membresías</span>
        <h2 class="split-words">Elegí cómo<br>acceder.</h2>
        <div class="horizontal-scroll-hint" aria-hidden="true">
          <span class="hint-arrow"></span>
          <span>deslizá</span>
        </div>
      </div>

      <div class="cards-track-wrapper" aria-label="Planes disponibles">
        <div class="cards-track" role="list">
          {memberships.map((m) => (
            <div
              class={m.featured ? 'membresia-card featured' : 'membresia-card'}
              role="listitem"
              aria-label={`Membresía ${m.name}: ${m.grams} gramos por mes`}
            >
              {m.badge && <span class="card-badge" aria-label="Plan más popular">{m.badge}</span>}
              <h3 class="card-title">{m.name}</h3>
              <div class="card-grams" aria-label={`${m.grams} gramos`}>
                {m.grams}<span class="card-grams-unit">g</span>
              </div>
              <p class="card-unit">por mes · cultivo compartido</p>
              <ul class="card-features" aria-label="Características incluidas">
                {m.features.map((f) => <li>{f}</li>)}
              </ul>
              <a
                href={m.waLink}
                class="card-cta"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Consultar membresía ${m.name} por WhatsApp`}
              >
                Consultar por WhatsApp
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- CÓMO FUNCIONA                              -->
  <!-- ══════════════════════════════════════════ -->
  <section class="steps-section" id="como-funciona" aria-label="Cómo funciona">
    <div class="steps-inner">

      <div class="section-header">
        <div>
          <span class="section-label on-light">Proceso</span>
          <h2 class="section-title split-words">Cuatro pasos.<br><em>Sin grises.</em></h2>
        </div>
      </div>

      <div class="steps-list-wrap">
        <div class="step-connector" aria-hidden="true">
          <div class="step-line"></div>
        </div>
      <ol class="steps-list" aria-label="Pasos para asociarse">
        {steps.map((step) => (
          <li class="step-item">
            <div class="step-num-wrap" aria-hidden="true">
              <span class="step-num">{step.num}</span>
            </div>
            <div class="step-content">
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
            </div>
          </li>
        ))}
      </ol>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- PROGRAMA — Espacio libre de prejuicios     -->
  <!-- ══════════════════════════════════════════ -->
  <section class="programa-section" id="programa" aria-label="Programa Espacio libre de prejuicios">
    <div class="programa-inner">
      <div class="programa-head">
        <span class="section-label">Programa en YouTube</span>
        <h2 class="split-words">Espacio libre<br>de prejuicios.</h2>
        <p class="programa-lead">
          Conversaciones sin vueltas sobre cannabis medicinal: acceso, legalidad y
          bienestar. Para informarte antes de opinar.
        </p>
        <a class="programa-cta" href={ytChannel} target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
          </svg>
          Ver el canal
        </a>
      </div>

      <ul class="programa-episodes" role="list">
        {episodes.map((ep) => (
          <li class="episode-card clip-reveal">
            <button
              class="yt-facade"
              data-id={ep.id}
              data-title={ep.title}
              aria-label={`Reproducir episodio: ${ep.title}`}
            >
              <img
                class="yt-thumb"
                src={`https://i.ytimg.com/vi/${ep.id}/hqdefault.jpg`}
                alt={`Miniatura del episodio ${ep.title}`}
                loading="lazy"
                width="480"
                height="360"
              />
              <span class="yt-play" aria-hidden="true">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </span>
              <span class="yt-dur" aria-hidden="true">{ep.dur}</span>
            </button>
            <div class="episode-meta">
              <span class="episode-eyebrow">Episodio</span>
              <h3>{ep.title}</h3>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- INSTAGRAM — slider en vivo                 -->
  <!-- ══════════════════════════════════════════ -->
  <section class="ig-section" id="instagram" aria-label="Flora en Instagram">
    <div class="ig-inner">
      <div class="ig-head">
        <div class="ig-head-text">
          <span class="section-label">Comunidad</span>
          <h2 class="split-words">Lo último<br><em>en Instagram.</em></h2>
          <p class="ig-lead">
            Educación, cultivo y comunidad, día a día. Esto se actualiza solo con
            nuestros últimos posteos.
          </p>
        </div>
        <a class="ig-cta" href={igProfile} target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
          </svg>
          {igHandle}
        </a>
      </div>

      <div class="ig-slider" data-feed={igFeedUrl} data-profile={igProfile}>
        <button class="ig-nav ig-prev" type="button" aria-label="Posteos anteriores">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>

        <ul class="ig-track" role="list" aria-live="polite">
          {igFallback.map((p) => (
            <li class="ig-card is-fallback" role="listitem">
              <a class="ig-card-link" href={igProfile} target="_blank" rel="noopener noreferrer">
                <span class="ig-card-media" aria-hidden="true">
                  <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                  </svg>
                </span>
                <span class="ig-card-body">
                  <span class="ig-card-caption">{p.caption}</span>
                  <span class="ig-card-cue">Ver en Instagram →</span>
                </span>
              </a>
            </li>
          ))}
        </ul>

        <button class="ig-nav ig-next" type="button" aria-label="Posteos siguientes">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!-- FOOTER                                     -->
  <!-- ══════════════════════════════════════════ -->
  <footer class="footer" id="contacto">
    <div class="footer-cta-band">
      <h3>¿Listo para empezar?</h3>
      <a href={waFooter} class="btn-primary" target="_blank" rel="noopener noreferrer" aria-label="Asociarme a Flora por WhatsApp">
        Asociarme por WhatsApp
      </a>
    </div>

    <div class="footer-grid">
      <div class="footer-brand">
        <h4>Flora ONG</h4>
        <p>
          Club de cultivo de cannabis medicinal. Legal bajo Ley 27.350.
          Neuquén, Patagonia.
        </p>
      </div>

      <nav class="footer-col" aria-label="Navegación del sitio">
        <h5>Navegación</h5>
        <ul>
          <li><a href="#nosotros">Nosotros</a></li>
          <li><a href="#perfiles">Para qué sirve</a></li>
          <li><a href="#flora">Por qué Flora</a></li>
          <li><a href="#productos">Productos</a></li>
          <li><a href="#legalidad">Legalidad</a></li>
          <li><a href="#membresias">Membresías</a></li>
          <li><a href="#como-funciona">Cómo funciona</a></li>
        </ul>
      </nav>

      <nav class="footer-col" aria-label="Información legal">
        <h5>Legal</h5>
        <ul>
          <li><a href="#">Ley 27.350</a></li>
          <li><a href="#">REPROCANN</a></li>
          <li><a href="#">Estatuto ONG</a></li>
          <li><a href="#">Términos de uso</a></li>
        </ul>
      </nav>
    </div>

    <div class="footer-bottom">
      <p>© 2026 Flora ONG · Neuquén, Patagonia</p>
      <p>Cultivamos conciencia</p>
    </div>
  </footer>

  <!-- WhatsApp flotante — oculto en el hero, aparece al navegar -->
  <a
    class="wa-float"
    href={waAsociarse}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Escribinos por WhatsApp"
  >
    <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor" aria-hidden="true">
      <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.477-.911zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
    </svg>
  </a>
</Layout>
