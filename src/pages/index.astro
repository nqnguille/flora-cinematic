// Acceso a material vegetal. La cantidad (10 a 40 g por mes)
// se elige una vez adentro, por WhatsApp. Mismo acompañamiento y variedades para todos.
const accesoWa = wa('Hola Flora, quiero acceder al material vegetal. ¿Me orientan para empezar?')

// Programa de YouTube — "Espacio libre de prejuicios"
const ytChannel = 'https://www.youtube.com/@FloraCultivamosConciencia'
const episodes = [
