const memberships = [
  {
    name: 'Semilla',
    grams: '10',
    features: [
      'Acceso mensual a tu parte del cultivo',
      'Variedad rotativa de temporada',
      'Cultivo propio, sin pesticidas',
    ],
    featured: false,
    waLink: `${WA}?text=Hola%20Flora%2C%20me%20interesa%20la%20membres%C3%ADa%20Semilla%20(10g).%20%C2%BFPueden%20darme%20m%C3%A1s%20informaci%C3%B3n%3F`,
  },
  {
    name: 'Raíz',
    grams: '20',
    features: [
      'Acceso mensual a tu parte del cultivo',
      'Elección de variedad disponible',
      'Orientación para elegir tu variedad',
      'Acompañamiento por WhatsApp',
    ],
    featured: true,
    badge: 'El más elegido',
    waLink: `${WA}?text=Hola%20Flora%2C%20me%20interesa%20la%20membres%C3%ADa%20Ra%C3%ADz%20(20g).%20%C2%BFPueden%20darme%20m%C3%A1s%20informaci%C3%B3n%3F`,
  },
  {
    name: 'Cosecha',
    grams: '30',
    features: [
      'Acceso mensual a tu parte del cultivo',
      'Prioridad en variedades nuevas',
