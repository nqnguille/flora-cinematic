  .pa-tab-panel[hidden] { display: none; }

  /* ── Genéticas: toolbar (filtros + buscador) ── */
  .pa-toolbar { display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap; margin-bottom: 1.1rem; }
  .pa-availfilter { display: flex; gap: 0.3rem; }
