---
import Layout from '../../../layouts/Layout.astro'
import '../../../styles/global.css'

const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || ''
---

<Layout
  title="Panel de genéticas — admin | Flora ONG"
  description="Panel interno para gestionar el catálogo de genéticas."
  noindex={true}
>
  <main class="ad-main">
    <div class="ad-wrap">
      <span class="ad-eyebrow">Panel interno</span>
      <h1 class="ad-title">Catálogo de genéticas</h1>

      <div id="ad-login" class="ad-login">
        <div id="g_id_button"></div>
        <p id="ad-login-msg" class="ad-msg" hidden></p>
      </div>

      <div id="ad-forbidden" class="ad-msg" hidden>
        Tu cuenta de Google inició sesión pero no tiene permisos de administrador.
      </div>

      <div id="ad-content" class="ad-content" hidden>
        <div class="ad-tabs" role="tablist">
          <button class="ad-tab is-active" data-tab="geneticas" type="button">Genéticas</button>
          <button class="ad-tab" data-tab="socios" type="button">Socios</button>
        </div>

        <!-- ── Pestaña Genéticas ── -->
        <div id="tab-geneticas" class="ad-tab-panel">
          <div class="ad-toolbar">
            <div class="ad-availfilter" role="group" aria-label="Filtrar por disponibilidad">
              <button class="ad-avail is-active" data-avail="" type="button">Todas</button>
              <button class="ad-avail" data-avail="on" type="button">Disponibles</button>
              <button class="ad-avail" data-avail="off" type="button">No disponibles</button>
            </div>
            <input id="ad-search" class="ad-input ad-search" type="search" placeholder="Buscar por nombre…" autocomplete="off" />
            <span id="ad-count" class="ad-count"></span>
          </div>

          <div class="ad-genscroll">
            <div class="ad-rows-head">
              <span>Disp.</span><span>Nombre</span><span>Banco</span><span>Tipo</span>
              <span>Predominancia</span><span>THC</span><span>CBD</span>
              <span>Formato</span><span>Sabor</span><span>Efecto</span><span>Foto</span><span></span>
            </div>
            <div id="ad-list" class="ad-rows"></div>
          </div>
          <button id="ad-add" type="button" class="ad-btn ad-btn-ghost">+ Agregar genética</button>

          <div class="ad-savebar">
            <span id="ad-save-status" class="ad-save-status"></span>
            <button id="ad-save" type="button" class="ad-btn ad-btn-primary">Guardar cambios</button>
          </div>
        </div>

        <!-- ── Pestaña Socios ── -->
        <div id="tab-socios" class="ad-tab-panel" hidden>
          <p class="ad-help">
            Cargá el <strong>email de la cuenta de Google</strong> con la que el socio va a entrar, y opcionalmente
            una nota para reconocerlo. Apenas ingrese, su ficha se completa sola con el nombre y la foto de Google.
          </p>
          <form id="ad-socio-form" class="ad-socio-form">
            <input id="ad-socio-email" type="email" class="ad-input" placeholder="email@gmail.com" autocomplete="off" required />
            <input id="ad-socio-nota" type="text" class="ad-input" placeholder="Nota (ej. Gastón — WhatsApp)" autocomplete="off" />
            <button type="submit" class="ad-btn ad-btn-primary">Agregar socio</button>
          </form>
          <p id="ad-socio-status" class="ad-save-status"></p>
          <div id="ad-socios-list" class="ad-socios-list"></div>
        </div>
      </div>
    </div>
  </main>

  <script src="https://accounts.google.com/gsi/client" async defer is:inline></script>
  <script src="/socios/icons.js" is:inline></script>
  <script src="/socios/bancos.js" is:inline></script>
  <script define:vars={{ googleClientId }}>
    let CATALOG = []

    function esc(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]))
    }

    function tipoLabel(t) { return t === 'hibrida' ? 'Híbrida' : t === 'cbd' ? 'Full CBD' : t[0].toUpperCase() + t.slice(1) }

    function bancoOptionsHtml(current) {
      const bancos = window.FLORA_BANCOS
      return Object.entries(bancos)
        .map(([slug, b]) => `<option value="${slug}" ${slug === current ? 'selected' : ''}>${esc(b.nombre)}</option>`)
        .join('') + `<option value="" ${!(current in bancos) ? 'selected' : ''}>Otro</option>`
    }

    // ── Desplegable tildable (formato / sabor / efecto) ──
    const DD_LABEL = { formato: 'Formato', sabor: 'Sabor', efecto: 'Efecto' }
    function ddOptions(dim) {
      if (dim === 'formato') return [['flor', 'Flor a granel', ''], ['preroll', 'Preroll 1g', '']]
      const cat = window.FLORA_TAG_ICONS[dim] || {}
      return Object.entries(cat).map(([k, def]) => [k, def.label, def.svg])
    }
    function ddHtml(dim, idx, selected) {
      const sel = selected || []
      const opts = ddOptions(dim).map(([val, lab, icon]) => {
        const on = sel.includes(val)
        return `<label class="ad-ddopt ${on ? 'is-on' : ''}"><input type="checkbox" data-dd="${dim}" data-idx="${idx}" value="${esc(val)}" ${on ? 'checked' : ''} />${icon ? `<span class="ad-ddicon">${icon}</span>` : ''}<span>${esc(lab)}</span></label>`
      }).join('')
      const n = sel.length
      return `<div class="ad-dd" data-ddwrap="${dim}-${idx}">
        <button type="button" class="ad-dd-toggle ${n ? 'has' : ''}"><span class="ad-dd-txt">${DD_LABEL[dim]}${n ? ` · ${n}` : ''}</span><svg class="ad-dd-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button>
        <div class="ad-dd-panel" hidden>${opts}</div>
      </div>`
    }
    function updateDd(i, dim) {
      const wrap = document.querySelector(`[data-ddwrap="${dim}-${i}"]`)
      if (!wrap) return
      const key = dim === 'formato' ? 'formatos' : dim === 'sabor' ? 'sabores' : 'efectos'
      const sel = CATALOG[i][key] || []
      wrap.querySelector('.ad-dd-txt').textContent = DD_LABEL[dim] + (sel.length ? ` · ${sel.length}` : '')
      wrap.querySelector('.ad-dd-toggle').classList.toggle('has', sel.length > 0)
      wrap.querySelectorAll('.ad-ddopt').forEach((opt) => opt.classList.toggle('is-on', opt.querySelector('input').checked))
    }

    function rowHtml(g, idx) {
      const fotoSrc = g.foto || (g.id ? `/socios/geneticas/${g.id}.webp` : '')
      return `
      <div class="ad-row" data-idx="${idx}">
        <label class="ad-avail-toggle" title="Disponible en la carta">
          <input type="checkbox" data-field="activo" data-idx="${idx}" ${g.activo ? 'checked' : ''} />
        </label>
        <input class="ad-input" data-field="nombre" data-idx="${idx}" value="${esc(g.nombre)}" placeholder="Nombre" />
        <select class="ad-input" data-field="bancoSlug" data-idx="${idx}">${bancoOptionsHtml(g.bancoSlug)}</select>
        <select class="ad-input" data-field="tipo" data-idx="${idx}">${['sativa', 'indica', 'hibrida', 'cbd'].map((t) => `<option value="${t}" ${g.tipo === t ? 'selected' : ''}>${tipoLabel(t)}</option>`).join('')}</select>
        <input class="ad-input" data-field="predominancia" data-idx="${idx}" value="${esc(g.predominancia)}" placeholder="70% S | 30% I" />
        <input class="ad-input ad-cell-num" data-field="thc" data-idx="${idx}" value="${esc(g.thc)}" placeholder="THC" />
        <input class="ad-input ad-cell-num" data-field="cbd" data-idx="${idx}" value="${esc(g.cbd)}" placeholder="CBD" />
        ${ddHtml('formato', idx, g.formatos && g.formatos.length ? g.formatos : ['flor'])}
        ${ddHtml('sabor', idx, g.sabores || [])}
        ${ddHtml('efecto', idx, g.efectos || [])}
        <div class="ad-foto">
          <div class="ad-foto-thumb">${fotoSrc ? `<img src="${esc(fotoSrc)}" alt="" onerror="this.remove()" />` : ''}</div>
          <input type="file" accept="image/jpeg,image/png,image/webp" id="ad-foto-${idx}" class="ad-foto-input" data-foto-idx="${idx}" hidden />
          <label for="ad-foto-${idx}" class="ad-foto-btn" title="Subir imagen">📷</label>
          <span class="ad-foto-status" data-fotostatus-idx="${idx}"></span>
        </div>
        <button type="button" class="ad-del" data-idx="${idx}" aria-label="Eliminar">×</button>
      </div>`
    }

    let availFilter = ''
    let searchQ = ''
    function updateCount() {
      const disp = CATALOG.filter((g) => g.activo).length
      const el = document.getElementById('ad-count')
      if (el) el.textContent = `${disp} disponible(s) · ${CATALOG.length} en total`
    }
    function render() {
      const q = searchQ.toLowerCase()
      const html = CATALOG.map((g, i) => {
        if (availFilter === 'on' && !g.activo) return ''
        if (availFilter === 'off' && g.activo) return ''
        if (q && !String(g.nombre || '').toLowerCase().includes(q)) return ''
        return rowHtml(g, i)
      }).join('')
      document.getElementById('ad-list').innerHTML = html || '<p class="ad-empty">Ninguna genética coincide con el filtro.</p>'
      updateCount()
    }

    function slugify(s) {
      return String(s).toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '')
    }

    let statusTimer = null
    function flashStatus(msg) {
      const el = document.getElementById('ad-save-status')
      el.textContent = msg
      clearTimeout(statusTimer)
      statusTimer = setTimeout(() => (el.textContent = ''), 3000)
    }
    async function autoSaveActivo(i) {
      const g = CATALOG[i]
      if (!g.id || String(g.id).startsWith('nueva-')) { flashStatus('Guardá para aplicar la disponibilidad'); return }
      try {
        const res = await fetch('/api/socios/admin/geneticas', {
          method: 'PATCH', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
          body: JSON.stringify({ id: g.id, activo: g.activo }),
        })
        flashStatus(res.ok ? 'Disponibilidad guardada ✓' : 'Error al guardar')
      } catch { flashStatus('Error de red') }
    }

    // Filtros del panel (disponibilidad + buscador)
    document.querySelectorAll('.ad-avail').forEach((b) => b.addEventListener('click', () => {
      document.querySelectorAll('.ad-avail').forEach((x) => x.classList.remove('is-active'))
      b.classList.add('is-active'); availFilter = b.dataset.avail; render()
    }))
    document.getElementById('ad-search').addEventListener('input', (e) => { searchQ = e.target.value.trim(); render() })

    // Edición de campos + dropdowns + toggle disponible (autoguardado)
    document.addEventListener('input', (e) => {
      const t = e.target
      const idx = t.getAttribute('data-idx')
      if (idx === null) return
      const i = Number(idx)
      const field = t.getAttribute('data-field')
      const dd = t.getAttribute('data-dd')

      if (dd) {
        const key = dd === 'formato' ? 'formatos' : dd === 'sabor' ? 'sabores' : 'efectos'
        const max = dd === 'formato' ? 99 : 2
        let arr = Array.isArray(CATALOG[i][key]) ? [...CATALOG[i][key]] : []
        if (t.checked) {
          if (arr.length >= max) { t.checked = false; return }
          if (!arr.includes(t.value)) arr.push(t.value)
        } else {
          arr = arr.filter((v) => v !== t.value)
        }
        CATALOG[i][key] = arr
        updateDd(i, dd)
      } else if (field === 'activo') {
        CATALOG[i].activo = t.checked
        autoSaveActivo(i)
        updateCount()
        if (availFilter) render()
      } else if (field) {
        CATALOG[i][field] = t.value
      }
    })

    // Abrir/cerrar los desplegables tildables
    document.addEventListener('click', (e) => {
      const tgl = e.target.closest('.ad-dd-toggle')
      const panels = document.querySelectorAll('.ad-dd-panel')
      if (tgl) {
        const panel = tgl.nextElementSibling
        const willOpen = panel.hidden
        panels.forEach((p) => { if (p !== panel) { p.hidden = true; p.previousElementSibling.classList.remove('open') } })
        panel.hidden = !willOpen
        tgl.classList.toggle('open', willOpen)
        return
      }
      if (!e.target.closest('.ad-dd-panel')) panels.forEach((p) => { p.hidden = true; p.previousElementSibling.classList.remove('open') })
    })

    document.addEventListener('click', (e) => {
      const del = e.target.closest('.ad-del')
      if (del) {
        CATALOG.splice(Number(del.getAttribute('data-idx')), 1)
        render()
        return
      }
      const clr = e.target.closest('.ad-foto-clear')
      if (clr) {
        CATALOG[Number(clr.getAttribute('data-fotoclear-idx'))].foto = null
        render()
      }
    })

    // Subida de foto: sube el archivo a KV y guarda la URL en la genética.
    document.addEventListener('change', async (e) => {
      const inp = e.target
      if (!inp.classList || !inp.classList.contains('ad-foto-input')) return
      const i = Number(inp.getAttribute('data-foto-idx'))
      const file = inp.files && inp.files[0]
      if (!file) return
      const status = document.querySelector(`[data-fotostatus-idx="${i}"]`)
      if (status) status.textContent = 'Subiendo…'
      const fd = new FormData()
      fd.append('id', CATALOG[i].id || slugify(CATALOG[i].nombre) || 'foto')
      fd.append('file', file)
      try {
        const res = await fetch('/api/socios/admin/foto', { method: 'POST', credentials: 'include', body: fd })
        const data = await res.json()
        if (res.ok && data.ok) { CATALOG[i].foto = data.url; render() }
        else if (status) status.textContent = 'Error: ' + (data.error || res.status)
      } catch {
        if (status) status.textContent = 'Error de red'
      }
    })

    document.getElementById('ad-add').addEventListener('click', () => {
      CATALOG.push({
        id: `nueva-${Date.now()}`,
        nombre: '',
        banco: '',
        bancoSlug: '',
        predominancia: '',
        tipo: 'hibrida',
        thc: '',
        cbd: '',
        sabores: [],
        efectos: [],
        formatos: ['flor'],
        foto: null,
        activo: false,
      })
      render()
    })

    document.getElementById('ad-save').addEventListener('click', async () => {
      const status = document.getElementById('ad-save-status')
      status.textContent = 'Guardando…'
      CATALOG.forEach((g) => {
        if (!g.id) g.id = slugify(g.nombre) || `genetica-${Date.now()}`
        g.banco = (window.FLORA_BANCOS[g.bancoSlug] || {}).nombre || g.banco || ''
      })
      try {
        const res = await fetch('/api/socios/admin/geneticas', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ geneticas: CATALOG }),
        })
        const data = await res.json()
        status.textContent = res.ok && data.ok ? 'Guardado ✓' : `Error: ${data.error || res.status}`
      } catch {
        status.textContent = 'Error de red al guardar.'
      }
      setTimeout(() => (status.textContent = ''), 4000)
    })

    /* ── Pestañas ── */
    document.querySelectorAll('.ad-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const name = tab.dataset.tab
        document.querySelectorAll('.ad-tab').forEach((t) => t.classList.toggle('is-active', t === tab))
        document.getElementById('tab-geneticas').hidden = name !== 'geneticas'
        document.getElementById('tab-socios').hidden = name !== 'socios'
        if (name === 'socios') loadSocios()
      })
    })

    /* ── Socios ── */
    function fmtFecha(iso) {
      if (!iso) return '—'
      try {
        const d = new Date(iso)
        return d.toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric' }) +
          ' ' + d.toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit' })
      } catch { return iso }
    }
    function initials(s) {
      const t = (s || '').trim()
      if (!t) return '?'
      const p = t.split(/\s+/)
      return ((p[0]?.[0] || '') + (p[1]?.[0] || '')).toUpperCase() || '?'
    }
    function socioRow(s) {
      const ava = `<span class="ad-socio-ava"><span class="ad-socio-ini">${esc(initials(s.name || s.email))}</span>${s.picture ? `<img src="${esc(s.picture)}" alt="" referrerpolicy="no-referrer" onerror="this.remove()" />` : ''}</span>`
      const estado = s.lastLogin
        ? '<span class="ad-socio-badge is-on">Ingresó</span>'
        : '<span class="ad-socio-badge">Sin ingresar</span>'
      const meta = s.lastLogin
        ? `Último ingreso: ${fmtFecha(s.lastLogin)} · ${s.logins} ingreso(s)`
        : 'Todavía no ingresó con esta cuenta'
      return `
        <article class="ad-socio">
          ${ava}
          <div class="ad-socio-main">
            <div class="ad-socio-top">
              <strong class="ad-socio-name">${esc(s.name || '(sin nombre aún)')}</strong>
              ${estado}
            </div>
            <div class="ad-socio-email">${esc(s.email)}</div>
            <input class="ad-input ad-socio-nota" data-email="${esc(s.email)}" value="${esc(s.nota)}" placeholder="Nota…" />
            <div class="ad-socio-meta">${meta}</div>
          </div>
          <button type="button" class="ad-socio-del" data-email="${esc(s.email)}" aria-label="Eliminar socio">×</button>
        </article>`
    }
    async function loadSocios() {
      const list = document.getElementById('ad-socios-list')
      list.innerHTML = '<p class="ad-save-status">Cargando…</p>'
      try {
        const res = await fetch('/api/socios/admin/socios', { credentials: 'include' })
        const data = await res.json()
        if (!res.ok || !data.ok) { list.innerHTML = `<p class="ad-msg">Error: ${esc(data.error || res.status)}</p>`; return }
        list.innerHTML = data.socios.length
          ? data.socios.map(socioRow).join('')
          : '<p class="ad-save-status">Todavía no hay socios cargados.</p>'
      } catch {
        list.innerHTML = '<p class="ad-msg">Error de red al cargar socios.</p>'
      }
    }
    async function saveSocio(email, nota) {
      const res = await fetch('/api/socios/admin/socios', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ email, nota }),
      })
      return res.ok
    }
    document.getElementById('ad-socio-form').addEventListener('submit', async (e) => {
      e.preventDefault()
      const emailEl = document.getElementById('ad-socio-email')
      const notaEl = document.getElementById('ad-socio-nota')
      const status = document.getElementById('ad-socio-status')
      const email = emailEl.value.trim().toLowerCase()
      if (!email) return
      status.textContent = 'Guardando…'
      const ok = await saveSocio(email, notaEl.value.trim())
      status.textContent = ok ? 'Socio agregado ✓' : 'Error al agregar'
      if (ok) { emailEl.value = ''; notaEl.value = ''; loadSocios() }
      setTimeout(() => (status.textContent = ''), 3000)
    })
    document.addEventListener('change', (e) => {
      const nota = e.target.closest && e.target.closest('.ad-socio-nota')
      if (nota) saveSocio(nota.getAttribute('data-email'), nota.value)
    })
    document.addEventListener('click', async (e) => {
      const del = e.target.closest && e.target.closest('.ad-socio-del')
      if (!del) return
      const email = del.getAttribute('data-email')
      if (!confirm('¿Dar de baja a ' + email + '? No podrá entrar a la carta.')) return
      await fetch('/api/socios/admin/socios', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ email }),
      })
      loadSocios()
    })

    function showLoginError(message) {
      const msg = document.getElementById('ad-login-msg')
      msg.textContent = message
      msg.hidden = false
    }

    async function loadCatalog() {
      const res = await fetch('/api/socios/admin/geneticas', { credentials: 'include' })
      if (res.status === 401) return false
      if (res.status === 403) {
        document.getElementById('ad-login').hidden = true
        document.getElementById('ad-forbidden').hidden = false
        return true
      }
      const data = await res.json()
      CATALOG = data.geneticas || []
      // La pestaña Socios solo la ve el super admin.
      if (!data.isSuperAdmin) {
        const tabSocios = document.querySelector('.ad-tab[data-tab="socios"]')
        if (tabSocios) tabSocios.hidden = true
      }
      document.getElementById('ad-login').hidden = true
      document.getElementById('ad-content').hidden = false
      render()
      return true
    }

    window.handleGoogleCredential = async (response) => {
      try {
        const res = await fetch('/api/socios/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ credential: response.credential }),
        })
        const data = await res.json()
        if (!res.ok || !data.ok) {
          showLoginError(data.error || 'No se pudo verificar tu cuenta.')
          return
        }
        await loadCatalog()
      } catch {
        showLoginError('Error de red al verificar con Google.')
      }
    }

    if (googleClientId) {
      window.onload = () => {
        google.accounts.id.initialize({ client_id: googleClientId, callback: window.handleGoogleCredential })
        google.accounts.id.renderButton(document.getElementById('g_id_button'), { theme: 'filled_black', size: 'large', text: 'signin_with' })
      }
    } else {
      showLoginError('Falta configurar el Google Client ID del sitio.')
    }

    loadCatalog()
  </script>
</Layout>

<style is:global>
  /* ══════════════════════════════════════════════
     PANEL ADMIN — modo nocturno de marca (igual carta)
     Violeta profundo · crema · acentos violeta/verde
  ══════════════════════════════════════════════ */
  .ad-main {
    --ad-bg:     #130d1c;
    --ad-card:   #1c1430;
    --ad-card-2: #251a3d;
    --ad-line:   rgba(244, 241, 247, 0.1);
    --ad-cream:  #f4f1f7;
    --ad-muted:  rgba(244, 241, 247, 0.55);
    --ad-violet: #b79de6;
    --ad-green:  #3cb492;
    --ad-danger: #f2818a;

    min-height: 100svh;
    padding: clamp(24px, 4vw, 56px) clamp(16px, 4vw, 40px);
    background: var(--ad-bg);
    color: var(--ad-cream);
    font-family: var(--font-ui);
    position: relative;
  }
  .ad-main::before {
    content: '';
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background:
      radial-gradient(55% 40% at 88% -5%, rgba(56, 31, 86, 0.5), transparent 70%),
      radial-gradient(50% 35% at 0% 100%, rgba(10, 80, 60, 0.14), transparent 70%);
  }
  html, body { background-color: #130d1c; }

