  }
  .pa-dd-panel[hidden] { display: none; }
  .pa-ddopt {
    display: flex; align-items: center; gap: 0.5rem; padding: 0.42rem 0.5rem; border-radius: 8px;
    font-size: 0.82rem; color: var(--pa-muted); cursor: pointer;
  }
  .pa-ddopt:hover { background: rgba(244, 241, 247, 0.05); }
  .pa-ddopt.is-on { color: var(--pa-cream); }
  .pa-ddopt input { accent-color: var(--pa-violet); flex-shrink: 0; }
  .pa-ddicon { width: 16px; height: 16px; display: inline-flex; color: var(--pa-violet); flex-shrink: 0; }
  .pa-ddicon svg { width: 100%; height: 100%; }

  /* ── Subida de foto ── */
  .pa-foto { display: flex; align-items: center; flex-wrap: wrap; gap: 0.7rem; }
