---
import Layout from '../../../layouts/Layout.astro'
import '../../../styles/global.css'

const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || ''
---

<Layout
  title="Panel de genéticas — admin | Flora ONG"
  description="Panel interno para gestionar el catálogo de genéticas."
  noindex={true}
>
  <main class="pa-main">
    <div class="pa-wrap">
      <span class="pa-eyebrow">Panel interno</span>
      <h1 class="pa-title">Catálogo de genéticas</h1>

      <div id="pa-login" class="pa-login">
        <div id="g_id_button"></div>
        <p id="pa-login-msg" class="pa-msg" hidden></p>
      </div>

      <div id="pa-forbidden" class="pa-msg" hidden>
        Tu cuenta de Google inició sesión pero no tiene permisos de administrador.
      </div>

      <div id="pa-content" class="pa-content" hidden>
        <div class="pa-tabs" role="tablist">
          <button class="pa-tab is-active" data-tab="geneticas" type="button">Genéticas</button>
          <button class="pa-tab" data-tab="pedidos" type="button">Reservas<span id="pa-ped-dot" class="pa-ped-dot" hidden></span></button>
          <button class="pa-tab" data-tab="socios" type="button">Socios</button>
        </div>

        <!-- ── Pestaña Genéticas ── -->
        <div id="tab-geneticas" class="pa-tab-panel">
          <div class="pa-toolbar">
            <div class="pa-availfilter" role="group" aria-label="Filtrar por disponibilidad">
              <button class="pa-avail is-active" data-avail="" type="button">Todas</button>
              <button class="pa-avail" data-avail="on" type="button">Disponibles</button>
              <button class="pa-avail" data-avail="off" type="button">No disponibles</button>
            </div>
            <input id="pa-search" class="pa-input pa-search" type="search" placeholder="Buscar por nombre…" autocomplete="off" />
            <span id="pa-count" class="pa-count"></span>
          </div>

          <div class="pa-genscroll">
            <div class="pa-rows-head">
              <span>Disp.</span><span>Nombre</span><span>Banco</span><span>Tipo</span>
              <span>Predominancia</span><span>THC</span><span>CBD</span>
              <span>Formato</span><span>Sabores</span><span>Efectos</span><span>Foto</span><span></span>
            </div>
            <div id="pa-list" class="pa-rows"></div>
          </div>
          <button id="pa-add" type="button" class="pa-btn pa-btn-ghost">+ Agregar genética</button>

          <div class="pa-savebar">
            <span id="pa-save-status" class="pa-save-status"></span>
            <button id="pa-save" type="button" class="pa-btn pa-btn-primary">Guardar cambios</button>
          </div>
        </div>

        <!-- ── Pestaña Reservas ── -->
        <div id="tab-pedidos" class="pa-tab-panel" hidden>
          <div class="pa-toolbar">
            <div class="pa-availfilter" role="group" aria-label="Filtrar reservas">
              <button class="pa-pedfilter pa-avail is-active" data-pedfilter="activos" type="button">Activas</button>
              <button class="pa-pedfilter pa-avail" data-pedfilter="" type="button">Todas</button>
            </div>
            <button id="pa-ped-refresh" type="button" class="pa-btn pa-btn-ghost pa-btn-slim">↻ Actualizar</button>
            <span id="pa-ped-count" class="pa-count"></span>
          </div>
          <div id="pa-pedidos-list" class="pa-socios-list"></div>
        </div>

        <!-- ── Pestaña Socios ── -->
        <div id="tab-socios" class="pa-tab-panel" hidden>
          <p class="pa-help">
            Cargá el <strong>email de la cuenta de Google</strong> con la que el socio va a entrar, y opcionalmente
            una nota para reconocerlo. Apenas ingrese, su ficha se completa sola con el nombre y la foto de Google.
          </p>
          <form id="pa-socio-form" class="pa-socio-form">
            <input id="pa-socio-email" type="email" class="pa-input" placeholder="email@gmail.com" autocomplete="off" required />
            <input id="pa-socio-nota" type="text" class="pa-input" placeholder="Nota (ej. Gastón — WhatsApp)" autocomplete="off" />
            <button type="submit" class="pa-btn pa-btn-primary">Agregar socio</button>
          </form>
          <p id="pa-socio-status" class="pa-save-status"></p>
          <div id="pa-socios-list" class="pa-socios-list"></div>
        </div>
      </div>
    </div>
  </main>

  <script src="https://accounts.google.com/gsi/client" async defer is:inline></script>
  <script src="/socios/icons.js" is:inline></script>
  <script src="/socios/bancos.js" is:inline></script>
  <script define:vars={{ googleClientId }}>
    // Cazador de errores: cualquier excepción no capturada se muestra en un
    // cartel visible en vez de dejar la página muda/negra. Diagnóstico > silencio.
    function showFatal(msg) {
      let el = document.getElementById('pa-fatal')
      if (!el) {
        el = document.createElement('div')
        el.id = 'pa-fatal'
        el.style.cssText = 'position:fixed;top:0;left:0;right:0;z-index:9999;background:#7a1f2b;color:#fff;font:600 13px/1.5 system-ui;padding:10px 16px;white-space:pre-wrap;word-break:break-word'
        document.body.appendChild(el)
      }
      el.textContent = '⚠ Error del panel (sacale captura y pasásela a Claude): ' + msg
    }
    window.addEventListener('error', (e) => showFatal((e.message || 'error') + (e.filename ? ` @ ${e.filename.split('/').pop()}:${e.lineno}` : '')))
    window.addEventListener('unhandledrejection', (e) => showFatal('promesa rechazada: ' + (e.reason?.message || e.reason)))

    // ── Sonda de diagnóstico TEMPORAL (pantalla negra) ──
    // A los 4s y 15s de abrir, radiografía la pantalla y la manda a /api/socios/debug:
    // qué hay arriba de todo en el centro, qué capas fijas cubren el viewport,
    // si el título es visible y en qué estado quedó la sesión. Sacar al cazar el bug.
    function diagSnapshot(tag) {
      try {
        const w = innerWidth, h = innerHeight
        const pick = (el) => {
          const cs = getComputedStyle(el)
          return { t: el.tagName, id: el.id || '', cls: String(el.className).slice(0, 90), pos: cs.position, z: cs.zIndex, bg: cs.backgroundColor, op: cs.opacity, mix: cs.mixBlendMode, disp: cs.display }
        }
        const centerStack = (document.elementsFromPoint(w / 2, h / 2) || []).slice(0, 7).map(pick)
        const fixedCovers = [...document.querySelectorAll('body *')].filter((el) => {
          const cs = getComputedStyle(el)
          if (cs.position !== 'fixed' || cs.display === 'none' || cs.visibility === 'hidden') return false
          const r = el.getBoundingClientRect()
          return r.width >= w * 0.9 && r.height >= h * 0.9
        }).slice(0, 8).map(pick)
        const vis = (id) => { const el = document.getElementById(id); if (!el) return null; const r = el.getBoundingClientRect(); return { hidden: el.hidden, h: Math.round(r.height) } }
        const title = document.querySelector('.pa-title')
        const tcs = title ? getComputedStyle(title) : null
        const ba = getComputedStyle(document.body, '::after')
        const diag = {
          tag, ts: new Date().toISOString(), ua: navigator.userAgent.slice(0, 120), vw: w, vh: h,
          login: vis('pa-login'), content: vis('pa-content'), forbidden: vis('pa-forbidden'),
          title: title ? { h: Math.round(title.getBoundingClientRect().height), top: Math.round(title.getBoundingClientRect().top), color: tcs.color, disp: tcs.display, vis: tcs.visibility, op: tcs.opacity } : null,
          centerStack, fixedCovers,
          bodyAfter: { disp: ba.display, mix: ba.mixBlendMode, z: ba.zIndex, pos: ba.position },
          catalogLen: typeof CATALOG !== 'undefined' ? CATALOG.length : -1,
          fatal: document.getElementById('pa-fatal')?.textContent || null,
          htmlCls: document.documentElement.className, bodyCls: document.body.className,
        }
        navigator.sendBeacon('/api/socios/debug', new Blob([JSON.stringify(diag)], { type: 'text/plain' }))
      } catch (e) {
        try { navigator.sendBeacon('/api/socios/debug', new Blob([JSON.stringify({ tag, error: String(e) })], { type: 'text/plain' })) } catch {}
      }
    }
    setTimeout(() => diagSnapshot('t4'), 4000)
    setTimeout(() => diagSnapshot('t15'), 15000)

    let CATALOG = []

    function esc(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]))
    }

    function tipoLabel(t) { return t === 'hibrida' ? 'Híbrida' : t === 'cbd' ? 'Full CBD' : t[0].toUpperCase() + t.slice(1) }

    function bancoOptionsHtml(current) {
      const bancos = window.FLORA_BANCOS
      return Object.entries(bancos)
        .map(([slug, b]) => `<option value="${slug}" ${slug === current ? 'selected' : ''}>${esc(b.nombre)}</option>`)
        .join('') + `<option value="" ${!(current in bancos) ? 'selected' : ''}>Otro</option>`
    }

    // ── Desplegable tildable (formato / sabor / efecto) ──
    const DD_LABEL = { formato: 'Formato', sabor: 'Sabores', efecto: 'Efectos' }
    function ddOptions(dim) {
      if (dim === 'formato') return [['flor', 'Flor a granel', ''], ['preroll', 'Preroll 1g', '']]
      const cat = window.FLORA_TAG_ICONS[dim] || {}
      return Object.entries(cat).map(([k, def]) => [k, def.label, def.svg])
    }
    function ddHtml(dim, idx, selected) {
      const sel = selected || []
      const opts = ddOptions(dim).map(([val, lab, icon]) => {
        const on = sel.includes(val)
        return `<label class="pa-ddopt ${on ? 'is-on' : ''}"><input type="checkbox" data-dd="${dim}" data-idx="${idx}" value="${esc(val)}" ${on ? 'checked' : ''} />${icon ? `<span class="pa-ddicon">${icon}</span>` : ''}<span>${esc(lab)}</span></label>`
      }).join('')
      const n = sel.length
      return `<div class="pa-dd" data-ddwrap="${dim}-${idx}">
        <button type="button" class="pa-dd-toggle ${n ? 'has' : ''}"><span class="pa-dd-txt">${DD_LABEL[dim]}${n ? ` · ${n}` : ''}</span><svg class="pa-dd-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button>
        <div class="pa-dd-panel" hidden>${opts}</div>
      </div>`
    }
    function updateDd(i, dim) {
      const wrap = document.querySelector(`[data-ddwrap="${dim}-${i}"]`)
      if (!wrap) return
      const key = dim === 'formato' ? 'formatos' : dim === 'sabor' ? 'sabores' : 'efectos'
      const sel = CATALOG[i][key] || []
      wrap.querySelector('.pa-dd-txt').textContent = DD_LABEL[dim] + (sel.length ? ` · ${sel.length}` : '')
      wrap.querySelector('.pa-dd-toggle').classList.toggle('has', sel.length > 0)
      wrap.querySelectorAll('.pa-ddopt').forEach((opt) => opt.classList.toggle('is-on', opt.querySelector('input').checked))
    }

    function rowHtml(g, idx) {
      const fotoSrc = g.foto || (g.id ? `/socios/geneticas/${g.id}.webp` : '')
      return `
      <div class="pa-row" data-idx="${idx}">
        <label class="pa-avail-toggle" title="Disponible en la carta">
          <input type="checkbox" data-field="activo" data-idx="${idx}" ${g.activo ? 'checked' : ''} />
        </label>
        <input class="pa-input" data-field="nombre" data-idx="${idx}" value="${esc(g.nombre)}" placeholder="Nombre" />
        <select class="pa-input" data-field="bancoSlug" data-idx="${idx}">${bancoOptionsHtml(g.bancoSlug)}</select>
        <select class="pa-input" data-field="tipo" data-idx="${idx}">${['sativa', 'indica', 'hibrida', 'cbd'].map((t) => `<option value="${t}" ${g.tipo === t ? 'selected' : ''}>${tipoLabel(t)}</option>`).join('')}</select>
        <input class="pa-input" data-field="predominancia" data-idx="${idx}" value="${esc(g.predominancia)}" placeholder="70% S | 30% I" />
        <input class="pa-input pa-cell-num" data-field="thc" data-idx="${idx}" value="${esc(g.thc)}" placeholder="THC" />
        <input class="pa-input pa-cell-num" data-field="cbd" data-idx="${idx}" value="${esc(g.cbd)}" placeholder="CBD" />
        ${ddHtml('formato', idx, g.formatos && g.formatos.length ? g.formatos : ['flor'])}
        ${ddHtml('sabor', idx, g.sabores || [])}
        ${ddHtml('efecto', idx, g.efectos || [])}
        <div class="pa-foto">
          <div class="pa-foto-thumb">${fotoSrc ? `<img src="${esc(fotoSrc)}" alt="" onerror="this.remove()" />` : ''}</div>
          <input type="file" accept="image/jpeg,image/png,image/webp" id="pa-foto-${idx}" class="pa-foto-input" data-foto-idx="${idx}" hidden />
          <label for="pa-foto-${idx}" class="pa-foto-btn" title="Subir imagen">📷</label>
          <span class="pa-foto-status" data-fotostatus-idx="${idx}"></span>
        </div>
        <button type="button" class="pa-del" data-idx="${idx}" aria-label="Eliminar">×</button>
      </div>`
    }

    let availFilter = ''
    let searchQ = ''
    function updateCount() {
      const disp = CATALOG.filter((g) => g.activo).length
      const el = document.getElementById('pa-count')
      if (el) el.textContent = `${disp} disponible(s) · ${CATALOG.length} en total`
    }
    function render() {
      const q = searchQ.toLowerCase()
      const html = CATALOG.map((g, i) => {
        if (availFilter === 'on' && !g.activo) return ''
        if (availFilter === 'off' && g.activo) return ''
        if (q && !String(g.nombre || '').toLowerCase().includes(q)) return ''
        return rowHtml(g, i)
      }).join('')
      document.getElementById('pa-list').innerHTML = html || '<p class="pa-empty">Ninguna genética coincide con el filtro.</p>'
      updateCount()
    }

    function slugify(s) {
      return String(s).toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '')
    }

    let statusTimer = null
    function flashStatus(msg) {
      const el = document.getElementById('pa-save-status')
      el.textContent = msg
      clearTimeout(statusTimer)
      statusTimer = setTimeout(() => (el.textContent = ''), 3000)
    }
    async function autoSaveActivo(i) {
      const g = CATALOG[i]
      if (!g.id || String(g.id).startsWith('nueva-')) { flashStatus('Guardá para aplicar la disponibilidad'); return }
      try {
        const res = await fetch('/api/socios/admin/geneticas', {
          method: 'PATCH', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
          body: JSON.stringify({ id: g.id, activo: g.activo }),
        })
        flashStatus(res.ok ? 'Disponibilidad guardada ✓' : 'Error al guardar')
      } catch { flashStatus('Error de red') }
    }

    // Filtros del panel (disponibilidad + buscador) — scopeados a SU pestaña:
    // los botones de Reservas también llevan .pa-avail y se pisaban con estos.
    document.querySelectorAll('#tab-geneticas .pa-avail').forEach((b) => b.addEventListener('click', () => {
      document.querySelectorAll('#tab-geneticas .pa-avail').forEach((x) => x.classList.remove('is-active'))
      b.classList.add('is-active'); availFilter = b.dataset.avail; render()
    }))
    document.getElementById('pa-search').addEventListener('input', (e) => { searchQ = e.target.value.trim(); render() })

    // Edición de campos + dropdowns + toggle disponible (autoguardado)
    document.addEventListener('input', (e) => {
      const t = e.target
      const idx = t.getAttribute('data-idx')
      if (idx === null) return
      const i = Number(idx)
      const field = t.getAttribute('data-field')
      const dd = t.getAttribute('data-dd')

      if (dd) {
        const key = dd === 'formato' ? 'formatos' : dd === 'sabor' ? 'sabores' : 'efectos'
        const max = dd === 'formato' ? 99 : 2
        let arr = Array.isArray(CATALOG[i][key]) ? [...CATALOG[i][key]] : []
        if (t.checked) {
          if (arr.length >= max) { t.checked = false; return }
          if (!arr.includes(t.value)) arr.push(t.value)
        } else {
          arr = arr.filter((v) => v !== t.value)
        }
        CATALOG[i][key] = arr
        updateDd(i, dd)
      } else if (field === 'activo') {
        CATALOG[i].activo = t.checked
        autoSaveActivo(i)
        updateCount()
        if (availFilter) render()
      } else if (field) {
        CATALOG[i][field] = t.value
      }
    })

    // Abrir/cerrar los desplegables tildables
    document.addEventListener('click', (e) => {
      const tgl = e.target.closest('.pa-dd-toggle')
      const panels = document.querySelectorAll('.pa-dd-panel')
      if (tgl) {
        const panel = tgl.nextElementSibling
        const willOpen = panel.hidden
        panels.forEach((p) => { if (p !== panel) { p.hidden = true; p.previousElementSibling.classList.remove('open') } })
        panel.hidden = !willOpen
        tgl.classList.toggle('open', willOpen)
        return
      }
      if (!e.target.closest('.pa-dd-panel')) panels.forEach((p) => { p.hidden = true; p.previousElementSibling.classList.remove('open') })
    })

    document.addEventListener('click', (e) => {
      const del = e.target.closest('.pa-del')
      if (del) {
        CATALOG.splice(Number(del.getAttribute('data-idx')), 1)
        render()
        return
      }
      const clr = e.target.closest('.pa-foto-clear')
      if (clr) {
        CATALOG[Number(clr.getAttribute('data-fotoclear-idx'))].foto = null
        render()
      }
    })

    // Subida de foto: sube el archivo a KV y guarda la URL en la genética.
    document.addEventListener('change', async (e) => {
      const inp = e.target
      if (!inp.classList || !inp.classList.contains('pa-foto-input')) return
      const i = Number(inp.getAttribute('data-foto-idx'))
      const file = inp.files && inp.files[0]
      if (!file) return
      const status = document.querySelector(`[data-fotostatus-idx="${i}"]`)
      if (status) status.textContent = 'Subiendo…'
      const fd = new FormData()
      fd.append('id', CATALOG[i].id || slugify(CATALOG[i].nombre) || 'foto')
      fd.append('file', file)
      try {
        const res = await fetch('/api/socios/admin/foto', { method: 'POST', credentials: 'include', body: fd })
        const data = await res.json()
        if (res.ok && data.ok) { CATALOG[i].foto = data.url; render() }
        else if (status) status.textContent = 'Error: ' + (data.error || res.status)
      } catch {
        if (status) status.textContent = 'Error de red'
      }
    })

    document.getElementById('pa-add').addEventListener('click', () => {
      CATALOG.push({
        id: `nueva-${Date.now()}`,
        nombre: '',
        banco: '',
        bancoSlug: '',
        predominancia: '',
        tipo: 'hibrida',
        thc: '',
        cbd: '',
        sabores: [],
        efectos: [],
        formatos: ['flor'],
        foto: null,
        activo: false,
      })
      render()
    })

    document.getElementById('pa-save').addEventListener('click', async () => {
      const status = document.getElementById('pa-save-status')
      status.textContent = 'Guardando…'
      CATALOG.forEach((g) => {
        if (!g.id) g.id = slugify(g.nombre) || `genetica-${Date.now()}`
        g.banco = (window.FLORA_BANCOS[g.bancoSlug] || {}).nombre || g.banco || ''
      })
      try {
        const res = await fetch('/api/socios/admin/geneticas', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ geneticas: CATALOG }),
        })
        const data = await res.json()
        status.textContent = res.ok && data.ok ? 'Guardado ✓' : `Error: ${data.error || res.status}`
      } catch {
        status.textContent = 'Error de red al guardar.'
      }
      setTimeout(() => (status.textContent = ''), 4000)
    })

    /* ── Pestañas ── */
    document.querySelectorAll('.pa-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const name = tab.dataset.tab
        document.querySelectorAll('.pa-tab').forEach((t) => t.classList.toggle('is-active', t === tab))
        ;['geneticas', 'pedidos', 'socios'].forEach((n) => {
          const panel = document.getElementById('tab-' + n)
          if (panel) panel.hidden = n !== name
        })
        if (name === 'socios') loadSocios()
        if (name === 'pedidos') loadPedidos()
      })
    })

    /* ── Pedidos ── */
    let PEDIDOS = []
    let pedFilter = 'activos'
    const PED_BADGE = {
      pendiente: ['Pendiente', ''],
      listo: ['Lista para retirar', 'is-on'],
      entregado: ['Entregada', 'is-done'],
      cancelado: ['Cancelada', 'is-off'],
    }
    function pedidoItems(p) {
      return p.items
        .map((i) => `<li>${esc(`${i.cantidad} ${i.formato === 'flor' ? 'g' : 'u'} — ${i.nombre}`)}${i.formato === 'preroll' ? ' <span class="pa-ped-fmt">preroll</span>' : ''}</li>`)
        .join('')
    }
    function pedidoAcciones(p) {
      if (p.estado === 'pendiente') {
        return `<button type="button" class="pa-btn pa-btn-primary pa-btn-slim pa-ped-action" data-id="${esc(p.id)}" data-estado="listo">Marcar lista</button>
                <button type="button" class="pa-btn pa-btn-ghost pa-btn-slim pa-ped-action is-danger" data-id="${esc(p.id)}" data-estado="cancelado">Cancelar</button>`
      }
      if (p.estado === 'listo') {
        return `<button type="button" class="pa-btn pa-btn-primary pa-btn-slim pa-ped-action" data-id="${esc(p.id)}" data-estado="entregado">Marcar entregada</button>
                <button type="button" class="pa-btn pa-btn-ghost pa-btn-slim pa-ped-action is-danger" data-id="${esc(p.id)}" data-estado="cancelado">Cancelar</button>`
      }
      return ''
    }
    function pedidoRow(p) {
      const [label, cls] = PED_BADGE[p.estado] || [p.estado, '']
      return `
        <article class="pa-socio pa-pedido">
          <div class="pa-socio-main">
            <div class="pa-socio-top">
              <strong class="pa-socio-name">${esc(p.name || p.email)}</strong>
              <span class="pa-socio-badge ${cls}">${esc(label)}</span>
              <span class="pa-socio-meta">${esc(fmtFecha(p.creado))}</span>
            </div>
            <div class="pa-socio-email">${esc(p.email)}</div>
            <ul class="pa-ped-items">${pedidoItems(p)}</ul>
            ${p.nota ? `<div class="pa-socio-meta">Nota: ${esc(p.nota)}</div>` : ''}
          </div>
          <div class="pa-ped-actions">${pedidoAcciones(p)}</div>
        </article>`
    }
    function renderPedidos() {
      const list = document.getElementById('pa-pedidos-list')
      const filtered = pedFilter === 'activos'
        ? PEDIDOS.filter((p) => p.estado === 'pendiente' || p.estado === 'listo')
        : PEDIDOS
      const activos = PEDIDOS.filter((p) => p.estado === 'pendiente' || p.estado === 'listo').length
      document.getElementById('pa-ped-count').textContent = `${activos} activa(s) · ${PEDIDOS.length} en total`
      const dot = document.getElementById('pa-ped-dot')
      dot.hidden = activos === 0
      dot.textContent = activos || ''
      list.innerHTML = filtered.length
        ? filtered.map(pedidoRow).join('')
        : `<p class="pa-save-status">${pedFilter === 'activos' ? 'No hay reservas activas.' : 'Todavía no entró ninguna reserva.'}</p>`
    }
    async function loadPedidos() {
      const list = document.getElementById('pa-pedidos-list')
      if (!PEDIDOS.length) list.innerHTML = '<p class="pa-save-status">Cargando…</p>'
      try {
        const res = await fetch('/api/socios/admin/pedidos', { credentials: 'include' })
        const data = await res.json()
        if (!res.ok || !data.ok) { list.innerHTML = `<p class="pa-msg">Error: ${esc(data.error || res.status)}</p>`; return }
        PEDIDOS = data.pedidos || []
        renderPedidos()
      } catch {
        list.innerHTML = '<p class="pa-msg">Error de red al cargar pedidos.</p>'
      }
    }
    document.querySelectorAll('.pa-pedfilter').forEach((b) => b.addEventListener('click', () => {
      document.querySelectorAll('.pa-pedfilter').forEach((x) => x.classList.remove('is-active'))
      b.classList.add('is-active')
      pedFilter = b.dataset.pedfilter
      renderPedidos()
    }))
    document.getElementById('pa-ped-refresh').addEventListener('click', loadPedidos)
    document.addEventListener('click', async (e) => {
      const btn = e.target.closest && e.target.closest('.pa-ped-action')
      if (!btn) return
      const estado = btn.dataset.estado
      if (estado === 'cancelado' && !confirm('¿Cancelar esta reserva?')) return
      btn.disabled = true
      try {
        const res = await fetch('/api/socios/admin/pedidos', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ id: btn.dataset.id, estado }),
        })
        if (res.ok) await loadPedidos()
        else btn.disabled = false
      } catch { btn.disabled = false }
    })

    /* ── Socios ── */
    function fmtFecha(iso) {
      if (!iso) return '—'
      try {
        const d = new Date(iso)
        if (isNaN(d.getTime())) return '—'
        return d.toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric' }) +
          ' ' + d.toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit' })
      } catch { return iso }
    }
    function initials(s) {
      const t = (s || '').trim()
      if (!t) return '?'
      const p = t.split(/\s+/)
      return ((p[0]?.[0] || '') + (p[1]?.[0] || '')).toUpperCase() || '?'
    }
    function socioRow(s) {
      const ava = `<span class="pa-socio-ava"><span class="pa-socio-ini">${esc(initials(s.name || s.email))}</span>${s.picture ? `<img src="${esc(s.picture)}" alt="" referrerpolicy="no-referrer" onerror="this.remove()" />` : ''}</span>`
      const estado = s.lastLogin
        ? '<span class="pa-socio-badge is-on">Ingresó</span>'
        : '<span class="pa-socio-badge">Sin ingresar</span>'
      const meta = s.lastLogin
        ? `Último ingreso: ${fmtFecha(s.lastLogin)} · ${s.logins} ingreso(s)`
        : 'Todavía no ingresó con esta cuenta'
      return `
        <article class="pa-socio">
          ${ava}
          <div class="pa-socio-main">
            <div class="pa-socio-top">
              <strong class="pa-socio-name">${esc(s.name || '(sin nombre aún)')}</strong>
              ${estado}
            </div>
            <div class="pa-socio-email">${esc(s.email)}</div>
            <input class="pa-input pa-socio-nota" data-email="${esc(s.email)}" value="${esc(s.nota)}" placeholder="Nota…" />
            <div class="pa-socio-meta">${meta}</div>
          </div>
          <button type="button" class="pa-socio-del" data-email="${esc(s.email)}" aria-label="Eliminar socio">×</button>
        </article>`
    }
    async function loadSocios() {
      const list = document.getElementById('pa-socios-list')
      list.innerHTML = '<p class="pa-save-status">Cargando…</p>'
      try {
        const res = await fetch('/api/socios/admin/socios', { credentials: 'include' })
        const data = await res.json()
        if (!res.ok || !data.ok) { list.innerHTML = `<p class="pa-msg">Error: ${esc(data.error || res.status)}</p>`; return }
        list.innerHTML = data.socios.length
          ? data.socios.map(socioRow).join('')
          : '<p class="pa-save-status">Todavía no hay socios cargados.</p>'
      } catch {
        list.innerHTML = '<p class="pa-msg">Error de red al cargar socios.</p>'
      }
    }
    async function saveSocio(email, nota) {
      try {
        const res = await fetch('/api/socios/admin/socios', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ email, nota }),
        })
        return res.ok
      } catch {
        return false // sin red: que el caller muestre el error, nunca silencio
      }
    }
    document.getElementById('pa-socio-form').addEventListener('submit', async (e) => {
      e.preventDefault()
      const emailEl = document.getElementById('pa-socio-email')
      const notaEl = document.getElementById('pa-socio-nota')
      const status = document.getElementById('pa-socio-status')
      const email = emailEl.value.trim().toLowerCase()
      if (!email) return
      status.textContent = 'Guardando…'
      const ok = await saveSocio(email, notaEl.value.trim())
      status.textContent = ok ? 'Socio agregado ✓' : 'Error al agregar'
      if (ok) { emailEl.value = ''; notaEl.value = ''; loadSocios() }
      setTimeout(() => (status.textContent = ''), 3000)
    })
    document.addEventListener('change', async (e) => {
      const nota = e.target.closest && e.target.closest('.pa-socio-nota')
      if (!nota) return
      const status = document.getElementById('pa-socio-status')
      status.textContent = 'Guardando nota…'
      const ok = await saveSocio(nota.getAttribute('data-email'), nota.value)
      status.textContent = ok ? 'Nota guardada ✓' : 'Error al guardar la nota — probá de nuevo'
      setTimeout(() => (status.textContent = ''), 3000)
    })
    document.addEventListener('click', async (e) => {
      const del = e.target.closest && e.target.closest('.pa-socio-del')
      if (!del) return
      const email = del.getAttribute('data-email')
      if (!confirm('¿Dar de baja a ' + email + '? No podrá entrar a la carta.')) return
      await fetch('/api/socios/admin/socios', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ email }),
      })
      loadSocios()
    })

    function showLoginError(message) {
      const msg = document.getElementById('pa-login-msg')
      msg.textContent = message
      msg.hidden = false
    }

    async function loadCatalog() {
      const res = await fetch('/api/socios/admin/geneticas', { credentials: 'include' })
      if (res.status === 401) return false
      if (res.status === 403) {
        document.getElementById('pa-login').hidden = true
        document.getElementById('pa-forbidden').hidden = false
        return true
      }
      if (!res.ok) {
        showLoginError(`El servidor respondió ${res.status}. Esperá un momento y recargá.`)
        return true
      }
      const data = await res.json()
      CATALOG = data.geneticas || []
      // La pestaña Socios solo la ve el super admin.
      if (!data.isSuperAdmin) {
        const tabSocios = document.querySelector('.pa-tab[data-tab="socios"]')
        if (tabSocios) tabSocios.hidden = true
      }
      document.getElementById('pa-login').hidden = true
      document.getElementById('pa-content').hidden = false
      render()
      loadPedidos() // completa el contador de pedidos activos en la pestaña
      return true
    }

    window.handleGoogleCredential = async (response) => {
      try {
        const res = await fetch('/api/socios/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ credential: response.credential }),
        })
        const data = await res.json()
        if (!res.ok || !data.ok) {
          showLoginError(data.error || 'No se pudo verificar tu cuenta.')
          return
        }
        await loadCatalog()
      } catch {
        showLoginError('Error de red al verificar con Google.')
      }
    }

    if (googleClientId) {
      window.onload = () => {
        google.accounts.id.initialize({ client_id: googleClientId, callback: window.handleGoogleCredential })
        google.accounts.id.renderButton(document.getElementById('g_id_button'), { theme: 'filled_black', size: 'large', text: 'signin_with' })
      }
    } else {
      showLoginError('Falta configurar el Google Client ID del sitio.')
    }

    loadCatalog().catch(() => showLoginError('No se pudo conectar con el servidor. Recargá la página.'))
  </script>
</Layout>

<style is:global>
  /* ══════════════════════════════════════════════
     PANEL ADMIN — modo nocturno de marca (igual carta)
     Violeta profundo · crema · acentos violeta/verde
  ══════════════════════════════════════════════ */
  .pa-main {
    --pa-bg:     #130d1c;
    --pa-card:   #1c1430;
    --pa-card-2: #251a3d;
    --pa-line:   rgba(244, 241, 247, 0.1);
    --pa-cream:  #f4f1f7;
    --pa-muted:  rgba(244, 241, 247, 0.55);
    --pa-violet: #b79de6;
    --pa-green:  #3cb492;
    --pa-danger: #f2818a;

    min-height: 100svh;
    padding: clamp(24px, 4vw, 56px) clamp(16px, 4vw, 40px);
    background: var(--pa-bg);
    color: var(--pa-cream);
    font-family: var(--font-ui);
    position: relative;
  }
  .pa-main::before {
    content: '';
    position: absolute; inset: 0; pointer-events: none; z-index: 0;
    background:
      radial-gradient(55% 40% at 88% -5%, rgba(56, 31, 86, 0.5), transparent 70%),
      radial-gradient(50% 35% at 0% 100%, rgba(10, 80, 60, 0.14), transparent 70%);
  }
  html, body { background-color: #130d1c; }
  /* El grano cinematográfico global (body::after: capa fixed full-viewport con
     mix-blend-mode + feTurbulence) dispara un bug del compositor de Chrome en
     desktop que pinta TODA la pantalla de negro al repintar (pestaña Socios).
     En un panel de datos no aporta: fuera. */
  body::after { display: none !important; }

  .pa-wrap { position: relative; z-index: 1; max-width: 1460px; margin: 0 auto; }

  .pa-eyebrow {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--pa-muted); font-weight: 700; margin-bottom: 0.6rem;
  }
  .pa-eyebrow::before {
    content: ''; width: 7px; height: 7px; border-radius: 50%;
    background: var(--pa-violet);
  }
  .pa-title {
    font-family: var(--font-display); font-weight: 400;
    font-size: clamp(2rem, 5vw, 3.2rem); line-height: 1; letter-spacing: 0.005em;
    color: var(--pa-cream); margin: 0 0 1.8rem;
  }

  .pa-login[hidden], .pa-content[hidden] { display: none; }
  .pa-login {
    display: flex; flex-direction: column; align-items: flex-start; gap: 1rem;
    background: var(--pa-card); border: 1px solid var(--pa-line);
    border-radius: 20px; padding: clamp(24px, 4vw, 40px); max-width: 460px;
    box-shadow: 0 24px 60px -30px rgba(0, 0, 0, 0.7);
  }
  .pa-msg {
    color: var(--pa-danger); font-size: 0.9rem;
    background: rgba(242, 129, 138, 0.08); border: 1px solid rgba(242, 129, 138, 0.2);
    padding: 0.9rem 1.1rem; border-radius: 12px;
  }
  .pa-help {
    background: rgba(244, 241, 247, 0.04); border: 1px solid var(--pa-line); border-radius: 14px;
    padding: 0.95rem 1.15rem; font-size: 0.88rem; line-height: 1.55; color: var(--pa-muted);
    margin-bottom: 1.4rem;
  }
  .pa-help strong { color: var(--pa-cream); font-weight: 700; }

  /* ── Inputs ── */
  input[type="checkbox"] { accent-color: var(--pa-violet); }
  .pa-input, select.pa-input, .pa-field select, .pa-field input {
    width: 100%; font-family: var(--font-ui); font-size: 0.88rem;
    border: 1px solid var(--pa-line); border-radius: 10px; padding: 0.5rem 0.7rem;
    color: var(--pa-cream); background: var(--pa-card-2);
  }
  .pa-input::placeholder { color: rgba(244, 241, 247, 0.3); }
  .pa-input:focus, .pa-field select:focus, .pa-field input:focus { outline: none; border-color: var(--pa-violet); }
  .pa-field select option { background: var(--pa-card-2); color: var(--pa-cream); }

  /* ── Genéticas: cards ── */
  .pa-list { display: flex; flex-direction: column; gap: 1rem; }
  .pa-card {
    background: var(--pa-card); border: 1px solid var(--pa-line);
    border-radius: 18px; padding: 1.2rem 1.3rem;
  }
  .pa-card-top { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1rem; }
  .pa-input-nombre {
    flex: 1; font-family: var(--font-display); font-weight: 500; font-size: 1.35rem;
    background: none; border: none; border-bottom: 1px solid var(--pa-line); border-radius: 0;
    padding: 0.3rem 0.1rem; color: var(--pa-cream);
  }
  .pa-input-nombre:focus { border-bottom-color: var(--pa-violet); }
  .pa-activo {
    display: flex; align-items: center; gap: 0.45rem; font-size: 0.8rem; white-space: nowrap;
    color: var(--pa-muted);
  }
  .pa-del {
    background: none; border: 1px solid var(--pa-line); border-radius: 9px;
    width: 32px; height: 32px; font-size: 1.15rem; line-height: 1; cursor: pointer;
    color: var(--pa-danger); flex-shrink: 0; transition: border-color 0.15s ease;
  }
  .pa-del:hover { border-color: var(--pa-danger); }

  .pa-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 0.8rem; margin-bottom: 1rem; }
  .pa-field { display: flex; flex-direction: column; gap: 0.3rem; }
  .pa-field > span {
    font-size: 0.66rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--pa-violet);
  }
  .pa-field-wide { grid-column: 1 / -1; }

  /* ── Formato ── */
  .pa-formatos { display: flex; align-items: center; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 1rem; }
  .pa-formatos-label {
    font-size: 0.66rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--pa-muted);
  }
  .pa-fmt {
    display: inline-flex; align-items: center; gap: 0.45rem; font-size: 0.82rem; font-weight: 600;
    border: 1px solid var(--pa-line); border-radius: 999px;
    padding: 0.35rem 0.85rem; cursor: pointer; color: var(--pa-muted);
  }
  .pa-fmt.is-on { color: var(--pa-cream); background: rgba(60, 180, 146, 0.14); border-color: var(--pa-green); }
  .pa-fmt input { margin: 0; }

  /* ── Sabor / efecto ── */
  .pa-tags-block { margin-top: 0.8rem; }
  .pa-tags-label {
    display: block; font-size: 0.66rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
