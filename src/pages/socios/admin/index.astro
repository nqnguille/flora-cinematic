---
import Layout from '../../../layouts/Layout.astro'
import '../../../styles/global.css'

const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || ''
---

<Layout
  title="Panel del club — admin | Flora ONG"
  description="Back-office interno del club: genéticas, productos, reservas y socios."
  noindex={true}
>
  <main class="pa-main">
    <div class="pa-wrap">
      <div class="pa-head">
        <div>
          <span class="pa-eyebrow">Flora · Panel del club</span>
          <h1 class="pa-title">Panel del club</h1>
        </div>
        <div id="pa-quien" class="pa-quien" hidden>
          <span id="pa-quien-ini" class="pa-quien-ini"></span>
          <span id="pa-quien-mail" class="pa-quien-mail"></span>
          <button id="pa-logout" class="pa-logout" type="button">Salir</button>
        </div>
      </div>

      <div id="pa-login" class="pa-login">
        <div id="g_id_button"></div>
        <p id="pa-login-msg" class="pa-msg" hidden></p>
      </div>

      <div id="pa-forbidden" class="pa-msg" hidden>
        Tu cuenta de Google inició sesión pero no tiene permisos de administrador.
      </div>

      <div id="pa-content" class="pa-content" hidden>
        <!-- Franja resumen: contexto de un vistazo, cada chip navega a su pestaña -->
        <div id="pa-stats" class="pa-stats"></div>

        <div class="pa-tabs" role="tablist">
          <button class="pa-tab" data-tab="pedidos" type="button"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 7h12l1.2 13a1 1 0 0 1-1 1H5.8a1 1 0 0 1-1-1L6 7Z"/><path d="M9 10V6a3 3 0 0 1 6 0v4"/></svg>Reservas<span id="pa-ped-dot" class="pa-ped-dot" hidden></span></button>
          <button class="pa-tab" data-tab="geneticas" type="button"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3c2.8 2.4 4.8 5.4 4.8 8.8A4.8 4.8 0 0 1 7.2 11.8C7.2 8.4 9.2 5.4 12 3Z"/><path d="M12 16.6V21"/></svg>Genéticas</button>
          <button class="pa-tab" data-tab="productos" type="button"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3.5 8.5 12 4l8.5 4.5v7L12 20l-8.5-4.5v-7Z"/><path d="M12 12v8M3.5 8.5 12 12l8.5-3.5"/></svg>Productos<span id="pa-prod-dot" class="pa-ped-dot is-warn" hidden></span></button>
          <button class="pa-tab" data-tab="socios" type="button"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"/><path d="M3.5 19c.6-3 2.8-4.6 5.5-4.6S13.9 16 14.5 19"/><circle cx="16.5" cy="9.5" r="2.6"/><path d="M16 14.6c2.4.1 4 1.6 4.5 4.1"/></svg>Socios</button>
        </div>

        <!-- ── Pestaña Genéticas ── -->
        <div id="tab-geneticas" class="pa-tab-panel">
          <div class="pa-toolbar">
            <div class="pa-availfilter" role="group" aria-label="Filtrar por disponibilidad">
              <button class="pa-avail is-active" data-avail="" type="button">Todas</button>
              <button class="pa-avail" data-avail="on" type="button">Disponibles</button>
              <button class="pa-avail" data-avail="off" type="button">No disponibles</button>
            </div>
            <input id="pa-search" class="pa-input pa-search" type="search" placeholder="Buscar por nombre…" autocomplete="off" />
            <span id="pa-count" class="pa-count"></span>
          </div>

          <div class="pa-genscroll">
            <div class="pa-rows-head">
              <span>Disp.</span><span>Nombre</span><span>Banco</span><span>Tipo</span>
              <span>Predominancia</span><span>THC</span><span>CBD</span>
              <span>Formato</span><span>Sabores</span><span>Efectos</span><span>Foto</span><span></span>
            </div>
            <div id="pa-list" class="pa-rows"></div>
          </div>
          <button id="pa-add" type="button" class="pa-btn pa-btn-ghost">+ Agregar genética</button>

          <div class="pa-savebar">
            <span id="pa-save-status" class="pa-save-status"></span>
            <button id="pa-save" type="button" class="pa-btn pa-btn-primary">Guardar cambios</button>
          </div>
        </div>

        <!-- ── Pestaña Reservas ── -->
        <div id="tab-pedidos" class="pa-tab-panel" hidden>
          <div class="pa-toolbar">
            <div class="pa-availfilter" role="group" aria-label="Filtrar reservas">
              <button class="pa-pedfilter pa-avail is-active" data-pedfilter="activos" type="button">Activas</button>
              <button class="pa-pedfilter pa-avail" data-pedfilter="" type="button">Todas</button>
            </div>
            <button id="pa-ped-refresh" type="button" class="pa-btn pa-btn-ghost pa-btn-slim">↻ Actualizar</button>
            <span id="pa-ped-count" class="pa-count"></span>
            <span id="pa-ped-status" class="pa-save-status"></span>
          </div>
          <div id="pa-ped-top" class="pa-ped-top" hidden></div>
          <div id="pa-pedidos-list" class="pa-socios-list"></div>
        </div>

        <!-- ── Pestaña Productos ── -->
        <div id="tab-productos" class="pa-tab-panel" hidden>
          <p class="pa-help">
            Precios y fotos de los productos que ven los socios (aceites, cremas, cartuchos y baterías).
            Los cambios se aplican al tocar <strong>Guardar productos</strong>.
          </p>
          <div id="pa-prods-wrap"></div>
          <div class="pa-savebar">
            <span id="pa-prod-status" class="pa-save-status"></span>
            <button id="pa-prod-save" type="button" class="pa-btn pa-btn-primary">Guardar productos</button>
          </div>
        </div>

        <!-- ── Pestaña Socios ── -->
        <div id="tab-socios" class="pa-tab-panel" hidden>
          <p class="pa-help">
            Cargá el <strong>email de la cuenta de Google</strong> con la que el socio va a entrar, y opcionalmente
            una nota para reconocerlo. Apenas ingrese, su ficha se completa sola con el nombre y la foto de Google.
          </p>
          <form id="pa-socio-form" class="pa-socio-form">
            <input id="pa-socio-email" type="email" class="pa-input" placeholder="email@gmail.com" autocomplete="off" required />
            <input id="pa-socio-nota" type="text" class="pa-input" placeholder="Nota (ej. Gastón — WhatsApp)" autocomplete="off" />
            <button type="submit" class="pa-btn pa-btn-primary">Agregar socio</button>
          </form>

          <!-- ── Intentos de acceso: gmails que probaron entrar a la carta y no son socios ── -->
          <div id="pa-intentos-block" class="pa-intentos-block" hidden>
            <div class="pa-intentos-head">
              <h2 class="pa-subhead">Intentos de acceso <span id="pa-intentos-count" class="pa-count-badge"></span></h2>
              <p class="pa-help">Cuentas de Google que probaron entrar a la carta y todavía no son socios — posibles leads para invitar.</p>
            </div>
            <div id="pa-intentos-list" class="pa-socios-list pa-intentos-list"></div>
          </div>

          <div id="pa-socio-stats" class="pa-stats pa-stats-sub"></div>
          <div class="pa-toolbar">
            <div id="pa-socio-sort" class="pa-availfilter" role="group" aria-label="Ordenar socios">
              <button class="pa-avail is-active" data-sort="lastLogin" type="button">Último ingreso</button>
              <button class="pa-avail" data-sort="name" type="button">Nombre</button>
              <button class="pa-avail" data-sort="logins" type="button">Ingresos</button>
              <button class="pa-avail" data-sort="alta" type="button">Alta</button>
              <button class="pa-avail" data-sort="sin" type="button">Sin ingresar</button>
            </div>
            <input id="pa-socio-buscar" class="pa-input pa-search" type="search" placeholder="Buscar socio…" autocomplete="off" />
          </div>
          <p id="pa-socio-status" class="pa-save-status"></p>
          <div id="pa-socios-list" class="pa-socios-list"></div>
        </div>
      </div>
    </div>

    <!-- Confirmación de marca (reemplaza el confirm() nativo) -->
    <div id="pa-confirm" class="pa-confirm" hidden>
      <div class="pa-confirm-card" role="alertdialog" aria-modal="true" aria-labelledby="pa-confirm-txt">
        <h2 id="pa-confirm-txt" class="pa-confirm-txt"></h2>
        <div class="pa-confirm-actions">
          <button id="pa-confirm-no" class="pa-btn pa-btn-ghost" type="button">Volver</button>
          <button id="pa-confirm-si" class="pa-btn pa-btn-danger" type="button">Confirmar</button>
        </div>
      </div>
    </div>
  </main>

  <script src="https://accounts.google.com/gsi/client" async defer is:inline></script>
  <script src="/socios/icons.js" is:inline></script>
  <script src="/socios/bancos.js" is:inline></script>
  <script define:vars={{ googleClientId }}>
    // Cazador de errores: cualquier excepción no capturada se muestra en un
    // cartel visible en vez de dejar la página muda/negra. Diagnóstico > silencio.
    function showFatal(msg) {
      let el = document.getElementById('pa-fatal')
      if (!el) {
        el = document.createElement('div')
        el.id = 'pa-fatal'
        el.style.cssText = 'position:fixed;top:0;left:0;right:0;z-index:9999;background:#7a1f2b;color:#fff;font:600 13px/1.5 system-ui;padding:10px 16px;white-space:pre-wrap;word-break:break-word'
        document.body.appendChild(el)
      }
      el.textContent = '⚠ Error del panel (sacale captura y pasásela a Claude): ' + msg
    }
    window.addEventListener('error', (e) => showFatal((e.message || 'error') + (e.filename ? ` @ ${e.filename.split('/').pop()}:${e.lineno}` : '')))
    window.addEventListener('unhandledrejection', (e) => showFatal('promesa rechazada: ' + (e.reason?.message || e.reason)))

    let CATALOG = []
    let CATALOG_VERSION = 0 // control de concurrencia: ver comentario en geneticas.ts

    // ── Confirmación de marca (promesa): reemplaza el confirm() nativo ──
    let confirmResolve = null
    function paConfirm(texto) {
      return new Promise((resolve) => {
        confirmResolve = resolve
        document.getElementById('pa-confirm-txt').textContent = texto
        document.getElementById('pa-confirm').hidden = false
        document.getElementById('pa-confirm-no').focus()
      })
    }
    document.getElementById('pa-confirm').addEventListener('click', (e) => {
      if (e.target.id === 'pa-confirm-si') { document.getElementById('pa-confirm').hidden = true; confirmResolve?.(true) }
      else if (e.target.id === 'pa-confirm-no' || e.target.id === 'pa-confirm') { document.getElementById('pa-confirm').hidden = true; confirmResolve?.(false) }
    })

    // ── Cambios sin guardar (genéticas + productos) ──
    let genDirty = 0
    let prodDirty = 0
    function marcarDirty(cual) {
      if (cual === 'gen') genDirty++
      else prodDirty++
      pintarPendientes()
    }
    function pintarPendientes() {
      const g = document.getElementById('pa-save-status')
      if (g && genDirty && !g.textContent) g.textContent = `${genDirty} cambio(s) sin guardar`
      const p = document.getElementById('pa-prod-status')
      if (p && prodDirty && !p.textContent) p.textContent = `${prodDirty} cambio(s) sin guardar`
    }
    window.addEventListener('beforeunload', (e) => {
      if (genDirty || prodDirty) { e.preventDefault(); e.returnValue = '' }
    })

    function esc(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]))
    }

    function tipoLabel(t) { return t === 'hibrida' ? 'Híbrida' : t === 'cbd' ? 'Full CBD' : t[0].toUpperCase() + t.slice(1) }

    function bancoOptionsHtml(current) {
      const bancos = window.FLORA_BANCOS
      return Object.entries(bancos)
        .map(([slug, b]) => `<option value="${slug}" ${slug === current ? 'selected' : ''}>${esc(b.nombre)}</option>`)
        .join('') + `<option value="" ${!(current in bancos) ? 'selected' : ''}>Otro</option>`
    }

    // ── Desplegable tildable (formato / sabor / efecto) ──
    const DD_LABEL = { formato: 'Formato', sabor: 'Sabores', efecto: 'Efectos' }
    function ddOptions(dim) {
      if (dim === 'formato') return [['flor', 'Flor a granel', ''], ['preroll', 'Preroll 1g', '']]
      const cat = window.FLORA_TAG_ICONS[dim] || {}
      return Object.entries(cat).map(([k, def]) => [k, def.label, def.svg])
    }
    function ddHtml(dim, idx, selected) {
      const sel = selected || []
      const opts = ddOptions(dim).map(([val, lab, icon]) => {
        const on = sel.includes(val)
        return `<label class="pa-ddopt ${on ? 'is-on' : ''}"><input type="checkbox" data-dd="${dim}" data-idx="${idx}" value="${esc(val)}" ${on ? 'checked' : ''} />${icon ? `<span class="pa-ddicon">${icon}</span>` : ''}<span>${esc(lab)}</span></label>`
      }).join('')
      const n = sel.length
      return `<div class="pa-dd" data-ddwrap="${dim}-${idx}">
        <button type="button" class="pa-dd-toggle ${n ? 'has' : ''}"><span class="pa-dd-txt">${DD_LABEL[dim]}${n ? ` · ${n}` : ''}</span><svg class="pa-dd-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button>
        <div class="pa-dd-panel" hidden>${opts}</div>
      </div>`
    }
    function updateDd(i, dim) {
      const wrap = document.querySelector(`[data-ddwrap="${dim}-${i}"]`)
      if (!wrap) return
      const key = dim === 'formato' ? 'formatos' : dim === 'sabor' ? 'sabores' : 'efectos'
      const sel = CATALOG[i][key] || []
      wrap.querySelector('.pa-dd-txt').textContent = DD_LABEL[dim] + (sel.length ? ` · ${sel.length}` : '')
      wrap.querySelector('.pa-dd-toggle').classList.toggle('has', sel.length > 0)
      wrap.querySelectorAll('.pa-ddopt').forEach((opt) => opt.classList.toggle('is-on', opt.querySelector('input').checked))
    }

    function rowHtml(g, idx) {
      const fotoSrc = g.foto || (g.id ? `/socios/geneticas/${g.id}.webp` : '')
      return `
      <div class="pa-row" data-idx="${idx}">
        <label class="pa-avail-toggle" title="Disponible en la carta">
          <input type="checkbox" data-field="activo" data-idx="${idx}" ${g.activo ? 'checked' : ''} />
        </label>
        <input class="pa-input" data-field="nombre" data-idx="${idx}" value="${esc(g.nombre)}" placeholder="Nombre" />
        <select class="pa-input" data-field="bancoSlug" data-idx="${idx}">${bancoOptionsHtml(g.bancoSlug)}</select>
        <select class="pa-input" data-field="tipo" data-idx="${idx}">${['sativa', 'indica', 'hibrida', 'cbd'].map((t) => `<option value="${t}" ${g.tipo === t ? 'selected' : ''}>${tipoLabel(t)}</option>`).join('')}</select>
        <input class="pa-input" data-field="predominancia" data-idx="${idx}" value="${esc(g.predominancia)}" placeholder="70% S | 30% I" />
        <input class="pa-input pa-cell-num" data-field="thc" data-idx="${idx}" value="${esc(g.thc)}" placeholder="THC" />
        <input class="pa-input pa-cell-num" data-field="cbd" data-idx="${idx}" value="${esc(g.cbd)}" placeholder="CBD" />
        ${ddHtml('formato', idx, g.formatos && g.formatos.length ? g.formatos : ['flor'])}
        ${ddHtml('sabor', idx, g.sabores || [])}
        ${ddHtml('efecto', idx, g.efectos || [])}
        <div class="pa-foto">
          <div class="pa-foto-thumb">${fotoSrc ? `<img src="${esc(fotoSrc)}" alt="" onerror="this.remove()" />` : ''}</div>
          <input type="file" accept="image/jpeg,image/png,image/webp" id="pa-foto-${idx}" class="pa-foto-input" data-foto-idx="${idx}" hidden />
          <label for="pa-foto-${idx}" class="pa-foto-btn" title="Subir imagen">📷</label>
          <span class="pa-foto-status" data-fotostatus-idx="${idx}"></span>
        </div>
        <button type="button" class="pa-del" data-idx="${idx}" aria-label="Eliminar">×</button>
      </div>`
    }

    let availFilter = ''
    let searchQ = ''
    function updateCount() {
      const disp = CATALOG.filter((g) => g.activo).length
      const el = document.getElementById('pa-count')
      if (el) el.textContent = `${disp} disponible(s) · ${CATALOG.length} en total`
    }
    function render() {
      const q = searchQ.toLowerCase()
      const html = CATALOG.map((g, i) => {
        if (availFilter === 'on' && !g.activo) return ''
        if (availFilter === 'off' && g.activo) return ''
        if (q && !String(g.nombre || '').toLowerCase().includes(q)) return ''
        return rowHtml(g, i)
      }).join('')
      document.getElementById('pa-list').innerHTML = html || '<p class="pa-empty">Ninguna genética coincide con el filtro.</p>'
      updateCount()
    }

    function slugify(s) {
      return String(s).toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '')
    }

    let statusTimer = null
    function flashStatus(msg) {
      const el = document.getElementById('pa-save-status')
      el.textContent = msg
      clearTimeout(statusTimer)
      statusTimer = setTimeout(() => (el.textContent = ''), 3000)
    }
    async function autoSaveActivo(i) {
      const g = CATALOG[i]
      if (!g.id || String(g.id).startsWith('nueva-')) { flashStatus('Guardá para aplicar la disponibilidad'); return }
      try {
        const res = await fetch('/api/socios/admin/geneticas', {
          method: 'PATCH', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
          body: JSON.stringify({ id: g.id, activo: g.activo }),
        })
        const data = await res.json().catch(() => ({}))
        if (res.ok && data.version) CATALOG_VERSION = data.version
        flashStatus(res.ok ? 'Disponibilidad guardada ✓' : 'Error al guardar')
      } catch { flashStatus('Error de red') }
    }

    // Filtros del panel (disponibilidad + buscador) — scopeados a SU pestaña:
    // los botones de Reservas también llevan .pa-avail y se pisaban con estos.
    document.querySelectorAll('#tab-geneticas .pa-avail').forEach((b) => b.addEventListener('click', () => {
      document.querySelectorAll('#tab-geneticas .pa-avail').forEach((x) => x.classList.remove('is-active'))
      b.classList.add('is-active'); availFilter = b.dataset.avail; render()
    }))
    document.getElementById('pa-search').addEventListener('input', (e) => { searchQ = e.target.value.trim(); render() })

    // Edición de campos + dropdowns + toggle disponible (autoguardado)
    document.addEventListener('input', (e) => {
      const t = e.target
      const idx = t.getAttribute('data-idx')
      if (idx === null) return
      const i = Number(idx)
      const field = t.getAttribute('data-field')
      const dd = t.getAttribute('data-dd')

      if (dd) {
        const key = dd === 'formato' ? 'formatos' : dd === 'sabor' ? 'sabores' : 'efectos'
        const max = dd === 'formato' ? 99 : 2
        let arr = Array.isArray(CATALOG[i][key]) ? [...CATALOG[i][key]] : []
        if (t.checked) {
          if (arr.length >= max) { t.checked = false; return }
          if (!arr.includes(t.value)) arr.push(t.value)
        } else {
          arr = arr.filter((v) => v !== t.value)
        }
        CATALOG[i][key] = arr
        // efectoTexto/saborTexto son texto libre heredado del import de Excel,
        // sin ningún campo acá para editarlo — pero la carta lo usa como
        // etiqueta en vez del tag si la cantidad de "segmentos" (separados
        // por | o ·) coincide con la cantidad de tags tildados. Sin este
        // clear, tildar/destildar puede hacer que ese texto viejo "reaparezca"
        // por coincidencia de cantidad, dando la falsa sensación de que la
        // carta no actualiza los cambios de acá.
        if (dd === 'sabor') CATALOG[i].saborTexto = ''
        if (dd === 'efecto') CATALOG[i].efectoTexto = ''
        updateDd(i, dd)
        marcarDirty('gen')
      } else if (field === 'activo') {
        CATALOG[i].activo = t.checked
        autoSaveActivo(i)
        updateCount()
        pintarStats()
        if (availFilter) render()
      } else if (field) {
        CATALOG[i][field] = t.value
        marcarDirty('gen')
      }
    })

    // Abrir/cerrar los desplegables tildables
    document.addEventListener('click', (e) => {
      const tgl = e.target.closest('.pa-dd-toggle')
      const panels = document.querySelectorAll('.pa-dd-panel')
      if (tgl) {
        const panel = tgl.nextElementSibling
        const willOpen = panel.hidden
        panels.forEach((p) => { if (p !== panel) { p.hidden = true; p.previousElementSibling.classList.remove('open') } })
        panel.hidden = !willOpen
        tgl.classList.toggle('open', willOpen)
        return
      }
      if (!e.target.closest('.pa-dd-panel')) panels.forEach((p) => { p.hidden = true; p.previousElementSibling.classList.remove('open') })
    })

    document.addEventListener('click', (e) => {
      const del = e.target.closest('.pa-del')
      if (del && del.hasAttribute('data-idx')) {
        CATALOG.splice(Number(del.getAttribute('data-idx')), 1)
        render()
        marcarDirty('gen')
        return
      }
      const clr = e.target.closest('.pa-foto-clear')
      if (clr) {
        CATALOG[Number(clr.getAttribute('data-fotoclear-idx'))].foto = null
        render()
        marcarDirty('gen')
      }
    })

    // Subida de foto: sube el archivo a KV y guarda la URL en la genética.
    document.addEventListener('change', async (e) => {
      const inp = e.target
      if (!inp.classList || !inp.classList.contains('pa-foto-input')) return
      const i = Number(inp.getAttribute('data-foto-idx'))
      const file = inp.files && inp.files[0]
      if (!file) return
      const status = document.querySelector(`[data-fotostatus-idx="${i}"]`)
      if (status) status.textContent = 'Subiendo…'
      const fd = new FormData()
      fd.append('id', CATALOG[i].id || slugify(CATALOG[i].nombre) || 'foto')
      fd.append('file', file)
      try {
        const res = await fetch('/api/socios/admin/foto', { method: 'POST', credentials: 'include', body: fd })
        const data = await res.json()
        if (res.ok && data.ok) { CATALOG[i].foto = data.url; render() }
        else if (status) status.textContent = 'Error: ' + (data.error || res.status)
      } catch {
        if (status) status.textContent = 'Error de red'
      }
    })

    document.getElementById('pa-add').addEventListener('click', () => {
      marcarDirty('gen')
      CATALOG.push({
        id: `nueva-${Date.now()}`,
        nombre: '',
        banco: '',
        bancoSlug: '',
        predominancia: '',
        tipo: 'hibrida',
        thc: '',
        cbd: '',
        sabores: [],
        efectos: [],
        formatos: ['flor'],
        foto: null,
        activo: false,
      })
      render()
    })

    document.getElementById('pa-save').addEventListener('click', async () => {
      const btn = document.getElementById('pa-save')
      const status = document.getElementById('pa-save-status')
      status.classList.remove('is-ok', 'is-err')
      status.textContent = 'Guardando…'
      btn.disabled = true
      CATALOG.forEach((g) => {
        if (!g.id) g.id = slugify(g.nombre) || `genetica-${Date.now()}`
        g.banco = (window.FLORA_BANCOS[g.bancoSlug] || {}).nombre || g.banco || ''
      })
      try {
        const res = await fetch('/api/socios/admin/geneticas', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ geneticas: CATALOG, version: CATALOG_VERSION }),
        })
        const data = await res.json()
        if (res.ok && data.ok) {
          genDirty = 0; CATALOG_VERSION = data.version || CATALOG_VERSION
          status.classList.add('is-ok'); status.textContent = 'Guardado ✓'
        } else if (res.status === 409 && data.conflict) {
          // Alguien más guardó desde que esta pantalla cargó — no pisamos:
          // traemos la versión del servidor y avisamos en vez de sobrescribir
          // en silencio. Las ediciones sin guardar de esta pantalla se pierden
          // (mejor eso que perder las del otro admin sin que nadie se entere).
          CATALOG = data.geneticas || CATALOG
          CATALOG_VERSION = data.version || CATALOG_VERSION
          render()
          status.classList.add('is-err')
          status.textContent = data.error || 'Alguien más guardó cambios — se recargó la versión más reciente, revisá tus ediciones.'
        } else {
          status.classList.add('is-err')
          status.textContent = `Error: ${data.error || res.status}`
        }
      } catch {
        status.classList.add('is-err')
        status.textContent = 'Error de red al guardar.'
      }
      btn.disabled = false
      setTimeout(() => { status.textContent = ''; status.classList.remove('is-ok', 'is-err'); pintarPendientes() }, 4000)
    })

    /* ── Productos: precios y fotos (KV precios) ── */
    let PRECIOS = { aceites: [], cremas: [], extracciones: [] }
    let PRECIOS_ORIG = {} // para detectar saltos de precio >50% al guardar
    const CAT_LABEL = { aceites: 'Aceites', cremas: 'Cremas', extracciones: 'Extracciones · cartuchos y baterías' }
    const CAT_ICON = {
      aceites: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 3h5M10 3v3.2L7.2 10a5.5 5.5 0 1 0 9.6 0L14 6.2V3"/><path d="M8.4 14.5h7.2"/></svg>',
      cremas: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5.5" y="8.5" width="13" height="12" rx="3"/><path d="M8 8.5V6.8A1.8 1.8 0 0 1 9.8 5h4.4A1.8 1.8 0 0 1 16 6.8v1.7"/></svg>',
      extracciones: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10.2 21.4 9.1 7Q9 5.9 9.9 5.5L14.1 5.5Q15 5.9 14.9 7L13.8 21.4Q13.7 22.3 12 22.3Q10.3 22.3 10.2 21.4Z"/><path d="M10.5 18.5h3"/></svg>',
    }
    const fmtARS = (n) => Number(n || 0).toLocaleString('es-AR')

    function prodCard(cat, it, idx) {
      return `
        <div class="pa-prod" data-cat="${cat}" data-pidx="${idx}">
          <div class="pa-prod-foto">
            ${it.foto ? `<img src="${esc(it.foto)}" alt="" onerror="this.remove()" />` : `<span class="pa-prod-fotoph">${CAT_ICON[cat]}</span>`}
            <input type="file" accept="image/jpeg,image/png,image/webp" id="pa-pfoto-${cat}-${idx}" class="pa-prod-fotoinput" data-cat="${cat}" data-pidx="${idx}" hidden />
            <label for="pa-pfoto-${cat}-${idx}" class="pa-prod-fotobtn" title="Subir foto">📷</label>
          </div>
          <div class="pa-prod-main">
            <input class="pa-input pa-prod-label" data-pfield="label" data-cat="${cat}" data-pidx="${idx}" value="${esc(it.label)}" placeholder="Nombre" />
            <input class="pa-input pa-prod-detalle" data-pfield="detalle" data-cat="${cat}" data-pidx="${idx}" value="${esc(it.detalle)}" placeholder="Detalle (ej. THC · 0,5 ml)" />
            <div class="pa-precio">
              <span class="pa-precio-sym">$</span>
              <input class="pa-input pa-precio-input" inputmode="numeric" data-pfield="precio" data-cat="${cat}" data-pidx="${idx}" value="${it.precio || ''}" placeholder="0" />
              <span class="pa-precio-fmt">$ ${fmtARS(it.precio)}</span>
            </div>
          </div>
          <button type="button" class="pa-del pa-prod-del" data-cat="${cat}" data-pidx="${idx}" aria-label="Eliminar producto">×</button>
        </div>`
    }

    function renderProductos() {
      const wrap = document.getElementById('pa-prods-wrap')
      wrap.innerHTML = Object.keys(CAT_LABEL).map((cat) => {
        const items = PRECIOS[cat] || []
        const cards = items.map((it, i) => prodCard(cat, it, i)).join('')
        return `
          <section class="pa-cat">
            <div class="pa-cat-head">
              <h2 class="pa-cat-title">${CAT_LABEL[cat]}</h2>
              <span class="pa-count">${items.length} producto(s)</span>
              <button type="button" class="pa-btn pa-btn-ghost pa-btn-slim pa-prod-add" data-cat="${cat}">+ Agregar</button>
            </div>
            ${cards
              ? `<div class="pa-prods">${cards}</div>`
              : `<p class="pa-empty">Sin productos en esta categoría todavía.</p>`}
          </section>`
      }).join('')
      pintarProdDot()
    }

    function pintarProdDot() {
      const sinPrecio = Object.values(PRECIOS).flat().filter((it) => !Number(it.precio)).length
      const dot = document.getElementById('pa-prod-dot')
      dot.hidden = sinPrecio === 0
      dot.textContent = sinPrecio || ''
      dot.title = sinPrecio ? `${sinPrecio} producto(s) sin precio` : ''
    }

    // Edición de campos de producto (delegado)
    document.addEventListener('input', (e) => {
      const t = e.target
      const pf = t.getAttribute && t.getAttribute('data-pfield')
      if (!pf) return
      const it = (PRECIOS[t.getAttribute('data-cat')] || [])[Number(t.getAttribute('data-pidx'))]
      if (!it) return
      if (pf === 'precio') {
        const digits = t.value.replace(/[^\d]/g, '')
        if (t.value !== digits) t.value = digits
        it.precio = Number(digits || 0)
        const fmt = t.closest('.pa-precio').querySelector('.pa-precio-fmt')
        fmt.textContent = `$ ${fmtARS(it.precio)}`
      } else {
        it[pf] = t.value
      }
      marcarDirty('prod')
      if (pf === 'precio') pintarProdDot()
    })

    document.addEventListener('click', async (e) => {
      const add = e.target.closest('.pa-prod-add')
      if (add) {
        const cat = add.getAttribute('data-cat')
        // Las páginas de Aceites/Cremas/Extracciones muestran una lista fija
        // (foto, ficha técnica, análisis de laboratorio si aplica) que vive
        // en el código, no acá — un producto realmente nuevo necesita que un
        // desarrollador lo sume a esa página. Lo que se guarda acá queda en
        // la base de datos pero NO aparece solo en el sitio.
        if (!(await paConfirm('Un producto nuevo acá queda guardado, pero no va a aparecer solo en la página pública — hace falta que alguien sume la foto y la ficha en el código. Si es para eso (por ejemplo, dejar el precio ya cargado para cuando se agregue), seguí. Si buscás algo que ya está en el sitio, cancelá y buscalo en la lista de abajo.'))) return
        PRECIOS[cat] = PRECIOS[cat] || []
        PRECIOS[cat].push({ id: `nuevo-${Date.now().toString(36)}`, label: '', detalle: '', precio: 0 })
        renderProductos()
        marcarDirty('prod')
        return
      }
      const del = e.target.closest('.pa-prod-del')
      if (del) {
        const cat = del.getAttribute('data-cat')
        const it = PRECIOS[cat][Number(del.getAttribute('data-pidx'))]
        if (!(await paConfirm(`¿Eliminar "${it.label || 'este producto'}" de ${CAT_LABEL[cat]}? Deja de verse en la tienda al guardar.`))) return
        PRECIOS[cat].splice(Number(del.getAttribute('data-pidx')), 1)
        renderProductos()
        marcarDirty('prod')
      }
    })

    // Subida de foto de producto → KV FOTOS → URL /foto/<key>
    document.addEventListener('change', async (e) => {
      const inp = e.target
      if (!inp.classList || !inp.classList.contains('pa-prod-fotoinput')) return
      const cat = inp.getAttribute('data-cat')
      const idx = Number(inp.getAttribute('data-pidx'))
      const it = (PRECIOS[cat] || [])[idx]
      const file = inp.files && inp.files[0]
      if (!it || !file) return
      const status = document.getElementById('pa-prod-status')
      status.textContent = 'Subiendo foto…'
      const fd = new FormData()
      fd.append('id', `producto-${it.id || slugify(it.label) || 'item'}`)
      fd.append('file', file)
      try {
        const res = await fetch('/api/socios/admin/foto', { method: 'POST', credentials: 'include', body: fd })
        const data = await res.json()
        if (res.ok && data.ok) { it.foto = data.url; renderProductos(); marcarDirty('prod'); status.textContent = 'Foto subida ✓' }
        else status.textContent = 'Error al subir: ' + (data.error || res.status)
      } catch { status.textContent = 'Error de red al subir la foto' }
      setTimeout(() => (status.textContent = ''), 3000)
    })

    async function loadPrecios() {
      try {
        const res = await fetch('/api/socios/admin/precios', { credentials: 'include' })
        const data = await res.json()
        if (!res.ok || !data.ok) return
        PRECIOS = data.precios
        PRECIOS_ORIG = {}
        for (const it of Object.values(PRECIOS).flat()) PRECIOS_ORIG[it.id] = it.precio
        renderProductos()
        pintarStats()
      } catch { /* la pestaña mostrará vacío; el guardado avisa si falla */ }
    }

    document.getElementById('pa-prod-save').addEventListener('click', async () => {
      const status = document.getElementById('pa-prod-status')
      // Precio en $0: nunca es un caso legítimo acá — casi siempre un campo
      // que quedó vacío por error — y el servidor ahora lo rechaza igual,
      // pero avisarlo ANTES de guardar (con el/los producto(s) señalados) es
      // mucho más claro que un error genérico después del intento.
      const sinPrecio = Object.values(PRECIOS).flat().filter((it) => !(it.precio > 0))
      if (sinPrecio.length) {
        status.classList.remove('is-ok'); status.classList.add('is-err')
        status.textContent = `Sin precio: ${sinPrecio.map((it) => it.label).join(', ')} — completá el precio antes de guardar.`
        return
      }
      // Saltos de precio >50%: el error más caro del panel es un cero de más o de menos
      const saltos = Object.values(PRECIOS).flat().filter((it) => {
        const antes = PRECIOS_ORIG[it.id]
        return antes > 0 && it.precio > 0 && Math.abs(it.precio - antes) / antes > 0.5
      })
      if (saltos.length) {
        const detalle = saltos.map((it) => `${it.label}: $ ${fmtARS(PRECIOS_ORIG[it.id])} → $ ${fmtARS(it.precio)}`).join(' · ')
        if (!(await paConfirm(`Cambio grande de precio — ${detalle}. ¿Está bien?`))) return
      }
      // Completar ids de productos nuevos a partir del nombre
      for (const items of Object.values(PRECIOS)) {
        for (const it of items) if (!it.id || it.id.startsWith('nuevo-')) it.id = slugify(it.label) || `producto-${Date.now().toString(36)}`
      }
      status.classList.remove('is-ok', 'is-err')
      status.textContent = 'Guardando…'
      try {
        const res = await fetch('/api/socios/admin/precios', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ precios: PRECIOS }),
        })
        const data = await res.json()
        if (res.ok && data.ok) {
          PRECIOS = data.precios
          prodDirty = 0
          PRECIOS_ORIG = {}
          for (const it of Object.values(PRECIOS).flat()) PRECIOS_ORIG[it.id] = it.precio
          renderProductos()
          status.classList.add('is-ok')
          status.textContent = 'Productos guardados ✓'
        } else {
          status.classList.add('is-err')
          status.textContent = `Error: ${data.error || res.status}`
        }
      } catch {
        status.classList.add('is-err')
        status.textContent = 'Error de red al guardar.'
      }
      setTimeout(() => { status.textContent = ''; status.classList.remove('is-ok', 'is-err'); pintarPendientes() }, 4000)
    })

    /* ── Franja resumen: chips que navegan ── */
    function pintarStats() {
      const el = document.getElementById('pa-stats')
      const activas = PEDIDOS.filter((p) => p.estado === 'pendiente' || p.estado === 'listo').length
      const disp = CATALOG.filter((g) => g.activo).length
      const prods = Object.values(PRECIOS).flat().length
      const chips = [
        ['pedidos', `<strong class="is-green">${activas}</strong> reserva(s) activa(s)`],
        ['geneticas', `<strong class="is-violet">${disp}</strong> en carta`],
        ['productos', `<strong>${prods}</strong> producto(s)`],
      ]
      if (SOCIOS_COUNT !== null) chips.push(['socios', `<strong>${SOCIOS_COUNT}</strong> socio(s)`])
      el.innerHTML = chips.map(([tab, html]) => `<button type="button" class="pa-stat" data-goto="${tab}">${html}</button>`).join('')
    }
    document.getElementById('pa-stats').addEventListener('click', (e) => {
      const chip = e.target.closest('.pa-stat')
      if (chip) irATab(chip.getAttribute('data-goto'))
    })
    let SOCIOS_COUNT = null

    /* ── Pestañas ── */
    let tabActual = 'pedidos'
    function irATab(name) {
      tabActual = name
      document.querySelectorAll('.pa-tab').forEach((t) => t.classList.toggle('is-active', t.dataset.tab === name))
      ;['geneticas', 'pedidos', 'productos', 'socios'].forEach((n) => {
        const panel = document.getElementById('tab-' + n)
        if (panel) panel.hidden = n !== name
      })
      if (name === 'socios') { loadSocios(); loadIntentos(); setTimeout(() => document.getElementById('pa-socio-email')?.focus(), 100) }
      if (name === 'pedidos') loadPedidos()
      if (name === 'productos') renderProductos()
    }
    document.querySelectorAll('.pa-tab').forEach((tab) => tab.addEventListener('click', () => irATab(tab.dataset.tab)))

    // Reservas frescas sin tocar nada: refresh cada 60s con la pestaña visible
    setInterval(() => {
      if (document.visibilityState === 'visible' && tabActual === 'pedidos' && !document.getElementById('pa-content').hidden) loadPedidos()
    }, 60000)

    /* ── Pedidos ── */
    let PEDIDOS = []
    let pedFilter = 'activos'
    const PED_BADGE = {
      pendiente: ['Pendiente', ''],
      listo: ['Lista para retirar', 'is-on'],
      entregado: ['Entregada', 'is-done'],
      cancelado: ['Cancelada', 'is-off'],
    }
    function pedidoItems(p) {
      return p.items
        .map((i) => `<li>${esc(`${i.cantidad} ${i.formato === 'flor' ? 'g' : 'u'} — ${i.nombre}`)}${i.formato === 'preroll' ? ' <span class="pa-ped-fmt">preroll</span>' : ''}</li>`)
        .join('')
    }
    // Una sola acción primaria grande (triage con el pulgar); Cancelar vive
    // escondida en el menú ⋯ para que nadie cancele sin querer.
    function pedidoAcciones(p) {
      const menu = `
        <div class="pa-ped-menu">
          <button type="button" class="pa-ped-menubtn" data-menu="${esc(p.id)}" aria-label="Más acciones">⋯</button>
          <div class="pa-ped-menupanel" data-menupanel="${esc(p.id)}" hidden>
            <button type="button" class="pa-btn pa-btn-danger pa-btn-slim pa-ped-action" data-id="${esc(p.id)}" data-estado="cancelado">Cancelar reserva</button>
          </div>
        </div>`
      if (p.estado === 'pendiente') {
        return `<button type="button" class="pa-btn pa-btn-primary pa-ped-action pa-ped-primary" data-id="${esc(p.id)}" data-estado="listo">Marcar lista</button>${menu}`
      }
      if (p.estado === 'listo') {
        return `<button type="button" class="pa-btn pa-btn-primary pa-ped-action pa-ped-primary" data-id="${esc(p.id)}" data-estado="entregado">Marcar entregada</button>${menu}`
      }
      return ''
    }
    function pedidoRow(p) {
      const [label, cls] = PED_BADGE[p.estado] || [p.estado, '']
      return `
        <article class="pa-socio pa-pedido">
          <div class="pa-socio-main">
            <div class="pa-socio-top">
              <strong class="pa-socio-name">${esc(p.name || p.email)}</strong>
              <span class="pa-socio-badge ${cls}">${esc(label)}</span>
              <span class="pa-socio-meta">${esc(fmtFecha(p.creado))}</span>
            </div>
            <div class="pa-socio-email">${esc(p.email)}</div>
            <ul class="pa-ped-items">${pedidoItems(p)}</ul>
            ${p.nota ? `<div class="pa-socio-meta">Nota: ${esc(p.nota)}</div>` : ''}
          </div>
          <div class="pa-ped-actions">${pedidoAcciones(p)}</div>
        </article>`
    }
    // Ranking "Más reservado": suma cantidades por producto en todos los pedidos
    // no cancelados — mismo dato que ya viaja en PEDIDOS, sin pegarle a otro endpoint.
    function renderPedidosTop() {
      const top = document.getElementById('pa-ped-top')
      const cantidades = new Map()
      for (const p of PEDIDOS) {
        if (p.estado === 'cancelado') continue
        for (const i of p.items || []) {
          const clave = i.nombre || '(sin nombre)'
          cantidades.set(clave, (cantidades.get(clave) || 0) + (i.cantidad || 0))
        }
      }
      const ranking = [...cantidades.entries()].sort((a, b) => b[1] - a[1]).slice(0, 5)
      if (!ranking.length) { top.hidden = true; top.innerHTML = ''; return }
      top.hidden = false
      top.innerHTML = '<span class="pa-ped-top-label">Más reservado:</span>' +
        ranking.map(([nombre, n]) => `<span class="pa-ped-top-chip">${esc(nombre)} <strong>${n}</strong></span>`).join('')
    }
    function renderPedidos() {
      const list = document.getElementById('pa-pedidos-list')
      // Triage: pendientes primero, después listas, después el histórico
      const peso = { pendiente: 0, listo: 1, entregado: 2, cancelado: 2 }
      const ordenadas = [...PEDIDOS].sort((a, b) => (peso[a.estado] ?? 3) - (peso[b.estado] ?? 3) || String(b.creado).localeCompare(String(a.creado)))
      const filtered = pedFilter === 'activos'
        ? ordenadas.filter((p) => p.estado === 'pendiente' || p.estado === 'listo')
        : ordenadas
      const activos = PEDIDOS.filter((p) => p.estado === 'pendiente' || p.estado === 'listo').length
      pintarStats()
      renderPedidosTop()
      document.getElementById('pa-ped-count').textContent = `${activos} activa(s) · ${PEDIDOS.length} en total`
      const dot = document.getElementById('pa-ped-dot')
      dot.hidden = activos === 0
      dot.textContent = activos || ''
      list.innerHTML = filtered.length
        ? filtered.map(pedidoRow).join('')
        : `<p class="pa-empty">${pedFilter === 'activos' ? 'No hay reservas activas ahora mismo.' : 'Todavía no entró ninguna reserva.'}</p>`
    }
    async function loadPedidos() {
      const list = document.getElementById('pa-pedidos-list')
      if (!PEDIDOS.length) list.innerHTML = '<p class="pa-save-status">Cargando…</p>'
      try {
        const res = await fetch('/api/socios/admin/pedidos', { credentials: 'include' })
        const data = await res.json()
        if (!res.ok || !data.ok) { list.innerHTML = `<p class="pa-msg">Error: ${esc(data.error || res.status)}</p>`; return }
        PEDIDOS = data.pedidos || []
        renderPedidos()
      } catch {
        list.innerHTML = '<p class="pa-msg">Error de red al cargar pedidos.</p>'
      }
    }
    document.querySelectorAll('.pa-pedfilter').forEach((b) => b.addEventListener('click', () => {
      document.querySelectorAll('.pa-pedfilter').forEach((x) => x.classList.remove('is-active'))
      b.classList.add('is-active')
      pedFilter = b.dataset.pedfilter
      renderPedidos()
    }))
    document.getElementById('pa-ped-refresh').addEventListener('click', loadPedidos)
    document.addEventListener('click', async (e) => {
      // Menú ⋯ de cada reserva
      const mbtn = e.target.closest && e.target.closest('.pa-ped-menubtn')
      if (mbtn) {
        const panel = document.querySelector(`[data-menupanel="${CSS.escape(mbtn.getAttribute('data-menu'))}"]`)
        const willOpen = panel.hidden
        document.querySelectorAll('.pa-ped-menupanel').forEach((p) => { p.hidden = true })
        panel.hidden = !willOpen
        return
      }
      if (!e.target.closest('.pa-ped-menupanel')) document.querySelectorAll('.pa-ped-menupanel').forEach((p) => { p.hidden = true })

      const btn = e.target.closest && e.target.closest('.pa-ped-action')
      if (!btn) return
      const estado = btn.dataset.estado
      if (estado === 'cancelado' && !(await paConfirm('¿Cancelar esta reserva? El socio la va a ver como cancelada.'))) return
      const pedStatus = document.getElementById('pa-ped-status')
      pedStatus.classList.remove('is-ok', 'is-err')
      pedStatus.textContent = ''
      btn.disabled = true
      try {
        const res = await fetch('/api/socios/admin/pedidos', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ id: btn.dataset.id, estado }),
        })
        const data = await res.json().catch(() => ({}))
        if (res.ok && data.ok) {
          await loadPedidos()
        } else {
          btn.disabled = false
          pedStatus.classList.add('is-err')
          pedStatus.textContent = data.error || `No se pudo actualizar (${res.status}) — probá de nuevo.`
          if (data.conflict) await loadPedidos() // trae el estado real, aunque el click no haya aplicado
          setTimeout(() => { pedStatus.textContent = ''; pedStatus.classList.remove('is-err') }, 6000)
        }
      } catch {
        btn.disabled = false
        pedStatus.classList.add('is-err')
        pedStatus.textContent = 'Error de red — probá de nuevo.'
        setTimeout(() => { pedStatus.textContent = ''; pedStatus.classList.remove('is-err') }, 6000)
      }
    })

    /* ── Socios ── */
    function fmtFecha(iso) {
      if (!iso) return '—'
      try {
        const d = new Date(iso)
        if (isNaN(d.getTime())) return '—'
        return d.toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric' }) +
          ' ' + d.toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit' })
      } catch { return iso }
    }
    function initials(s) {
      const t = (s || '').trim()
      if (!t) return '?'
      const p = t.split(/\s+/)
      return ((p[0]?.[0] || '') + (p[1]?.[0] || '')).toUpperCase() || '?'
    }
    // "hace 3 días" — el dato operativo es la distancia, no la fecha exacta
    function fmtRel(iso) {
      if (!iso) return null
      const d = new Date(iso)
      if (isNaN(d.getTime())) return null
      const min = Math.floor((Date.now() - d.getTime()) / 60000)
      if (min < 1) return 'recién'
      if (min < 60) return `hace ${min} min`
      const h = Math.floor(min / 60)
      if (h < 24) return `hace ${h} h`
      const dias = Math.floor(h / 24)
      if (dias < 31) return `hace ${dias} día${dias > 1 ? 's' : ''}`
      const meses = Math.floor(dias / 30)
      return `hace ${meses} mes${meses > 1 ? 'es' : ''}`
    }

    // Cruce con reservas (PEDIDOS ya está cargado en el panel)
    function reservasDe(email) {
      const rs = PEDIDOS.filter((p) => p.email === email)
      const activa = rs.find((p) => p.estado === 'pendiente' || p.estado === 'listo')
      return { total: rs.length, activa }
    }

    function socioRow(s) {
      const ava = `<span class="pa-socio-ava"><span class="pa-socio-ini">${esc(initials(s.name || s.email))}</span>${s.picture ? `<img src="${esc(s.picture)}" alt="" referrerpolicy="no-referrer" onerror="this.remove()" />` : ''}</span>`
      const estado = s.lastLogin
        ? `<span class="pa-socio-badge is-on" title="Último ingreso: ${esc(fmtFecha(s.lastLogin))}">Activo ${esc(fmtRel(s.lastLogin))}</span>`
        : '<span class="pa-socio-badge">Sin ingresar</span>'
      const verif = s.emailVerified ? '<span class="pa-socio-verif" title="Cuenta de Google verificada">✓</span>' : ''
      const res = reservasDe(s.email)
      const chipActiva = res.activa
        ? `<span class="pa-socio-badge is-res" title="Tiene una reserva ${res.activa.estado === 'listo' ? 'lista para retirar' : 'pendiente'}">Reserva ${res.activa.estado === 'listo' ? 'lista' : 'pendiente'}</span>`
        : ''
      const chipRes = res.total
        ? `${chipActiva}<button type="button" class="pa-socio-badge pa-socio-hist-btn" data-email="${esc(s.email)}" title="Ver historial de reservas">${res.total} reserva(s) <span class="pa-hist-chev">▸</span></button>`
        : chipActiva
      // Sin ingresar → invitación lista para mandar por WhatsApp
      const invitar = s.lastLogin ? '' : `<a class="pa-socio-invitar" target="_blank" rel="noopener" href="https://wa.me/?text=${encodeURIComponent(`Hola! Ya sos socio de Flora 🌿 Entrá a la carta del club con tu cuenta de Google (${s.email}): https://floraong.ar/socios/carta/`)}">Invitar por WhatsApp</a>`
      // Ficha Google: nombre y apellido reales + idioma de la cuenta
      const nombreCompleto = s.name || [s.givenName, s.familyName].filter(Boolean).join(' ')
      const fichaGoogle = [
        s.givenName && s.familyName ? `${s.givenName} ${s.familyName}` : '',
        s.locale ? `idioma ${s.locale}` : '',
      ].filter(Boolean).join(' · ')
      const metaPartes = [
        s.alta ? `Alta ${fmtFecha(s.alta).split(' ')[0]}` : '',
        s.firstLogin ? `Primer ingreso ${fmtFecha(s.firstLogin).split(' ')[0]}` : '',
        s.lastLogin ? `Último ${fmtFecha(s.lastLogin)}` : 'Todavía no ingresó con esta cuenta',
        s.logins ? `<strong>${s.logins}</strong> ingreso(s)` : '',
        fichaGoogle,
      ].filter(Boolean)
      return `
        <article class="pa-socio" data-buscable="${esc(`${nombreCompleto} ${s.email} ${s.nota || ''}`.toLowerCase())}">
          ${ava}
          <div class="pa-socio-main">
            <div class="pa-socio-top">
              <strong class="pa-socio-name">${esc(nombreCompleto || '(sin nombre aún)')}</strong>${verif}
              ${estado}
              ${chipRes}
              ${invitar}
            </div>
            <div class="pa-socio-email">${esc(s.email)}</div>
            <input class="pa-input pa-socio-nota" data-email="${esc(s.email)}" value="${esc(s.nota)}" placeholder="Nota…" />
            <div class="pa-socio-meta">${metaPartes.join(' · ')}</div>
            <div class="pa-socio-hist" data-hist="${esc(s.email)}" hidden></div>
          </div>
          <button type="button" class="pa-socio-del" data-email="${esc(s.email)}" aria-label="Eliminar socio">×</button>
        </article>`
    }

    // Historial de reservas del socio (se arma al abrir; vive lo que el KV: ~90 días)
    function histReservasHtml(email) {
      const rs = PEDIDOS.filter((p) => p.email === email)
        .sort((a, b) => String(b.creado).localeCompare(String(a.creado)))
      if (!rs.length) return '<p class="pa-socio-meta">Sin reservas registradas en los últimos 90 días.</p>'
      return rs.map((p) => {
        const [label, cls] = PED_BADGE[p.estado] || [p.estado, '']
        const items = p.items.map((i) => `${i.cantidad} ${i.formato === 'flor' ? 'g' : 'u'} ${esc(i.nombre)}`).join(' · ')
        return `
          <div class="pa-hist-row">
            <span class="pa-hist-fecha">${esc(fmtFecha(p.creado))}</span>
            <span class="pa-socio-badge ${cls}">${esc(label)}</span>
            <span class="pa-hist-items">${items}</span>
            ${p.nota ? `<span class="pa-hist-nota">“${esc(p.nota)}”</span>` : ''}
          </div>`
      }).join('') + '<p class="pa-hist-pie">El historial cubre los últimos 90 días.</p>'
    }

    document.addEventListener('click', (e) => {
      const btn = e.target.closest && e.target.closest('.pa-socio-hist-btn')
      if (!btn) return
      const email = btn.getAttribute('data-email')
      const hist = document.querySelector(`.pa-socio-hist[data-hist="${CSS.escape(email)}"]`)
      if (!hist) return
      if (hist.hidden && !hist.innerHTML) hist.innerHTML = histReservasHtml(email)
      hist.hidden = !hist.hidden
      btn.querySelector('.pa-hist-chev').textContent = hist.hidden ? '▸' : '▾'
    })
    let SOCIOS_LIST = []
    let socioSort = { key: 'lastLogin', dir: -1 } // arranca por actividad reciente
    let socioQ = ''

    const SOCIO_SORTERS = {
      // null/ausente siempre al final, gane quien gane la dirección
      lastLogin: (a, b) => (Date.parse(b.lastLogin || 0) || 0) - (Date.parse(a.lastLogin || 0) || 0),
      name: (a, b) => String(a.name || a.email).localeCompare(String(b.name || b.email), 'es'),
      logins: (a, b) => (b.logins || 0) - (a.logins || 0),
      alta: (a, b) => (Date.parse(b.alta || b.firstLogin || 0) || 0) - (Date.parse(a.alta || a.firstLogin || 0) || 0),
      sin: (a, b) => Number(!!a.lastLogin) - Number(!!b.lastLogin), // sin ingresar primero
    }

    // Filtros del padrón: las burbujas de stats filtran al tocarlas
    let socioFiltro = ''
    const SOCIO_FILTROS = {
      activos30: (s) => s.lastLogin && Date.now() - Date.parse(s.lastLogin) < 30 * 86400000,
      ingresaron: (s) => !!s.lastLogin,
      sin: (s) => !s.lastLogin,
    }

    function renderSocios() {
      const list = document.getElementById('pa-socios-list')
      let socios = [...SOCIOS_LIST].sort(SOCIO_SORTERS[socioSort.key])
      if (socioSort.dir === 1) socios.reverse()
      if (socioFiltro && SOCIO_FILTROS[socioFiltro]) socios = socios.filter(SOCIO_FILTROS[socioFiltro])
      if (socioQ) {
        socios = socios.filter((s) =>
          `${s.name || ''} ${s.givenName || ''} ${s.familyName || ''} ${s.email} ${s.nota || ''}`.toLowerCase().includes(socioQ)
        )
      }
      // Sub-estadísticas del padrón (clickeables: filtran)
      const conIngreso = SOCIOS_LIST.filter(SOCIO_FILTROS.ingresaron).length
      const activos30 = SOCIOS_LIST.filter(SOCIO_FILTROS.activos30).length
      const chip = (filtro, html, title) =>
        `<button type="button" class="pa-stat${socioFiltro === filtro ? ' is-active' : ''}" data-filtro="${filtro}" title="${title}">${html}</button>`
      document.getElementById('pa-socio-stats').innerHTML = [
        chip('', `<strong>${SOCIOS_LIST.length}</strong> socio(s)`, 'Ver todos'),
        chip('activos30', `<strong class="is-green">${activos30}</strong> activo(s) últimos 30 días`, 'Solo los que entraron este mes'),
        chip('ingresaron', `<strong class="is-violet">${conIngreso}</strong> ingresaron alguna vez`, 'Solo los que ya usaron la carta'),
        chip('sin', `<strong>${SOCIOS_LIST.length - conIngreso}</strong> sin ingresar`, 'Solo los que nunca entraron'),
      ].join('')
      // Flecha de dirección en el criterio activo
      document.querySelectorAll('#pa-socio-sort .pa-avail').forEach((b) => {
        const on = b.dataset.sort === socioSort.key
        b.classList.toggle('is-active', on)
        b.textContent = b.textContent.replace(/ [↓↑]$/, '') + (on ? (socioSort.dir === -1 ? ' ↓' : ' ↑') : '')
      })
      list.innerHTML = socios.length
        ? socios.map(socioRow).join('')
        : `<p class="pa-empty">${socioQ || socioFiltro ? 'Ningún socio coincide con ese filtro.' : 'Todavía no hay socios cargados.'}</p>`
    }
    document.getElementById('pa-socio-stats').addEventListener('click', (e) => {
      const chip = e.target.closest('.pa-stat')
      if (!chip) return
      const f = chip.getAttribute('data-filtro')
      socioFiltro = socioFiltro === f ? '' : f // tocar el activo lo limpia
      renderSocios()
    })

    async function loadSocios() {
      const list = document.getElementById('pa-socios-list')
      if (!SOCIOS_LIST.length) list.innerHTML = '<p class="pa-loading">Cargando…</p>'
      try {
        const res = await fetch('/api/socios/admin/socios', { credentials: 'include' })
        const data = await res.json()
        if (!res.ok || !data.ok) { list.innerHTML = `<p class="pa-msg">Error: ${esc(data.error || res.status)}</p>`; return }
        SOCIOS_LIST = data.socios
        SOCIOS_COUNT = data.socios.length
        pintarStats()
        renderSocios()
      } catch {
        list.innerHTML = '<p class="pa-msg">Error de red al cargar socios.</p>'
      }
    }
    document.getElementById('pa-socio-buscar').addEventListener('input', (e) => {
      socioQ = e.target.value.trim().toLowerCase()
      renderSocios()
    })
    document.getElementById('pa-socio-sort').addEventListener('click', (e) => {
      const b = e.target.closest('.pa-avail')
      if (!b) return
      const key = b.dataset.sort
      if (socioSort.key === key) socioSort.dir *= -1 // segundo click invierte
      else socioSort = { key, dir: -1 }
      renderSocios()
    })
    async function saveSocio(email, nota) {
      try {
        const res = await fetch('/api/socios/admin/socios', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ email, nota }),
        })
        return res.ok
      } catch {
        return false // sin red: que el caller muestre el error, nunca silencio
      }
    }
    document.getElementById('pa-socio-form').addEventListener('submit', async (e) => {
      e.preventDefault()
      const emailEl = document.getElementById('pa-socio-email')
      const notaEl = document.getElementById('pa-socio-nota')
      const status = document.getElementById('pa-socio-status')
      const email = emailEl.value.trim().toLowerCase()
      if (!email) return
      status.textContent = 'Guardando…'
      const ok = await saveSocio(email, notaEl.value.trim())
      status.textContent = ok ? 'Socio agregado ✓' : 'Error al agregar'
      if (ok) { emailEl.value = ''; notaEl.value = ''; loadSocios() }
      setTimeout(() => (status.textContent = ''), 3000)
    })
    document.addEventListener('change', async (e) => {
      const nota = e.target.closest && e.target.closest('.pa-socio-nota')
      if (!nota) return
      const status = document.getElementById('pa-socio-status')
      status.textContent = 'Guardando nota…'
      const ok = await saveSocio(nota.getAttribute('data-email'), nota.value)
      status.textContent = ok ? 'Nota guardada ✓' : 'Error al guardar la nota — probá de nuevo'
      setTimeout(() => (status.textContent = ''), 3000)
    })
    document.addEventListener('click', async (e) => {
      const del = e.target.closest && e.target.closest('.pa-socio-del')
      if (!del) return
      const email = del.getAttribute('data-email')
      if (!(await paConfirm(`¿Dar de baja a ${email}? Deja de poder entrar a la carta.`))) return
      await fetch('/api/socios/admin/socios', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ email }),
      })
      loadSocios()
    })

    /* ── Intentos de acceso (leads: gmails que probaron entrar y no son socios) ── */
    let INTENTOS_LIST = []
    function intentoRow(i) {
      const ava = `<span class="pa-socio-ava"><span class="pa-socio-ini">${esc(initials(i.name || i.email))}</span>${i.picture ? `<img src="${esc(i.picture)}" alt="" referrerpolicy="no-referrer" onerror="this.remove()" />` : ''}</span>`
      return `
        <article class="pa-socio pa-intento">
          ${ava}
          <div class="pa-socio-main">
            <div class="pa-socio-top">
              <strong class="pa-socio-name">${esc(i.name || '(sin nombre)')}</strong>
              <span class="pa-socio-badge is-warn">${i.attempts} intento${i.attempts === 1 ? '' : 's'}</span>
            </div>
            <div class="pa-socio-email">${esc(i.email)}</div>
            <div class="pa-socio-meta">Último intento ${esc(fmtRel(i.lastAttempt))} · ${esc(fmtFecha(i.lastAttempt))}</div>
          </div>
          <div class="pa-intento-actions">
            <button type="button" class="pa-btn pa-btn-primary pa-btn-slim pa-intento-add" data-email="${esc(i.email)}">+ Agregar como socio</button>
            <button type="button" class="pa-socio-del pa-intento-del" data-email="${esc(i.email)}" aria-label="Descartar intento">×</button>
          </div>
        </article>`
    }
    function renderIntentos() {
      const block = document.getElementById('pa-intentos-block')
      const countEl = document.getElementById('pa-intentos-count')
      block.hidden = INTENTOS_LIST.length === 0
      if (!INTENTOS_LIST.length) return
      countEl.textContent = INTENTOS_LIST.length
      document.getElementById('pa-intentos-list').innerHTML = INTENTOS_LIST.map(intentoRow).join('')
    }
    async function loadIntentos() {
      try {
        const res = await fetch('/api/socios/admin/intentos', { credentials: 'include' })
        const data = await res.json()
        if (!res.ok || !data.ok) return
        INTENTOS_LIST = data.intentos
        renderIntentos()
      } catch {
        // silencioso: no es contenido crítico de la pestaña
      }
    }
    document.addEventListener('click', async (e) => {
      const add = e.target.closest && e.target.closest('.pa-intento-add')
      if (!add) return
      const email = add.getAttribute('data-email')
      add.disabled = true
      add.textContent = 'Agregando…'
      const ok = await saveSocio(email, '')
      if (ok) {
        await fetch('/api/socios/admin/intentos', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ email }),
        })
        loadSocios()
        loadIntentos()
      } else {
        add.disabled = false
        add.textContent = '+ Agregar como socio'
      }
    })
    document.addEventListener('click', async (e) => {
      const del = e.target.closest && e.target.closest('.pa-intento-del')
      if (!del) return
      const email = del.getAttribute('data-email')
      if (!(await paConfirm(`¿Descartar el intento de ${email}?`))) return
      await fetch('/api/socios/admin/intentos', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ email }),
      })
      loadIntentos()
    })

    function showLoginError(message) {
      const msg = document.getElementById('pa-login-msg')
      msg.textContent = message
      msg.hidden = false
    }

    async function loadCatalog() {
      const res = await fetch('/api/socios/admin/geneticas', { credentials: 'include' })
      if (res.status === 401) return false
      if (res.status === 403) {
        document.getElementById('pa-login').hidden = true
        document.getElementById('pa-forbidden').hidden = false
        return true
      }
      if (!res.ok) {
        showLoginError(`El servidor respondió ${res.status}. Esperá un momento y recargá.`)
        return true
      }
      const data = await res.json()
      CATALOG = data.geneticas || []
      CATALOG_VERSION = data.version || 0
      // La pestaña Socios solo la ve el super admin.
      if (!data.isSuperAdmin) {
        const tabSocios = document.querySelector('.pa-tab[data-tab="socios"]')
        if (tabSocios) tabSocios.hidden = true
      }
      document.getElementById('pa-login').hidden = true
      document.getElementById('pa-content').hidden = false

      // Identidad del admin logueado + logout
      if (data.email) {
        document.getElementById('pa-quien').hidden = false
        document.getElementById('pa-quien-ini').textContent = initials(data.email)
        document.getElementById('pa-quien-mail').textContent = data.email
      }

      render()
      loadPrecios()
      // Aterrizar donde está el trabajo del día: Reservas si hay activas
      await loadPedidos()
      const activas = PEDIDOS.filter((p) => p.estado === 'pendiente' || p.estado === 'listo').length
      irATab(activas > 0 ? 'pedidos' : 'geneticas')
      return true
    }

    document.getElementById('pa-logout').addEventListener('click', async () => {
      if (genDirty || prodDirty) {
        if (!(await paConfirm('Tenés cambios sin guardar. ¿Salir igual?'))) return
        genDirty = prodDirty = 0
      }
      await fetch('/api/socios/logout', { method: 'POST', credentials: 'include' })
      location.reload()
    })

    window.handleGoogleCredential = async (response) => {
      try {
        const res = await fetch('/api/socios/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          // Este login es para el panel, no para reservar como paciente:
          // el backend solo salta el checkbox de términos cuando ve este
          // contexto Y la cuenta figura como staff (ADMIN/SUPER_ADMIN).
          body: JSON.stringify({ credential: response.credential, appContext: 'admin' }),
        })
        const data = await res.json()
        if (!res.ok || !data.ok) {
          showLoginError(data.error || 'No se pudo verificar tu cuenta.')
          return
        }
        await loadCatalog()
      } catch {
        showLoginError('Error de red al verificar con Google.')
      }
    }

    if (googleClientId) {
      window.onload = () => {
        google.accounts.id.initialize({ client_id: googleClientId, callback: window.handleGoogleCredential })
        google.accounts.id.renderButton(document.getElementById('g_id_button'), { theme: 'filled_black', size: 'large', text: 'signin_with' })
      }
    } else {
      showLoginError('Falta configurar el Google Client ID del sitio.')
    }

    loadCatalog().catch(() => showLoginError('No se pudo conectar con el servidor. Recargá la página.'))
  </script>
</Layout>

<style is:global>
  /* ══════════════════════════════════════════════
     PANEL ADMIN — modo nocturno de marca (igual carta)
     Violeta profundo · crema · acentos violeta/verde
  ══════════════════════════════════════════════ */
  .pa-main {
    --pa-bg:     #130d1c;
    --pa-card:   #1c1430;
    --pa-card-2: #251a3d;
    --pa-line:   rgba(244, 241, 247, 0.1);
    --pa-cream:  #f4f1f7;
    --pa-muted:  rgba(244, 241, 247, 0.55);
    --pa-violet: #b79de6;
    --pa-green:  #3cb492;
    --pa-danger: #f2818a;
    --pa-warn:   #e6a83e;

    min-height: 100svh;
    padding: clamp(24px, 4vw, 56px) clamp(16px, 4vw, 40px);
    background: var(--pa-bg);
    color: var(--pa-cream);
    font-family: var(--font-ui);
    position: relative;
  }
  .pa-main::before {
    content: '';
    position: absolute; inset: 0; pointer-events: none; z-index: 0;
    background:
      radial-gradient(55% 40% at 88% -5%, rgba(56, 31, 86, 0.5), transparent 70%),
      radial-gradient(50% 35% at 0% 100%, rgba(10, 80, 60, 0.14), transparent 70%);
  }
  html, body { background-color: #130d1c; }
  /* El grano cinematográfico global (body::after: capa fixed full-viewport con
     mix-blend-mode + feTurbulence) dispara un bug del compositor de Chrome en
     desktop que pinta TODA la pantalla de negro al repintar (pestaña Socios).
     En un panel de datos no aporta: fuera. */
  body::after { display: none !important; }

  .pa-wrap { position: relative; z-index: 1; max-width: 1460px; margin: 0 auto; }

  .pa-eyebrow {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--pa-muted); font-weight: 700; margin-bottom: 0.6rem;
  }
  .pa-eyebrow::before {
    content: ''; width: 7px; height: 7px; border-radius: 50%;
    background: var(--pa-violet);
  }
  .pa-title {
    font-family: var(--font-display); font-weight: 400;
    font-size: clamp(1.7rem, 3.5vw, 2.4rem); line-height: 1; letter-spacing: 0.005em;
    color: var(--pa-cream); margin: 0 0 1.2rem;
  }
  /* Header: título + identidad del admin */
  .pa-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .pa-quien {
    display: inline-flex; align-items: center; gap: 0.55rem;
    background: var(--pa-card); border: 1px solid var(--pa-line); border-radius: 999px;
    padding: 0.35rem 0.9rem 0.35rem 0.4rem; margin-top: 0.3rem;
  }
  .pa-quien[hidden] { display: none; }
  .pa-quien-ini {
    width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
    background: var(--pa-violet); color: #130d1c;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 0.72rem; font-weight: 800;
  }
  .pa-quien-mail { font-size: 0.82rem; font-weight: 600; color: var(--pa-cream); max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .pa-logout {
    background: none; border: none; cursor: pointer; font-family: var(--font-ui);
    font-size: 0.78rem; font-weight: 600; color: var(--pa-muted); padding: 0.2rem 0.2rem;
  }
  .pa-logout:hover { color: var(--pa-danger); }

  .pa-login[hidden], .pa-content[hidden] { display: none; }
  .pa-login {
    display: flex; flex-direction: column; align-items: flex-start; gap: 1rem;
    background: var(--pa-card); border: 1px solid var(--pa-line);
    border-radius: 20px; padding: clamp(24px, 4vw, 40px); max-width: 460px;
    box-shadow: 0 24px 60px -30px rgba(0, 0, 0, 0.7);
  }
  .pa-msg {
    color: var(--pa-danger); font-size: 0.9rem;
    background: rgba(242, 129, 138, 0.08); border: 1px solid rgba(242, 129, 138, 0.2);
    padding: 0.9rem 1.1rem; border-radius: 12px;
  }
  .pa-help {
    background: rgba(244, 241, 247, 0.04); border: 1px solid var(--pa-line); border-radius: 14px;
    padding: 0.95rem 1.15rem; font-size: 0.88rem; line-height: 1.55; color: var(--pa-muted);
    margin-bottom: 1.4rem;
  }
  .pa-help strong { color: var(--pa-cream); font-weight: 700; }

  /* ── Inputs ── */
  input[type="checkbox"] { accent-color: var(--pa-violet); }
  .pa-input, select.pa-input, .pa-field select, .pa-field input {
    width: 100%; font-family: var(--font-ui); font-size: 0.88rem;
    border: 1px solid var(--pa-line); border-radius: 10px; padding: 0.5rem 0.7rem;
    color: var(--pa-cream); background: var(--pa-card-2);
  }
  .pa-input::placeholder { color: rgba(244, 241, 247, 0.3); }
  .pa-input:focus, .pa-field select:focus, .pa-field input:focus { outline: none; border-color: var(--pa-violet); }
  .pa-field select option { background: var(--pa-card-2); color: var(--pa-cream); }

  /* ── Genéticas: cards ── */
  .pa-list { display: flex; flex-direction: column; gap: 1rem; }
  .pa-card {
    background: var(--pa-card); border: 1px solid var(--pa-line);
    border-radius: 18px; padding: 1.2rem 1.3rem;
  }
  .pa-card-top { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1rem; }
  .pa-input-nombre {
    flex: 1; font-family: var(--font-display); font-weight: 500; font-size: 1.35rem;
    background: none; border: none; border-bottom: 1px solid var(--pa-line); border-radius: 0;
    padding: 0.3rem 0.1rem; color: var(--pa-cream);
  }
  .pa-input-nombre:focus { border-bottom-color: var(--pa-violet); }
  .pa-activo {
    display: flex; align-items: center; gap: 0.45rem; font-size: 0.8rem; white-space: nowrap;
    color: var(--pa-muted);
  }
  .pa-del {
    background: none; border: 1px solid var(--pa-line); border-radius: 9px;
    width: 32px; height: 32px; font-size: 1.15rem; line-height: 1; cursor: pointer;
    color: var(--pa-danger); flex-shrink: 0; transition: border-color 0.15s ease;
  }
  .pa-del:hover { border-color: var(--pa-danger); }

  .pa-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 0.8rem; margin-bottom: 1rem; }
  .pa-field { display: flex; flex-direction: column; gap: 0.3rem; }
  .pa-field > span {
    font-size: 0.66rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--pa-violet);
  }
  .pa-field-wide { grid-column: 1 / -1; }

  /* ── Formato ── */
  .pa-formatos { display: flex; align-items: center; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 1rem; }
  .pa-formatos-label {
    font-size: 0.66rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--pa-muted);
  }
  .pa-fmt {
    display: inline-flex; align-items: center; gap: 0.45rem; font-size: 0.82rem; font-weight: 600;
    border: 1px solid var(--pa-line); border-radius: 999px;
    padding: 0.35rem 0.85rem; cursor: pointer; color: var(--pa-muted);
  }
  .pa-fmt.is-on { color: var(--pa-cream); background: rgba(60, 180, 146, 0.14); border-color: var(--pa-green); }
  .pa-fmt input { margin: 0; }

  /* ── Sabor / efecto ── */
  .pa-tags-block { margin-top: 0.8rem; }
  .pa-tags-label {
    display: block; font-size: 0.66rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--pa-muted); margin-bottom: 0.5rem;
  }
  .pa-tags { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .pa-tag {
    display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.8rem;
    border: 1px solid var(--pa-line); border-radius: 999px; padding: 0.35rem 0.8rem 0.35rem 0.6rem;
    cursor: pointer; color: var(--pa-muted);
  }
  .pa-tag.is-checked { color: var(--pa-cream); background: rgba(183, 157, 230, 0.16); border-color: var(--pa-violet); font-weight: 600; }
  .pa-tag input { position: absolute; opacity: 0; width: 0; height: 0; }
  .pa-tag-icon { width: 16px; height: 16px; display: inline-flex; color: var(--pa-violet); }
  .pa-tag-icon svg { width: 100%; height: 100%; }

  /* ── Botones ── */
  .pa-btn {
    font-family: var(--font-ui); font-weight: 700; font-size: 0.88rem; border-radius: 999px;
    padding: 0.6rem 1.35rem; cursor: pointer; border: none; transition: transform 0.08s ease, background 0.15s ease;
  }
  .pa-btn:active { transform: scale(0.97); }
  .pa-btn:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }
  .pa-btn-ghost { background: none; border: 1.5px dashed var(--pa-line); color: var(--pa-violet); margin-top: 1.2rem; }
  .pa-btn-ghost:hover { border-color: var(--pa-violet); }
  .pa-btn-primary { background: var(--pa-violet); color: #130d1c; }
  .pa-btn-primary:hover { background: #c8b2ec; }

  .pa-savebar {
    position: sticky; bottom: clamp(12px, 2vh, 20px); margin-top: 1.6rem; padding: 0.9rem 1.1rem;
    background: rgba(28, 20, 48, 0.97); /* sólido: backdrop-filter sumaba otra capa compuesta al bug del compositor */
    border: 1px solid var(--pa-line); border-radius: 16px;
    display: flex; align-items: center; justify-content: flex-end; gap: 1rem;
    box-shadow: 0 12px 34px -12px rgba(0, 0, 0, 0.6);
  }
  .pa-save-status { font-size: 0.85rem; color: var(--pa-muted); }

  /* ── Pestañas ── */
  .pa-tabs { display: flex; gap: 0.4rem; margin-bottom: 1.4rem; border-bottom: 1px solid var(--pa-line); }
  .pa-tab {
    background: none; border: none; cursor: pointer;
    font-family: var(--font-ui); font-size: 0.95rem; font-weight: 600;
    padding: 0.7rem 1rem; color: var(--pa-muted);
    border-bottom: 2px solid transparent; margin-bottom: -1px;
  }
  .pa-tab:hover { color: var(--pa-cream); }
  .pa-tab.is-active { color: var(--pa-cream); border-bottom-color: var(--pa-violet); }
  .pa-tab[hidden] { display: none; }
  .pa-tab-panel[hidden] { display: none; }

  /* ── Genéticas: toolbar (filtros + buscador) ── */
  .pa-toolbar { display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap; margin-bottom: 1.1rem; }
  .pa-availfilter { display: flex; gap: 0.3rem; }
  .pa-avail {
    background: none; border: 1px solid var(--pa-line); border-radius: 999px;
    padding: 0.42rem 0.95rem; font-family: var(--font-ui); font-size: 0.82rem; font-weight: 600;
    color: var(--pa-muted); cursor: pointer;
  }
  .pa-avail:hover { color: var(--pa-cream); }
  .pa-avail.is-active { background: var(--pa-violet); border-color: var(--pa-violet); color: #130d1c; }
  .pa-search { width: auto; flex: 1 1 220px; max-width: 320px; }
  .pa-count { font-size: 0.8rem; color: var(--pa-muted); margin-left: auto; white-space: nowrap; }

  /* ── Filas de una línea ── */
  .pa-genscroll { overflow: visible; }
  .pa-rows-head, .pa-row {
    display: grid;
    grid-template-columns: 44px minmax(150px, 1.6fr) 116px 96px minmax(120px, 1.2fr) 60px 60px 104px 104px 104px 76px 32px;
    gap: 0.4rem;
    align-items: center;
    min-width: 1080px;
  }
  .pa-rows-head {
    padding: 0 0.2rem 0.5rem;
    font-size: 0.62rem; font-weight: 700; letter-spacing: 0.09em; text-transform: uppercase;
    color: var(--pa-muted); border-bottom: 1px solid var(--pa-line);
  }
  .pa-rows { display: flex; flex-direction: column; }
  .pa-row { padding: 0.45rem 0.2rem; border-bottom: 1px solid var(--pa-line); }
  .pa-row:hover { background: rgba(244, 241, 247, 0.02); }
  .pa-row .pa-input { padding: 0.42rem 0.55rem; font-size: 0.82rem; border-radius: 8px; min-width: 0; }
  .pa-cell-num { text-align: center; }
  .pa-avail-toggle { display: flex; align-items: center; justify-content: center; }
  .pa-avail-toggle input { width: 20px; height: 20px; cursor: pointer; }
  .pa-empty { color: var(--pa-muted); padding: 1.4rem 0.3rem; min-width: auto; }

  /* Foto compacta en la fila */
  .pa-row .pa-foto { flex-wrap: nowrap; gap: 0.3rem; align-items: center; }
  .pa-row .pa-foto-thumb { width: 42px; height: 30px; border-radius: 6px; }
  .pa-row .pa-foto-btn { padding: 0.3rem 0.45rem; font-size: 1rem; line-height: 1; border-radius: 8px; }

  /* ── Desplegable tildable (formato/sabor/efecto) ── */
  .pa-dd { position: relative; min-width: 0; }
  .pa-dd-toggle {
    width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.3rem;
    background: var(--pa-card-2); border: 1px solid var(--pa-line); border-radius: 8px;
    padding: 0.42rem 0.5rem; font-family: var(--font-ui); font-size: 0.8rem; color: var(--pa-cream); cursor: pointer;
  }
  .pa-dd-toggle.has { border-color: var(--pa-violet); }
  .pa-dd-txt { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .pa-dd-chev { width: 12px; height: 12px; color: var(--pa-violet); flex-shrink: 0; transition: transform 0.15s ease; }
  .pa-dd-toggle.open .pa-dd-chev { transform: rotate(180deg); }
  .pa-dd-panel {
    position: absolute; top: calc(100% + 4px); left: 0; z-index: 40;
    min-width: 210px; max-height: 320px; overflow-y: auto;
    background: var(--pa-card-2); border: 1px solid var(--pa-line); border-radius: 12px; padding: 0.35rem;
    box-shadow: 0 18px 44px -14px rgba(0, 0, 0, 0.8);
  }
  .pa-dd-panel[hidden] { display: none; }
  .pa-ddopt {
    display: flex; align-items: center; gap: 0.5rem; padding: 0.42rem 0.5rem; border-radius: 8px;
    font-size: 0.82rem; color: var(--pa-muted); cursor: pointer;
  }
  .pa-ddopt:hover { background: rgba(244, 241, 247, 0.05); }
  .pa-ddopt.is-on { color: var(--pa-cream); }
  .pa-ddopt input { accent-color: var(--pa-violet); flex-shrink: 0; }
  .pa-ddicon { width: 16px; height: 16px; display: inline-flex; color: var(--pa-violet); flex-shrink: 0; }
  .pa-ddicon svg { width: 100%; height: 100%; }

  /* ── Subida de foto ── */
  .pa-foto { display: flex; align-items: center; flex-wrap: wrap; gap: 0.7rem; }
  .pa-foto-thumb {
    width: 72px; height: 54px; border-radius: 10px; overflow: hidden;
    background: var(--pa-card-2); border: 1px solid var(--pa-line); flex-shrink: 0;
  }
  .pa-foto-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pa-foto-btn {
    font-family: var(--font-ui); font-size: 0.8rem; font-weight: 600; cursor: pointer;
    border: 1px solid var(--pa-line); border-radius: 999px;
    padding: 0.45rem 0.95rem; color: var(--pa-cream); background: var(--pa-card-2);
  }
  .pa-foto-btn:hover { border-color: var(--pa-violet); }
  .pa-foto-clear {
    font-family: var(--font-ui); font-size: 0.78rem; cursor: pointer;
    background: none; border: none; color: var(--pa-danger); text-decoration: underline;
  }
  .pa-foto-status { font-size: 0.78rem; color: var(--pa-muted); }

  /* ── Socios ── */
  .pa-socio-form { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 0.6rem; }
  .pa-socio-form .pa-input { flex: 1 1 200px; width: auto; }
  .pa-socio-form .pa-btn { flex-shrink: 0; }
  /* Desktop-first: grilla de varias columnas en vez de una lista apilada de
     una card por fila — mismo criterio de densidad que la tabla de
     genéticas, adaptado a una card (el contenido de socio/pedido varía
     demasiado en alto para forzarlo a una fila de grid rígida). Vale tanto
     para el padrón de socios como para las reservas (comparten esta clase). */
  .pa-socios-list {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 0.7rem; margin-top: 1.2rem; align-items: start;
  }
  .pa-socios-list .pa-empty { grid-column: 1 / -1; }

  /* ── Intentos de acceso (leads) ── */
  .pa-intentos-block {
    margin: 1.4rem 0 1.6rem; padding: 1.1rem 1.2rem 1.3rem;
    background: rgba(230, 168, 62, 0.05); border: 1px solid rgba(230, 168, 62, 0.28);
    border-radius: 16px;
  }
  .pa-intentos-head { margin-bottom: 0.9rem; }
  .pa-subhead {
    display: flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-ui); font-size: 1rem; font-weight: 800; color: var(--pa-cream); margin: 0;
  }
  .pa-count-badge {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 1.3rem; height: 1.3rem; padding: 0 0.4rem; border-radius: 999px;
    font-size: 0.7rem; font-weight: 800; background: var(--pa-warn); color: #2a1c04;
  }
  .pa-intentos-head .pa-help { margin: 0.3rem 0 0; }
  .pa-intentos-list.pa-socios-list { margin-top: 0; }
  .pa-intento { border-color: rgba(230, 168, 62, 0.35); }
  .pa-socio-badge.is-warn { background: rgba(230, 168, 62, 0.18); color: var(--pa-warn); }
  .pa-intento-actions { display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; flex-shrink: 0; }
  .pa-intento-actions .pa-btn-slim { white-space: nowrap; }
  .pa-socio {
    display: flex; align-items: flex-start; gap: 0.9rem;
    background: var(--pa-card); border: 1px solid var(--pa-line);
    border-radius: 16px; padding: 1rem 1.1rem;
  }
  .pa-socio-ava {
    position: relative; flex-shrink: 0;
    width: 46px; height: 46px; border-radius: 50%; overflow: hidden;
    background: var(--pa-violet); color: #130d1c;
    display: inline-flex; align-items: center; justify-content: center;
  }
  .pa-socio-ini { font-size: 0.95rem; font-weight: 800; }
  .pa-socio-ava img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .pa-socio-main { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.32rem; }
  .pa-socio-top { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
  .pa-socio-name { font-size: 1rem; color: var(--pa-cream); }
  .pa-socio-badge {
    font-size: 0.64rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em;
    padding: 0.18rem 0.55rem; border-radius: 999px;
    background: rgba(244, 241, 247, 0.06); color: var(--pa-muted);
  }
  .pa-socio-badge.is-on { background: rgba(60, 180, 146, 0.16); color: var(--pa-green); }
  .pa-socio-email { font-size: 0.82rem; color: var(--pa-muted); }
  .pa-socio-nota { max-width: 360px; margin-top: 0.2rem; }
  .pa-socio-meta { font-size: 0.72rem; color: var(--pa-muted); opacity: 0.8; }
  .pa-socio-del {
    background: none; border: 1px solid var(--pa-line); border-radius: 9px;
    width: 32px; height: 32px; font-size: 1.15rem; line-height: 1; cursor: pointer;
    color: var(--pa-danger); flex-shrink: 0;
  }
  .pa-socio-del:hover { border-color: var(--pa-danger); }

  /* ── Pedidos ── */
  .pa-ped-dot {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 1.15rem; height: 1.15rem; padding: 0 0.32rem; margin-left: 0.45rem;
    font-size: 0.66rem; font-weight: 800; border-radius: 999px;
    background: var(--pa-green); color: #08160f;
  }
  .pa-ped-dot[hidden] { display: none; }
  .pa-ped-top {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem;
    margin: 0 0 1rem; padding: 0.7rem 0.9rem;
    background: rgba(183, 157, 230, 0.08); border: 1px solid var(--pa-line); border-radius: 12px;
  }
  .pa-ped-top[hidden] { display: none; }
  .pa-ped-top-label {
    font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--pa-muted);
  }
  .pa-ped-top-chip {
    font-size: 0.82rem; font-weight: 600; color: var(--pa-cream);
    padding: 0.28rem 0.6rem; border-radius: 999px; background: rgba(255, 255, 255, 0.04);
  }
  .pa-ped-top-chip strong { color: var(--pa-green); margin-left: 0.25rem; }
  .pa-btn-slim { padding: 0.42rem 0.95rem; font-size: 0.82rem; margin-top: 0; }
  .pa-pedido { align-items: stretch; }
  .pa-ped-items { list-style: none; margin: 0.25rem 0 0.2rem; padding: 0; }
  .pa-ped-items li {
    font-size: 0.92rem; font-weight: 600; color: var(--pa-cream);
    padding: 0.28rem 0; border-bottom: 1px dashed var(--pa-line);
  }
  .pa-ped-items li:last-child { border-bottom: none; }
  .pa-ped-fmt {
    font-size: 0.62rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em;
    padding: 0.12rem 0.45rem; border-radius: 999px; margin-left: 0.3rem;
    background: rgba(183, 157, 230, 0.16); color: var(--pa-violet);
  }
  .pa-ped-actions {
    display: flex; flex-direction: column; align-items: stretch; justify-content: center;
    gap: 0.45rem; flex-shrink: 0;
  }
  .pa-ped-actions .pa-btn-ghost { border-style: solid; }
  .pa-ped-actions .is-danger { color: var(--pa-danger); }
  .pa-ped-actions .is-danger:hover { border-color: var(--pa-danger); }
  .pa-socio-badge.is-done { background: rgba(183, 157, 230, 0.16); color: var(--pa-violet); }
  .pa-socio-badge.is-off { background: rgba(242, 129, 138, 0.12); color: var(--pa-danger); }

  /* ── Pestañas: sticky con íconos ── */
  .pa-tabs { position: sticky; top: 0; z-index: 30; background: rgba(19, 13, 28, 0.97); }
  .pa-tab { display: inline-flex; align-items: center; gap: 0.45rem; touch-action: manipulation; }
  .pa-tab svg { width: 16px; height: 16px; flex-shrink: 0; }
  .pa-ped-dot.is-warn { background: var(--pa-danger); color: #fff; }

  /* ── Franja resumen (chips navegables) ── */
  .pa-stats { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.3rem; }
  .pa-stat {
    background: var(--pa-card); border: 1px solid var(--pa-line); border-radius: 999px;
    padding: 0.4rem 0.95rem; font-family: var(--font-ui); font-size: 0.78rem;
    color: var(--pa-muted); cursor: pointer; touch-action: manipulation;
    transition: border-color 0.15s ease;
  }
  .pa-stat:hover { border-color: var(--pa-violet); color: var(--pa-cream); }
  .pa-stat strong { font-weight: 800; font-variant-numeric: tabular-nums; color: var(--pa-cream); margin-right: 0.15rem; }
  .pa-stat strong.is-green { color: var(--pa-green); }
  .pa-stat strong.is-violet { color: var(--pa-violet); }

  /* ── Productos ── */
  .pa-cat { margin: 0 0 2rem; }
  .pa-cat-head { display: flex; align-items: baseline; gap: 0.8rem; margin-bottom: 0.9rem; flex-wrap: wrap; }
  .pa-cat-title { font-family: var(--font-display); font-weight: 500; font-size: 1.3rem; color: var(--pa-cream); margin: 0; }
  .pa-cat-head .pa-count { margin-left: 0; }
  .pa-cat-head .pa-prod-add { margin-left: auto; margin-top: 0; }
  .pa-prods { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 0.9rem; }
  .pa-prod {
    background: var(--pa-card); border: 1px solid var(--pa-line); border-radius: 16px;
    padding: 0.9rem; display: grid; grid-template-columns: 76px 1fr 28px; gap: 0.8rem;
    align-items: start;
  }
  .pa-prod-foto {
    position: relative; width: 76px; height: 76px; border-radius: 12px; overflow: hidden;
    background: var(--pa-card-2); border: 1px solid var(--pa-line);
  }
  .pa-prod-foto img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pa-prod-fotoph { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; color: var(--pa-muted); }
  .pa-prod-fotoph svg { width: 30px; height: 30px; }
  .pa-prod-fotobtn {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    font-size: 1.15rem; cursor: pointer; opacity: 0; background: rgba(19, 13, 28, 0.55);
    transition: opacity 0.15s ease;
  }
  .pa-prod-foto:hover .pa-prod-fotobtn, .pa-prod-fotobtn:focus-visible { opacity: 1; }
  .pa-prod-main { display: flex; flex-direction: column; gap: 0.45rem; min-width: 0; }
  .pa-prod-label { font-weight: 700; }
  .pa-prod-detalle { font-size: 0.8rem; color: var(--pa-muted); }
  .pa-precio { display: flex; align-items: center; gap: 0.4rem; }
  .pa-precio-sym { color: var(--pa-green); font-weight: 800; }
  .pa-precio-input {
    width: 110px; text-align: right; font-weight: 800;
    font-variant-numeric: tabular-nums; color: var(--pa-green);
  }
