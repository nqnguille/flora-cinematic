---
import Layout from '../../layouts/Layout.astro'
import '../../styles/global.css'

const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || ''
---

<Layout
  title="Carta de genéticas — solo socios | Flora ONG"
  description="Stock de genéticas disponible, exclusivo para socios verificados de Flora."
  noindex={true}
>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet" />
  <main class="gn-main">
    <!-- ── Login ── -->
    <div id="gn-login" class="gn-login">
      <div class="gn-login-card">
        <div class="gn-brand">
          <svg class="gn-brand-leaf" viewBox="0 0 32 32" fill="none" aria-hidden="true"><path d="M16 6C16 6 10 10 10 17C10 20.3137 12.6863 23 16 23C19.3137 23 22 20.3137 22 17C22 10 16 6 16 6Z" fill="currentColor"/><line x1="16" y1="22" x2="16" y2="27" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span class="gn-brand-name">Flora <em>club</em></span>
        </div>
        <h1 class="gn-title">Carta de <em>genéticas</em></h1>
        <p class="gn-sub">
          Acá vas a encontrar el stock de flores y prerolls del club, en vivo. Elegís,
          reservamos tu lugar, y coordinás el retiro y tu aporte en la sede — por acá
          no se cobra nada.
        </p>
        <div id="g_id_button"></div>
        <p class="gn-privacy-note">
          Vamos a pedirte tu nombre, foto y email de Google para identificarte como socio.
          <button type="button" class="gn-tos-linkbtn gn-tos-open">Leer los términos completos</button>
        </p>
        <p id="gn-login-msg" class="gn-msg" hidden></p>
        <a href="/" class="gn-back">← Volver al sitio</a>
      </div>
    </div>

    <!-- ── Carta (fullscreen · carrusel) ── -->
    <div id="gn-content" class="gn-content" hidden>
      <div class="gn-topbar">
        <img class="gn-logo" src="/img/flora-logo-white.png" alt="Flora" width="1472" height="298" />
        <div class="gn-filters">
          <div id="gn-seg" class="gn-seg" role="group" aria-label="Formato"></div>
          <div id="gn-dd-tipo" class="gn-dd" data-dim="tipo"></div>
          <div id="gn-dd-efecto" class="gn-dd" data-dim="efecto"></div>
          <div id="gn-dd-sabor" class="gn-dd" data-dim="sabor"></div>
        </div>
        <div class="gn-topbar-right">
        <div class="gn-ctrls" role="group" aria-label="Control del carrusel">
          <button id="gn-prev" class="gn-ctrl" type="button" aria-label="Anterior"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 5-7 7 7 7"/></svg></button>
          <button id="gn-playpause" class="gn-ctrl gn-ctrl-pp" type="button" aria-label="Pausar"><svg class="ic-pause" viewBox="0 0 24 24" fill="currentColor"><rect x="6.5" y="5" width="3.7" height="14" rx="1"/><rect x="13.8" y="5" width="3.7" height="14" rx="1"/></svg><svg class="ic-play" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5.2v13.6l10.5-6.8z"/></svg></button>
          <button id="gn-next" class="gn-ctrl" type="button" aria-label="Siguiente"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 5 7 7-7 7"/></svg></button>
          <button id="gn-fs" class="gn-ctrl gn-ctrl-fs" type="button" aria-label="Pantalla completa"><svg class="ic-expand" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 9V5a1 1 0 0 1 1-1h4M20 9V5a1 1 0 0 0-1-1h-4M4 15v4a1 1 0 0 0 1 1h4M20 15v4a1 1 0 0 0-1 1h-4"/></svg><svg class="ic-compress" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 4v3a2 2 0 0 1-2 2H4M15 4v3a2 2 0 0 0 2 2h3M9 20v-3a2 2 0 0 0-2-2H4M15 20v-3a2 2 0 0 1 2-2h3"/></svg></button>
        </div>
        <button id="gn-logout" class="gn-logout" type="button" aria-label="Cerrar sesión">Salir</button>
        </div>
      </div>

      <div id="gn-grid" class="gn-track" aria-label="Carrusel de genéticas"></div>

      <footer class="gn-pagefoot">
        <p class="gn-disclaimer"><strong>Asociación Civil Cann de Cannabis Medicinal</strong> · I.G.J. 1994128 · Ley 27.350/REPROCANN. Reservás acá; abonás y retirás en el club. <button type="button" class="gn-tos-linkbtn gn-tos-open">Ver términos completos</button></p>
      </footer>

      <!-- ── Barra de reserva (flotante) ── -->
      <div id="gn-cartbar" class="gn-cartbar" hidden>
        <span id="gn-cartbar-txt" class="gn-cartbar-txt"></span>
        <button id="gn-cartbar-btn" class="gn-btn-primary" type="button">Revisar reserva</button>
      </div>

      <!-- ── Modal de reserva ── -->
      <div id="gn-modal" class="gn-modal" hidden>
        <div class="gn-modal-card" role="dialog" aria-modal="true" aria-labelledby="gn-modal-title">
          <h2 id="gn-modal-title" class="gn-modal-title">Tu <em>reserva</em></h2>
          <div id="gn-modal-body"></div>
          <p id="gn-modal-msg" class="gn-modal-msg" hidden></p>
          <div id="gn-modal-actions" class="gn-modal-actions"></div>
        </div>
      </div>
    </div>

    <!-- ── Términos de uso (login y footer lo abren en modo "view";
         el login lo abre en modo "accept" cuando el socio todavía no aceptó
         la versión vigente) ── -->
    <div id="gn-tos-modal" class="gn-modal" hidden>
      <div class="gn-modal-card gn-tos-card" role="dialog" aria-modal="true" aria-labelledby="gn-tos-title">
        <h2 id="gn-tos-title" class="gn-modal-title">Términos de <em>uso</em></h2>
        <div class="gn-tos-body">
          <p class="gn-tos-meta">Última actualización: 5 de julio de 2026</p>

          <h3>1. Quién puede usar esta carta</h3>
          <p>Esta carta es exclusiva para socios y socias <strong>mayores de 18 años</strong> de la Asociación Civil Cann de Cannabis Medicinal, con vínculo asociativo vigente y en el marco del programa REPROCANN (Ley 27.350). Al aceptar estos términos, declarás ser mayor de edad.</p>

          <h3>2. Qué es (y qué no es) este servicio</h3>
          <p>Acá reservás flores y prerolls disponibles en el club. <strong>No es una tienda online:</strong> no procesamos pagos ni hacemos envíos por este sitio. Tu aporte y el retiro de lo reservado siempre se coordinan en persona, en la sede del club.</p>

          <h3>3. Tus datos personales</h3>
          <p>Para identificarte usamos el inicio de sesión con tu cuenta de Google, de donde tomamos tu nombre, foto y email. Guardamos también el historial de tus reservas para poder atenderte. Cuando reservás, le avisamos al equipo del club por WhatsApp usando un servicio de mensajería de terceros — solo se comparte el contenido de la reserva, nunca tu email ni tus datos personales. No vendemos ni compartimos tus datos con nadie más.</p>

          <h3>4. Tus derechos sobre tus datos</h3>
          <p>Conforme la Ley 25.326 de Protección de Datos Personales, en cualquier momento podés pedirnos acceder, corregir o eliminar tus datos, o dar de baja tu cuenta de la carta, escribiéndonos por WhatsApp.</p>

          <h3>5. La información del catálogo es orientativa</h3>
          <p>THC, CBD y demás datos publicados son de referencia y pueden variar de lote a lote. Las fotos son ilustrativas —gentileza de los bancos de semillas de las genéticas que cultivamos— y no reflejan necesariamente la cosecha exacta que vas a retirar. Nada de lo publicado acá reemplaza la indicación de tu médica o médico tratante.</p>

          <h3>6. Disponibilidad y baja del servicio</h3>
          <p>La disponibilidad de cada genética puede cambiar entre tu reserva y el retiro; te avisamos si hay cambios. El club puede, a su criterio, dar de baja el acceso de un socio a la carta ante un uso indebido del servicio.</p>

          <h3>7. Cambios a estos términos</h3>
          <p>Podemos actualizar este texto. Si el cambio es importante, te vamos a pedir que lo aceptes de nuevo la próxima vez que entres.</p>

          <h3>8. Ley aplicable</h3>
          <p>Estos términos se rigen por las leyes de la República Argentina. Ante cualquier consulta, escribinos por <a href="https://wa.me/5492996375723" target="_blank" rel="noopener">WhatsApp</a>.</p>
        </div>
        <label id="gn-tos-acceptrow" class="gn-tos-check" hidden>
          <input type="checkbox" id="gn-tos-checkbox" />
          <span>Leí y acepto estos términos</span>
        </label>
        <p id="gn-tos-msg" class="gn-modal-msg" hidden></p>
        <div class="gn-modal-actions">
          <button id="gn-tos-close" class="gn-btn-ghost" type="button">Cerrar</button>
          <button id="gn-tos-accept" class="gn-btn-primary" type="button" hidden disabled>Aceptar y continuar</button>
        </div>
      </div>
    </div>
  </main>

  <script src="https://accounts.google.com/gsi/client" async defer is:inline></script>
  <script src="/socios/icons.js" is:inline></script>
  <script src="/socios/bancos.js" is:inline></script>
  <script define:vars={{ googleClientId }}>
    function escapeHtml(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]))
    }

    const TIPO_LABEL = { sativa: 'Sativa', indica: 'Indica', hibrida: 'Híbrida', cbd: 'Full CBD' }
    const LEAF_SVG = '<svg viewBox="0 0 32 32" fill="none" aria-hidden="true"><path d="M16 6C16 6 10 10 10 17C10 20.3137 12.6863 23 16 23C19.3137 23 22 20.3137 22 17C22 10 16 6 16 6Z" fill="currentColor"/><line x1="16" y1="22" x2="16" y2="27" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>'

    // Formatos: FLORES = "bud con hojitas" (elegido por Guille, ronda 3 del selector):
    // nug festoneado de cálices + tricomas + sugar leaves en la base + tallito.
    const ICON_FLOR = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5A2.4 2.4 0 0 1 16 7A2.4 2.4 0 0 1 17.5 11A2.4 2.4 0 0 1 16.3 15.2A2.5 2.5 0 0 1 13.2 17.8A2.2 2.2 0 0 1 9.6 17.4A2.3 2.3 0 0 1 6.8 14.6A2.4 2.4 0 0 1 6.4 10.4A2.5 2.5 0 0 1 8.6 6.6A2.2 2.2 0 0 1 12 5Z"/><path d="M8.4 17.6Q6.4 19 4.2 18.3Q5.2 16.2 7.4 15.9"/><path d="M15.6 17.6Q17.6 19 19.8 18.3Q18.8 16.2 16.6 15.9"/><path d="M12 18.6V21.2"/><circle cx="10.4" cy="9" r="0.95" fill="currentColor" stroke="none"/><circle cx="13.8" cy="8.6" r="0.95" fill="currentColor" stroke="none"/><circle cx="11.6" cy="12.2" r="0.95" fill="currentColor" stroke="none"/><circle cx="14.4" cy="13" r="0.95" fill="currentColor" stroke="none"/></svg>'
    // Mismo diseño de cono, redibujado a caja plena y MÁS LARGO (pedido de Guille):
    // ocupa todo el alto del viewBox, sin necesitar compensación de escala en CSS.
    const ICON_PREROLL = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10.4 21.4 9.1 7Q9 5.9 9.9 5.5L14.1 5.5Q15 5.9 14.9 7L13.6 21.4Q13.5 22.3 12 22.3Q10.5 22.3 10.4 21.4Z"/><path d="M10.6 18.5Q12 17.8 13.4 18.5"/><path d="M9.9 5.5Q12 3.2 14.1 5.5" fill="currentColor"/></svg>'
    const FORMATO = {
      flor: { label: 'Flores', svg: ICON_FLOR },
      preroll: { label: 'Preroll', svg: ICON_PREROLL },
    }

    // Formatos de una genética; por compatibilidad, sin dato = ['flor'].
    function formatosDe(g) {
      return Array.isArray(g.formatos) && g.formatos.length ? g.formatos : ['flor']
    }

    let allGeneticas = []
    // Cada dimensión es un Set: multi-selección (OR dentro de la dimensión, AND entre dimensiones).
    const filters = { q: '', tipo: new Set(), formato: new Set(), efecto: new Set(), sabor: new Set() }

    /* ── Helpers de datos ── */

    // "70% Sativa | 30% Indica" → { sativa: 70, indica: 30 } (null si no se puede leer)
    function parsePredominancia(pred) {
      if (!pred) return null
      const s = /(\d+)\s*%\s*sativa/i.exec(pred)
      const i = /(\d+)\s*%\s*indica/i.exec(pred)
      if (!s && !i) return null
      const sat = s ? Number(s[1]) : 100 - Number(i[1])
      return { sativa: sat, indica: 100 - sat }
    }

    // "25% THC" → 25 (null si no es un porcentaje legible, ej. "1:1")
    function parsePct(v) {
      const m = /([\d.]+)\s*%/.exec(String(v ?? ''))
      return m ? Number(m[1]) : null
    }

    /* ── Piezas de la tarjeta ── */

    // Predominancia genética sin números: "Predominancia sativa | Silver River"
    // Entre 40 y 60% sativa se considera equilibrada.
    function predGenetica(g) {
      const p = parsePredominancia(g.predominancia)
      if (p) {
        if (p.sativa > 60) return 'Predominancia sativa'
        if (p.sativa < 40) return 'Predominancia índica'
        return 'Híbrida equilibrada'
      }
      return TIPO_LABEL[g.tipo] || g.tipo || ''
    }

    function infoLine(g) {
      const gen = `<span class="gn-gen">${escapeHtml(predGenetica(g))}</span>`
      const banco = g.banco ? `<p class="gn-bank-line">${escapeHtml(g.banco)}</p>` : ''
      return `<p class="gn-info">${gen}</p>${banco}<span class="gn-rule"></span>`
    }

    // Medidor de cannabinoides: barra sin números. Sin dato → slot "—"
    // para que todas las tarjetas conserven la misma geometría.
    // IMPORTANTE: THC y CBD comparten la misma escala dentro de la tarjeta,
    // así los anchos relativos son comparables entre sí.
    function meter(label, rawValue, scaleMax) {
      const pct = parsePct(rawValue)
      if (pct === null) {
        return `<div class="gn-meter"><span class="gn-meter-label">${label}</span><span class="gn-meter-raw">—</span></div>`
      }
      const w = Math.min(100, Math.max(3, (pct / scaleMax) * 100))
      return `
        <div class="gn-meter">
          <span class="gn-meter-label">${label}</span>
          <div class="gn-meter-track"><span class="gn-meter-fill" style="width:${w}%"><i class="gn-meter-knob"></i></span></div>
        </div>`
    }

    // Ítems de círculo (icono + etiqueta) de una categoría. La etiqueta sale del
    // texto libre ("Mermelada cítrica | Skittlez de uva") si la cantidad coincide
    // con los iconos; si no, se usa la etiqueta genérica del icono.
    function circleItems(category, keys, texto) {
      if (!keys || !keys.length) return []
      const segments = String(texto || '')
        .split(/[|·]/)
        .map((s) => s.trim())
        .filter(Boolean)
      const useSegments = segments.length === keys.length
      return keys
        .map((key, idx) => {
          const def = (window.FLORA_TAG_ICONS[category] || {})[key]
          if (!def) return ''
          const label = useSegments ? segments[idx] : def.label
          return `
            <div class="gn-circle-item">
              <span class="gn-circle">${def.svg}</span>
              <span class="gn-circle-label">${escapeHtml(label)}</span>
            </div>`
        })
        .filter(Boolean)
    }

    // Un grupo (efecto o sabor) con su etiqueta de referencia y sus círculos.
    function circleGroup(labelText, items) {
      if (!items.length) return ''
      return `<div class="gn-circle-group"><span class="gn-circle-grouplabel">${labelText}</span><div class="gn-circle-cluster">${items.join('')}</div></div>`
    }

    // Los 4 iconos en una fila: efectos | sabores, con separador en el medio.
    function circleStrip(g) {
      const groups = [
        circleGroup('Efectos', circleItems('efecto', g.efectos, g.efectoTexto)),
        circleGroup('Sabores', circleItems('sabor', g.sabores, g.saborTexto)),
      ].filter(Boolean)
      if (!groups.length) return ''
      return `<div class="gn-circle-row">${groups.join('<span class="gn-circle-sep"></span>')}</div>`
    }

    // Steppers de reserva: una pastilla por formato (flor en gramos, preroll en
    // unidades), en fila propia debajo de una etiqueta — así entran aun con los
    // dos formatos en la tarjeta más angosta.
    function orderStrip(g) {
      const pills = formatosDe(g)
        .filter((f) => FORMATO[f])
        .map((f) => {
          const key = `${g.id}|${f}`
          return `
            <div class="gn-qty is-${f}" data-order="${escapeHtml(key)}">
              <span class="gn-qty-ic" title="${FORMATO[f].label}">${FORMATO[f].svg}</span>
              <span class="gn-qty-val">0</span>
              <span class="gn-qty-steps">
                <button class="gn-qty-btn" type="button" data-q="1" aria-label="Agregar ${FORMATO[f].label}">+</button>
                <button class="gn-qty-btn" type="button" data-q="-1" aria-label="Quitar ${FORMATO[f].label}">−</button>
              </span>
            </div>`
        })
        .join('')
      return pills ? `<div class="gn-order"><span class="gn-order-label">Reservar</span><div class="gn-order-pills">${pills}</div></div>` : ''
    }

    function card(g, idx) {
      const tipo = ['sativa', 'indica', 'hibrida', 'cbd'].includes(g.tipo) ? g.tipo : 'hibrida'
      // Foto por convención: /socios/geneticas/<id>.webp — si falla, la tarjeta
      // cae al placeholder de marca (la hoja) manteniendo la geometría. `g.foto`
      // (URL cargada desde el admin) tiene prioridad.
      const fotoSrc = g.foto || (g.id ? `/socios/geneticas/${g.id}.webp` : '')
      const delay = Math.min(idx || 0, 8) * 45
      // Escala compartida THC/CBD: 0-30 salvo que ambos sean bajos (0-5)
      const vThc = parsePct(g.thc) ?? 0
      const vCbd = parsePct(g.cbd) ?? 0
      const scaleMax = Math.max(vThc, vCbd) <= 5 ? 5 : 30
      // Sellos circulares: Flores (izquierda) y Preroll (derecha), solo icono.
      const seals = formatosDe(g)
        .map((f) => FORMATO[f] ? `<span class="gn-seal gn-seal-${f}" title="${FORMATO[f].label}" aria-label="${FORMATO[f].label}">${FORMATO[f].svg}</span>` : '')
        .join('')
      return `
        <article class="gn-item" data-tipo="${tipo}" style="--d:${delay}ms">
          <div class="gn-item-hero${fotoSrc ? '' : ' is-nophoto'}">
            ${fotoSrc ? `<img class="gn-item-img" src="${escapeHtml(fotoSrc)}" alt="${escapeHtml(g.nombre)}" loading="lazy" onerror="this.remove();this.closest('.gn-item-hero').classList.add('is-nophoto')" />` : ''}
            <span class="gn-item-watermark">${LEAF_SVG}</span>
            ${seals}
            <h3 class="gn-item-name">${escapeHtml(g.nombre)}</h3>
          </div>
          <div class="gn-item-body">
            <div class="gn-head">${infoLine(g)}</div>
            <div class="gn-meters">
              ${meter('THC', g.thc, scaleMax)}
              ${meter('CBD', g.cbd, scaleMax)}
            </div>
            ${circleStrip(g)}
            ${orderStrip(g)}
          </div>
        </article>`
    }

    /* ── Filtros ── */

    function matches(g) {
      if (filters.tipo.size && !filters.tipo.has(g.tipo)) return false
      if (filters.formato.size && !formatosDe(g).some((f) => filters.formato.has(f))) return false
      if (filters.efecto.size && !(g.efectos || []).some((e) => filters.efecto.has(e))) return false
      if (filters.sabor.size && !(g.sabores || []).some((s) => filters.sabor.has(s))) return false
      if (filters.q) {
        const hay = `${g.nombre} ${g.banco || ''}`.toLowerCase()
        if (!hay.includes(filters.q)) return false
      }
      return true
    }

    /* ── Carrusel: auto-deslizante + controles (pausa / adelantar / rebobinar) ── */
    const SPEED = 0.55 // px por frame
    let loopOffset = 0   // ancho de una copia (para el loop sin costura)
    let singleCount = 0  // tarjetas de UNA copia
    let pendingRecenter = false
    let userPaused = false   // pausa explícita (botón)
    let hoverPaused = false  // pausa temporal (mouse encima / arrastrando)
    let touchPaused = false  // pausa temporal (touch/wheel/prev/next reciente)
    let resumeTimer = null
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    function measure() {
      const track = document.getElementById('gn-grid')
      const secondCopyStart = track.children[singleCount]
      loopOffset = secondCopyStart ? secondCopyStart.offsetLeft : 0
      // Arrancamos en la 2ª copia para poder rebobinar sin toparse con el borde.
      if (pendingRecenter && loopOffset > 0) { track.scrollLeft = loopOffset; pendingRecenter = false }
      fitNames(track)
    }

    // Tamaño del nombre según el ANCHO REAL de la card (no del viewport): grande y
    // protagonista en cualquier pantalla, con la palabra más larga entrando en 1 línea.
    // Tamaño del nombre POR TARJETA: se agranda hasta que su palabra más larga
    // llena el ancho. Nombres cortos → enormes (tope); largos → se agrandan y
    // wrapean a 2-3 líneas. Mide con canvas en la fuente real (Bebas).
    function fitNames(track) {
      const first = track.querySelector('.gn-item')
      if (!first) return
      const w = first.getBoundingClientRect().width || first.clientWidth
      if (!w) { requestAnimationFrame(() => fitNames(track)); return } // aún sin layout: reintentar
      const usable = w - 22       // menos el padding lateral del nombre
      // En mobile el nombre cede protagonismo a la foto (hero más chico)
      const SHRINK = window.innerWidth <= 760 ? 0.6 : 0.8
      const ctx = (fitNames._c || (fitNames._c = document.createElement('canvas'))).getContext('2d')
      ctx.font = '100px "Bebas Neue", sans-serif'
      // TODAS al mismo tamaño: el de "TROPICANA" (una palabra de ancho medio).
      // Las palabras más largas (WATERMELON) igual entran a este tamaño.
      const refW = ctx.measureText('TROPICANA').width
      const fs = ((usable * 100) / refW) * SHRINK
      track.querySelectorAll('.gn-item-name').forEach((el) => { el.style.fontSize = fs + 'px' })
    }

    function pauseTouchSoon(delay) {
      touchPaused = true
      clearTimeout(resumeTimer)
      resumeTimer = setTimeout(() => { touchPaused = false }, delay || 4000)
    }

    function stepAmount(track) {
      const item = track.querySelector('.gn-item')
      const w = item ? item.getBoundingClientRect().width : 320
      return w + 20
    }

    let carouselStarted = false
    function startCarousel() {
      if (carouselStarted) return
      carouselStarted = true
      const track = document.getElementById('gn-grid')
      const playpause = document.getElementById('gn-playpause')

      // Recalcular el tamaño de los nombres cuando Bebas terminó de cargar
      // (el canvas mide bien recién ahí).
      if (document.fonts && document.fonts.ready) document.fonts.ready.then(() => fitNames(track))

      track.addEventListener('mouseenter', () => { hoverPaused = true })
      track.addEventListener('mouseleave', () => { hoverPaused = false })
      track.addEventListener('touchstart', () => { touchPaused = true; clearTimeout(resumeTimer) }, { passive: true })
      track.addEventListener('touchend', () => pauseTouchSoon(4000), { passive: true })
      track.addEventListener('wheel', () => pauseTouchSoon(4000), { passive: true })
      track.addEventListener('focusin', () => pauseTouchSoon(8000))
      window.addEventListener('resize', () => requestAnimationFrame(measure))

      // Arrastrar con el mouse para mover el carrusel a gusto
      // (salvo desde el stepper de reserva: ahí el gesto es tocar, no arrastrar)
      let dragging = false, lastX = 0
      track.addEventListener('pointerdown', (e) => {
        if (e.pointerType !== 'mouse' || e.target.closest('.gn-qty')) return
        dragging = true; lastX = e.clientX; track.classList.add('is-grabbing')
      })
      window.addEventListener('pointermove', (e) => {
        if (!dragging) return
        track.scrollLeft -= (e.clientX - lastX); lastX = e.clientX
      })
      window.addEventListener('pointerup', () => {
        if (!dragging) return
        dragging = false; track.classList.remove('is-grabbing')
      })

      // Adelantar / rebobinar de a una tarjeta
      document.getElementById('gn-prev').addEventListener('click', () => {
        track.scrollLeft -= stepAmount(track); pauseTouchSoon(4000)
      })
      document.getElementById('gn-next').addEventListener('click', () => {
        track.scrollLeft += stepAmount(track); pauseTouchSoon(4000)
      })
      // Pausa / reproducir explícito
      playpause.addEventListener('click', () => {
        userPaused = !userPaused
        playpause.classList.toggle('is-paused', userPaused)
        playpause.setAttribute('aria-label', userPaused ? 'Reproducir' : 'Pausar')
      })

      // Pantalla completa
      const fsBtn = document.getElementById('gn-fs')
      fsBtn.addEventListener('click', () => {
        if (document.fullscreenElement) document.exitFullscreen()
        else document.documentElement.requestFullscreen().catch(() => {})
      })
      document.addEventListener('fullscreenchange', () => {
        const on = !!document.fullscreenElement
        fsBtn.classList.toggle('is-fs', on)
        fsBtn.setAttribute('aria-label', on ? 'Salir de pantalla completa' : 'Pantalla completa')
      })

      function frame() {
        if (loopOffset > 0) {
          // Con ítems en el carrito el carrusel no avanza solo: el socio está
          // armando su reserva y la marquesina ya cumplió su rol.
          if (!userPaused && !hoverPaused && !touchPaused && !reduceMotion && !cart.size) {
            track.scrollLeft += SPEED
          }
          // Loop infinito en ambos sentidos: mantener en [loopOffset, 2·loopOffset)
          if (track.scrollLeft < loopOffset) track.scrollLeft += loopOffset
          else if (track.scrollLeft >= loopOffset * 2) track.scrollLeft -= loopOffset
        }
        requestAnimationFrame(frame)
      }
      requestAnimationFrame(frame)
    }

    function applyFilters() {
      const list = allGeneticas.filter(matches)
      const track = document.getElementById('gn-grid')

      if (!list.length) {
        singleCount = 0
        loopOffset = 0
        track.scrollLeft = 0
        track.innerHTML = `<p class="gn-empty">${allGeneticas.length === 0 ? 'No hay genéticas cargadas por el momento.' : 'Ninguna genética coincide con esos filtros.'}${filters.formato.size ? ' <button id="gn-empty-reset" class="gn-btn-ghost" type="button">Ver todas</button>' : ''}</p>`
      } else {
        // Repetimos el listado con buffer a ambos lados para loop sin huecos y
        // poder rebobinar; el corte se hace al ancho de UNA copia.
        const copies = Math.max(3, Math.ceil((window.innerWidth * 2.4) / (list.length * 320)) + 1)
        let html = ''
        for (let c = 0; c < copies; c++) html += list.map((g, i) => card(g, i)).join('')
        track.innerHTML = html
        singleCount = list.length
        pendingRecenter = true
        requestAnimationFrame(measure)
        // Re-pintar las cantidades del carrito en las tarjetas recién renderizadas
        for (const key of cart.keys()) syncQty(key)
      }
    }

    /* ── Desplegables tildables (multi-selección con checkboxes) ── */
    const DIM_LABEL = { tipo: 'Predominancia', efecto: 'Efectos', sabor: 'Sabores' }
    const STATIC_OPTS = {
      tipo: [['sativa', 'Sativa'], ['indica', 'Indica'], ['hibrida', 'Híbrida'], ['cbd', 'Full CBD']],
    }

    // Selector de formato: LA decisión principal va en un segmentado grande
    // siempre visible. "Ver:" es etiqueta; Flores y Prerolls se prenden y
    // apagan de forma independiente (también las dos juntas). Sin nada
    // prendido se ve todo. Un formato sin genéticas activas se atenúa.
    let paintSeg = () => {}
    function renderSegFormato() {
      const el = document.getElementById('gn-seg')
      const counts = { flor: 0, preroll: 0 }
      for (const g of allGeneticas) for (const f of formatosDe(g)) if (f in counts) counts[f]++
      const opts = [
        ['flor', 'Flores', ICON_FLOR],
        ['preroll', 'Prerolls', ICON_PREROLL],
      ]
      el.innerHTML = '<span class="gn-seg-label">Ver:</span>' + opts
        .map(([val, lab, icon]) =>
          `<button class="gn-seg-btn is-${val}${!counts[val] ? ' is-empty' : ''}" type="button" data-formato="${val}" aria-pressed="false">${icon ? `<span class="gn-seg-ic">${icon}</span>` : ''}${lab}</button>`
        )
        .join('')
      paintSeg = () => {
        el.querySelectorAll('.gn-seg-btn').forEach((b) => {
          const on = filters.formato.has(b.dataset.formato)
          b.classList.toggle('is-active', on)
          b.setAttribute('aria-pressed', on)
        })
      }
      el.addEventListener('click', (e) => {
        const b = e.target.closest('.gn-seg-btn')
        if (!b || b.classList.contains('is-empty')) return
        const val = b.dataset.formato
        if (filters.formato.has(val)) filters.formato.delete(val)
        else filters.formato.add(val)
        paintSeg()
        applyFilters()
      })
      paintSeg()
    }

    function closeAllPanels(except) {
      document.querySelectorAll('.gn-dd-panel').forEach((p) => {
        if (p !== except) {
          p.hidden = true
          const t = p.previousElementSibling
          if (t) t.classList.remove('is-open')
        }
      })
    }
    document.addEventListener('click', () => closeAllPanels(null))

    function updateDdCount(dim) {
      const el = document.getElementById('gn-dd-' + dim)
      const n = filters[dim].size
      const c = el.querySelector('.gn-dd-count')
      if (n === 0) { c.textContent = 'Todos'; c.classList.add('is-all') }
      else { c.textContent = n; c.classList.remove('is-all') }
      el.querySelector('.gn-dd-toggle').classList.toggle('has-sel', n > 0)
    }

    function renderDropdown(dim, options) {
      const el = document.getElementById('gn-dd-' + dim)
      if (!options.length) { el.hidden = true; return }
      el.hidden = false
      const allChecked = filters[dim].size === 0 ? 'checked' : ''
      const allRow = `<label class="gn-dd-opt gn-dd-all"><input type="checkbox" class="gn-dd-allcb" ${allChecked} /><span class="gn-dd-check"></span>Todos</label><div class="gn-dd-divider"></div>`
      const opts = options
        .map(([val, lab]) => {
          const checked = filters[dim].has(val) ? 'checked' : ''
          return `<label class="gn-dd-opt"><input type="checkbox" class="gn-dd-cb" value="${escapeHtml(val)}" ${checked} /><span class="gn-dd-check"></span>${escapeHtml(lab)}</label>`
        })
        .join('')
      el.innerHTML = `
        <button class="gn-dd-toggle" type="button">
          <span class="gn-dd-name">${DIM_LABEL[dim]}</span>
          <span class="gn-dd-count"></span>
          <svg class="gn-dd-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="gn-dd-panel" hidden>${allRow}${opts}</div>`
      const toggle = el.querySelector('.gn-dd-toggle')
      const panel = el.querySelector('.gn-dd-panel')
      const allcb = panel.querySelector('.gn-dd-allcb')
      toggle.addEventListener('click', (e) => {
        e.stopPropagation()
        const willOpen = panel.hidden
        closeAllPanels(willOpen ? panel : null)
        panel.hidden = !willOpen
        toggle.classList.toggle('is-open', willOpen)
      })
      panel.addEventListener('click', (e) => e.stopPropagation())

      // "Todos" = sin filtro. Tocarlo limpia la dimensión y destilda lo específico.
      allcb.addEventListener('change', () => {
        filters[dim].clear()
        panel.querySelectorAll('.gn-dd-cb').forEach((c) => { c.checked = false })
        allcb.checked = true
        updateDdCount(dim)
        applyFilters()
      })

      panel.querySelectorAll('.gn-dd-cb').forEach((cb) => {
        cb.addEventListener('change', () => {
          if (cb.checked) filters[dim].add(cb.value)
          else filters[dim].delete(cb.value)
          allcb.checked = filters[dim].size === 0
          updateDdCount(dim)
          applyFilters()
        })
      })
      updateDdCount(dim)
    }

    function buildFilters() {
      renderSegFormato()
      renderDropdown('tipo', STATIC_OPTS.tipo)
      const present = { efecto: new Set(), sabor: new Set() }
      for (const g of allGeneticas) {
        for (const e of g.efectos || []) present.efecto.add(e)
        for (const s of g.sabores || []) present.sabor.add(s)
      }
      const toOpts = (cat, set) =>
        [...set].sort().map((k) => [k, (window.FLORA_TAG_ICONS[cat] || {})[k]?.label || k])
      renderDropdown('efecto', toOpts('efecto', present.efecto))
      renderDropdown('sabor', toOpts('sabor', present.sabor))
    }

    /* ── Pedido (carrito + pedido activo) ── */
    const cart = new Map() // "id|formato" → cantidad
    let activePedido = null // pedido pendiente/listo del socio, si hay
    const QTY_MAX = { flor: 50, preroll: 20 }
    const ESTADO_TXT = {
      pendiente: 'Tu reserva está en preparación',
      listo: '¡Tu reserva está lista para retirar!',
    }

    function syncQty(key) {
      const n = cart.get(key) || 0
      document.querySelectorAll(`[data-order="${CSS.escape(key)}"]`).forEach((w) => {
        w.querySelector('.gn-qty-val').textContent = n
        w.classList.toggle('has-qty', n > 0)
      })
      updateCartBar()
    }

    function setPedidoMode() {
      document.getElementById('gn-content').classList.toggle('has-pedido', !!activePedido)
      updateCartBar()
    }

    function updateCartBar() {
      const bar = document.getElementById('gn-cartbar')
      const txt = document.getElementById('gn-cartbar-txt')
      const btn = document.getElementById('gn-cartbar-btn')
      if (activePedido) {
        bar.hidden = false
        bar.classList.toggle('is-listo', activePedido.estado === 'listo')
        txt.textContent = ESTADO_TXT[activePedido.estado] || 'Tenés una reserva en curso'
        btn.textContent = 'Ver reserva'
      } else if (cart.size) {
        let g = 0, u = 0
        for (const [k, c] of cart) k.endsWith('|flor') ? (g += c) : (u += c)
        bar.hidden = false
        bar.classList.remove('is-listo')
        txt.textContent = 'Tu reserva: ' + [g ? `${g} g de flores` : '', u ? `${u} preroll${u > 1 ? 's' : ''}` : ''].filter(Boolean).join(' + ')
        btn.textContent = 'Revisar reserva'
      } else {
        bar.hidden = true
      }
      // Con la barra visible, el pie reserva su alto: la barra no tapa ni los
      // steppers de las tarjetas ni el disclaimer legal.
      document.getElementById('gn-content').classList.toggle('has-cartbar', !bar.hidden)
    }

    function cartItems() {
      return [...cart.entries()].map(([key, cantidad]) => {
        const [id, formato] = key.split('|')
        const g = allGeneticas.find((x) => x.id === id)
        return { id, formato, cantidad, nombre: g ? g.nombre : id }
      })
    }
    function fmtItem(i) {
      return `${i.cantidad} ${i.formato === 'flor' ? 'g' : 'u'} — ${i.nombre}${i.formato === 'preroll' ? ' (preroll)' : ''}`
    }

    function stepQty(btn) {
      const key = btn.closest('.gn-qty').getAttribute('data-order')
      const formato = key.split('|')[1]
      const next = Math.min(QTY_MAX[formato] || 20, Math.max(0, (cart.get(key) || 0) + Number(btn.getAttribute('data-q'))))
      if (next === 0) cart.delete(key)
      else cart.set(key, next)
      syncQty(key)
      // Armando la reserva el carrusel espera mucho más (que no se lleve la tarjeta)
      pauseTouchSoon(20000)
    }

    // Tocar +/− en cualquier copia actualiza el carrito y TODAS las copias.
    // Mantener apretado repite (spinner): tras 400ms suma cada 90ms; el click
    // que dispara el pointerup post-hold se ignora con holdFired.
    let holdTimer = null, holdRepeat = null, holdFired = false
    function stopHold() { clearTimeout(holdTimer); clearInterval(holdRepeat); holdTimer = holdRepeat = null }
    const gridEl = document.getElementById('gn-grid')
    gridEl.addEventListener('click', (e) => {
      if (e.target.id === 'gn-empty-reset') {
        filters.formato.clear()
        paintSeg()
        applyFilters()
        return
      }
      const btn = e.target.closest('.gn-qty-btn')
      if (!btn) return
      if (holdFired) { holdFired = false; return }
      stepQty(btn)
    })
    gridEl.addEventListener('pointerdown', (e) => {
      const btn = e.target.closest('.gn-qty-btn')
      if (!btn) return
      stopHold()
      holdTimer = setTimeout(() => {
        holdFired = true
        stepQty(btn)
        holdRepeat = setInterval(() => stepQty(btn), 90)
      }, 400)
    })
    window.addEventListener('pointerup', stopHold)
    window.addEventListener('pointercancel', stopHold)

    /* ── Modal ── */
    function showModalMsg(text, isError) {
      const msg = document.getElementById('gn-modal-msg')
      msg.textContent = text
      msg.classList.toggle('is-error', !!isError)
      msg.hidden = false
    }

    function openModal(successText) {
      const body = document.getElementById('gn-modal-body')
      const actions = document.getElementById('gn-modal-actions')
      // La nota sobrevive al re-render (ej: al quitar un ítem de la lista)
      const prevNota = document.getElementById('gn-modal-nota')?.value || ''
      document.getElementById('gn-modal-msg').hidden = true
      if (activePedido) {
        const p = activePedido
        body.innerHTML = `
          <span class="gn-pedido-badge is-${escapeHtml(p.estado)}">${p.estado === 'listo' ? 'Lista para retirar' : 'En preparación'}</span>
          <ul class="gn-modal-list">${p.items.map((i) => `<li>${escapeHtml(fmtItem(i))}</li>`).join('')}</ul>
          ${p.nota ? `<p class="gn-modal-nota">Nota: ${escapeHtml(p.nota)}</p>` : ''}
          <p class="gn-modal-hint">${p.estado === 'listo' ? 'Acercate al club a retirarla. Recordá abonar tu cuota ahí — por el sitio no se cobra nada.' : 'Te avisamos apenas esté lista. El retiro y el pago de tu cuota son en el club.'}</p>`
        actions.innerHTML = `
          ${p.estado === 'pendiente' ? '<button id="gn-pedido-cancel" class="gn-btn-ghost" type="button">Cancelar reserva</button>' : ''}
          <button id="gn-modal-close" class="gn-btn-primary" type="button">Cerrar</button>`
      } else {
        const items = cartItems()
        if (!items.length) { closeModal(); return }
        body.innerHTML = `
          <ul class="gn-modal-list">${items
            .map((i) => `<li>${escapeHtml(fmtItem(i))}<button class="gn-modal-del" data-key="${escapeHtml(`${i.id}|${i.formato}`)}" type="button" aria-label="Quitar">×</button></li>`)
            .join('')}</ul>
          <textarea id="gn-modal-nota" class="gn-modal-textarea" placeholder="Nota para el club (opcional)" maxlength="400" rows="2">${escapeHtml(prevNota)}</textarea>
          <p class="gn-modal-hint">Esto es una <strong>reserva</strong>: te lo preparamos y lo retirás en el club, donde abonás tu cuota. Por el sitio no se cobra nada.</p>`
        actions.innerHTML = `
          <button id="gn-modal-close" class="gn-btn-ghost" type="button">Seguir mirando</button>
          <button id="gn-modal-send" class="gn-btn-primary" type="button">Confirmar reserva</button>`
      }
      document.getElementById('gn-modal').hidden = false
      if (successText) showModalMsg(successText, false)
      ;(document.getElementById('gn-modal-send') || document.getElementById('gn-modal-close'))?.focus()
    }
    function closeModal() { document.getElementById('gn-modal').hidden = true }
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !document.getElementById('gn-modal').hidden) closeModal()
    })

    async function sendPedido() {
      const btn = document.getElementById('gn-modal-send')
      btn.disabled = true
      btn.textContent = 'Enviando…'
      const nota = (document.getElementById('gn-modal-nota')?.value || '').trim()
      const items = cartItems().map(({ id, formato, cantidad }) => ({ id, formato, cantidad }))
      try {
        const res = await fetch('/api/socios/pedidos', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ items, nota }),
        })
        const data = await res.json()
        if (res.ok && data.ok) {
          const keys = [...cart.keys()]
          cart.clear()
          keys.forEach(syncQty)
          activePedido = data.pedido
          setPedidoMode()
          openModal('Reserva enviada ✓')
        } else if (res.status === 409 && data.activo) {
          activePedido = data.activo
          setPedidoMode()
          openModal()
          showModalMsg('Ya tenías una reserva en curso.', true)
        } else if (res.status === 401) {
          showModalMsg('Tu sesión venció — te llevamos al ingreso…', true)
          setTimeout(() => location.reload(), 1800)
        } else {
          btn.disabled = false
          btn.textContent = 'Confirmar reserva'
          showModalMsg(data.error || 'No se pudo enviar la reserva.', true)
        }
      } catch {
        btn.disabled = false
        btn.textContent = 'Confirmar reserva'
        showModalMsg('Error de red al enviar la reserva.', true)
      }
    }

    async function cancelPedido() {
      if (!activePedido || !confirm('¿Cancelar tu reserva?')) return
      try {
        const res = await fetch('/api/socios/pedidos', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ id: activePedido.id }),
        })
        const data = await res.json()
        if (res.ok && data.ok) {
          activePedido = null
          setPedidoMode()
          closeModal()
        } else if (res.status === 401) {
          showModalMsg('Tu sesión venció — te llevamos al ingreso…', true)
          setTimeout(() => location.reload(), 1800)
        } else {
          // Ej: el club ya la marcó lista → refrescar al estado real del servidor
          await loadPedidos()
          openModal()
          showModalMsg(data.error || 'No se pudo cancelar.', true)
        }
      } catch {
        showModalMsg('Error de red al cancelar.', true)
      }
    }

    document.getElementById('gn-cartbar-btn').addEventListener('click', () => openModal())
    document.getElementById('gn-modal').addEventListener('click', (e) => {
      if (e.target.id === 'gn-modal') { closeModal(); return } // clic afuera cierra
      if (e.target.id === 'gn-modal-close') closeModal()
      else if (e.target.id === 'gn-modal-send') sendPedido()
      else if (e.target.id === 'gn-pedido-cancel') cancelPedido()
      else if (e.target.classList.contains('gn-modal-del')) {
        cart.delete(e.target.getAttribute('data-key'))
        syncQty(e.target.getAttribute('data-key'))
        if (cart.size) openModal()
        else closeModal()
      }
    })

    async function loadPedidos() {
      try {
        const res = await fetch('/api/socios/pedidos', { credentials: 'include' })
        if (!res.ok) return
        const data = await res.json()
        activePedido = data.activo || null
        setPedidoMode()
      } catch { /* sin red no bloqueamos la carta */ }
    }

    /* ── Sesión ── */

    function showContent(list) {
      allGeneticas = list
      document.getElementById('gn-login').hidden = true
      document.getElementById('gn-content').hidden = false
      buildFilters()
      applyFilters()
      startCarousel()
      loadPedidos()
    }

    // El mensaje de "no sos socio" lleva un link de WhatsApp para resolverlo al toque
    function showLoginError(message) {
      const msg = document.getElementById('gn-login-msg')
      if (message === '__NOSOCIO__') {
        msg.innerHTML = 'Esa cuenta de Google todavía no figura como socia del club. Si ya sos socio, escribinos por <a href="https://wa.me/5492996375723" target="_blank" rel="noopener">WhatsApp</a> para habilitarte el acceso.'
      } else {
        msg.textContent = message
      }
      msg.hidden = false
    }

    async function loadGeneticas(email) {
      const res = await fetch('/api/socios/geneticas', { credentials: 'include' })
      if (!res.ok) return false
      const data = await res.json()
      showContent(data.geneticas || [])
      return true
    }

    /* ── Términos de uso: modal compartido por login (modo "accept") y por
       los links de "ver términos" del login/footer (modo "view") ── */
    let pendingCredential = null // credential de Google en espera mientras se muestra el modo "accept"
    let tosMode = 'view'

    function openTos(mode) {
      tosMode = mode
      const isAccept = mode === 'accept'
      document.getElementById('gn-tos-acceptrow').hidden = !isAccept
      document.getElementById('gn-tos-accept').hidden = !isAccept
      document.getElementById('gn-tos-checkbox').checked = false
      document.getElementById('gn-tos-accept').disabled = true
      document.getElementById('gn-tos-close').textContent = isAccept ? 'Ahora no' : 'Cerrar'
      document.getElementById('gn-tos-msg').hidden = true
      document.getElementById('gn-tos-modal').hidden = false
      document.querySelector('.gn-tos-body').scrollTop = 0
    }
    function closeTos() {
      document.getElementById('gn-tos-modal').hidden = true
      if (tosMode === 'accept') pendingCredential = null // cerrar sin aceptar cancela el login
    }
    document.addEventListener('click', (e) => {
      if (e.target.closest('.gn-tos-open')) openTos('view')
    })
    document.getElementById('gn-tos-close').addEventListener('click', closeTos)
    document.getElementById('gn-tos-modal').addEventListener('click', (e) => {
      if (e.target.id === 'gn-tos-modal') closeTos() // clic afuera cierra
    })
    document.getElementById('gn-tos-checkbox').addEventListener('change', (e) => {
      document.getElementById('gn-tos-accept').disabled = !e.target.checked
    })
    document.getElementById('gn-tos-accept').addEventListener('click', async () => {
      if (!pendingCredential) return
      const btn = document.getElementById('gn-tos-accept')
      btn.disabled = true
      btn.textContent = 'Confirmando…'
      await submitLogin(pendingCredential, true)
      btn.disabled = false
      btn.textContent = 'Aceptar y continuar'
    })

    async function submitLogin(credential, tosAccept) {
      try {
        const res = await fetch('/api/socios/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ credential, tosAccept: !!tosAccept }),
        })
        const data = await res.json()
        if (res.ok && data.ok) {
          pendingCredential = null
          document.getElementById('gn-tos-modal').hidden = true
          await loadGeneticas(data.email)
          return
        }
        if (data.needsTos) {
          pendingCredential = credential
          openTos('accept')
          return
        }
        if (res.status === 403) {
          showLoginError('__NOSOCIO__')
          return
        }
        // Error genuino (token inválido, etc.): si se disparó confirmando la
        // aceptación, el modal de términos sigue abierto y el mensaje va ahí;
        // si no, en la pantalla de login.
        if (tosAccept) {
          const msgEl = document.getElementById('gn-tos-msg')
          msgEl.textContent = data.error || 'No se pudo confirmar. Probá de nuevo.'
          msgEl.hidden = false
        } else {
          showLoginError(data.error || 'No se pudo verificar tu cuenta.')
        }
      } catch {
        if (tosAccept) {
          const msgEl = document.getElementById('gn-tos-msg')
          msgEl.textContent = 'Error de red. Probá de nuevo.'
          msgEl.hidden = false
        } else {
          showLoginError('Error de red al verificar con Google.')
        }
      }
    }

    window.handleGoogleCredential = (response) => submitLogin(response.credential, false)

    document.getElementById('gn-logout').addEventListener('click', async () => {
      await fetch('/api/socios/logout', { method: 'POST', credentials: 'include' })
      location.reload()
    })

    // Legal colapsado en mobile: tocarlo lo expande/colapsa (el link de términos
    // hace lo suyo aparte, no debe disparar el toggle de la línea).
    document.querySelector('.gn-disclaimer')?.addEventListener('click', (e) => {
      if (e.target.closest('.gn-tos-open')) return
      e.currentTarget.classList.toggle('is-open')
    })

    // Link directo a los términos (ej. compartido por WhatsApp): ?tos=1
    if (new URLSearchParams(location.search).get('tos') === '1') openTos('view')

    if (googleClientId) {
      window.onload = () => {
        google.accounts.id.initialize({
          client_id: googleClientId,
          callback: window.handleGoogleCredential,
        })
        google.accounts.id.renderButton(document.getElementById('g_id_button'), {
          theme: 'filled_black',
          size: 'large',
          text: 'signin_with',
        })
      }
    } else {
      showLoginError('Falta configurar el Google Client ID del sitio.')
    }

    loadGeneticas()
  </script>
</Layout>

