---
import Layout from '../../layouts/Layout.astro'
import '../../styles/global.css'

const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || ''
---

<Layout
  title="Extracciones — reservas para socios | Flora ONG"
  description="Reservá extracciones de Flora. Exclusivo para socios verificados."
  noindex={true}
>
  <link rel="stylesheet" href="/socios/tienda.css" />
  <main class="td-main">
    <!-- ── Login ── -->
    <div id="td-login" class="td-login">
      <div class="td-login-card">
        <div class="td-brand"><svg viewBox="0 0 32 32" fill="none" aria-hidden="true"><path d="M16 6C16 6 10 10 10 17C10 20.3137 12.6863 23 16 23C19.3137 23 22 20.3137 22 17C22 10 16 6 16 6Z" fill="currentColor"/><line x1="16" y1="22" x2="16" y2="27" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg><span class="td-brand-name">Flora <em>club</em></span></div>
        <h1 class="td-title">Nuestras <em>extracciones</em></h1>
        <p class="td-sub">
          Sección exclusiva para socios verificados. Ingresá con la cuenta de Google
          que registraste como socio para ver precios y reservar.
        </p>
        <div id="g_id_button"></div>
        <p id="td-login-msg" class="td-msg" hidden></p>
        <a href="/socios/" class="td-back">← Volver al portal</a>
      </div>
    </div>

    <!-- ── Tienda ── -->
    <div id="td-content" class="td-content" hidden>
      <div class="td-head">
        <a href="/socios/" class="td-back">← Portal</a>
        <div class="td-brand"><svg viewBox="0 0 32 32" fill="none" aria-hidden="true"><path d="M16 6C16 6 10 10 10 17C10 20.3137 12.6863 23 16 23C19.3137 23 22 20.3137 22 17C22 10 16 6 16 6Z" fill="currentColor"/><line x1="16" y1="22" x2="16" y2="27" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg><span class="td-brand-name">Flora <em>club</em></span></div>
        <button id="td-logout" class="td-logout" type="button">Salir</button>
      </div>
      <h1 class="td-title td-head-title">Nuestras <em>extracciones</em></h1>
      <p class="td-head-sub">Cartuchos y baterías 510 para uso discreto y dosificado. Elegí los tuyos y reservá.</p>

      <div id="td-activo" class="td-activo"></div>
      <div id="td-items" class="td-menu"></div>

      <div id="td-done" class="td-done">
        <h3>Reserva enviada ✓</h3>
        <p class="td-done-items"></p>
        <p>Es una <strong>reserva</strong>: te lo preparamos y lo retirás en el club, donde abonás. Por el sitio no se cobra nada.</p>
      </div>
    </div>

    <!-- ── Barra flotante ── -->
    <div id="td-bar" class="td-bar" role="region" aria-label="Resumen de reserva">
      <span id="td-bar-info" class="td-bar-info"></span>
      <button id="td-bar-btn" class="td-bar-btn" type="button">Reservar</button>
    </div>
  </main>

  <script src="https://accounts.google.com/gsi/client" async defer is:inline></script>
  <script define:vars={{ googleClientId }}>
    window.TIENDA = Object.assign({ categoria: 'extracciones', layout: 'menu', iconos: { 'cartucho-1ml-thc': "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M10 3.5h4v3h-4z\"/><path d=\"M9.5 6.5h5a1 1 0 0 1 1 1V19a1.5 1.5 0 0 1-1.5 1.5h-4A1.5 1.5 0 0 1 8.5 19V7.5a1 1 0 0 1 1-1Z\"/><path d=\"M8.5 11h7\"/></svg>", 'cartucho-05-thc': "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M10 3.5h4v3h-4z\"/><path d=\"M9.5 6.5h5a1 1 0 0 1 1 1V19a1.5 1.5 0 0 1-1.5 1.5h-4A1.5 1.5 0 0 1 8.5 19V7.5a1 1 0 0 1 1-1Z\"/><path d=\"M8.5 11h7\"/></svg>", 'cartucho-05-cbd': "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M10 3.5h4v3h-4z\"/><path d=\"M9.5 6.5h5a1 1 0 0 1 1 1V19a1.5 1.5 0 0 1-1.5 1.5h-4A1.5 1.5 0 0 1 8.5 19V7.5a1 1 0 0 1 1-1Z\"/><path d=\"M8.5 11h7\"/></svg>", 'bateria-510': "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"8\" y=\"5\" width=\"8\" height=\"16\" rx=\"2\"/><path d=\"M10.5 3h3\"/><path d=\"m12.8 9-2 4h2.4l-2 4\"/></svg>" } }, { googleClientId })
  </script>
  <script src="/socios/tienda.js" is:inline></script>
</Layout>
