---
import Layout from '../../layouts/Layout.astro'
import '../../styles/global.css'

const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || ''

// Íconos del gateway — idénticos a los de la landing pública
const productIconsSvg = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3s6 6.5 6 11a6 6 0 0 1-12 0c0-4.5 6-11 6-11z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 10h14v8a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2z"/><rect x="4" y="5.5" width="16" height="4.5" rx="1"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2" width="6" height="4" rx="1"/><path d="M8 6h8l-1.2 3.4H9.2z"/><rect x="7.5" y="9.4" width="9" height="12.1" rx="2.5"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V11M12 11c3.5-.4 6-3 6-7-3.5.4-6 3-6 7zM12 13C8.5 12.6 6 10 6 6c3.5.4 6 3 6 7z"/></svg>`,
]
---

<Layout
  title="Portal de socios | Flora ONG"
  description="Portal privado para socios verificados de Flora: precios y catálogo."
  noindex={true}
>
  <main class="pt-main">
    <!-- ── Login ── -->
    <div id="pt-login" class="pt-login">
      <video class="pt-login-video" src="/hero/socios-login.mp4" poster="/hero/socios-login_poster.jpg" autoplay muted loop playsinline preload="auto" aria-hidden="true"></video>
      <div class="pt-login-scrim" aria-hidden="true"></div>

      <a href="/" class="pt-login-back">← Volver al sitio</a>

      <div class="pt-login-split">
        <div class="pt-login-block pt-login-block-left">
          <img class="pt-login-logo" src="/img/flora-logo-white.png" alt="Flora" width="1472" height="298" />
          <span class="pt-login-eyebrow">Acceso privado</span>
          <h1 class="pt-title">Portal de <em>socios</em></h1>
        </div>

        <div class="pt-login-block pt-login-block-right">
          <p class="pt-sub">Precios de todos los productos y la carta de flores del mes, solo para socios verificados.</p>
          <div id="g_id_button" class="pt-login-gbtn"></div>
          <p id="pt-login-msg" class="pt-msg" hidden></p>
        </div>
      </div>
    </div>

    <!-- ── Portal ── -->
    <div id="pt-content" class="pt-content" hidden>
      <header class="pt-head">
        <div class="pt-brand">
          <svg class="pt-brand-leaf" viewBox="0 0 32 32" fill="none" aria-hidden="true"><path d="M16 6C16 6 10 10 10 17C10 20.3137 12.6863 23 16 23C19.3137 23 22 20.3137 22 17C22 10 16 6 16 6Z" fill="currentColor"/><line x1="16" y1="22" x2="16" y2="27" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span class="pt-brand-name">Flora <em>club</em></span>
        </div>
        <h1 class="pt-title">Portal de <em>socios</em></h1>
        <p class="pt-sub pt-sub-head">Elegí una categoría para ver precios y reservar. Retirás en el club.</p>
        <button id="pt-logout" class="pt-logout" type="button">Salir</button>
      </header>

      <div class="fl-gateway fl-prod-gateway pt-gw" role="list">
        <a class="fl-panel fl-panel-1" href="/aceites/" role="listitem" aria-label="Aceites">
          <img class="fl-panel-img" src="/img/prod-aceites-trio.jpg" alt="" loading="lazy" width="1448" height="1010" />
          <span class="fl-panel-icon" aria-hidden="true" set:html={productIconsSvg[0]} />
          <span class="fl-panel-body">
            <span class="fl-panel-title">Aceites</span>
            <span class="fl-panel-desc">Q1, Q2 y Q3 con su cromatografía. Elegí el tuyo y reservalo.</span>
            <span class="fl-panel-cta">Ver y reservar <span aria-hidden="true">→</span></span>
          </span>
        </a>

        <a class="fl-panel fl-panel-2" href="/cremas/" role="listitem" aria-label="Cremas">
          <img class="fl-panel-img" src="/img/prod-cremas.jpg" alt="" loading="lazy" width="1400" height="1750" />
          <span class="fl-panel-icon" aria-hidden="true" set:html={productIconsSvg[1]} />
          <span class="fl-panel-body">
            <span class="fl-panel-title">Cremas</span>
            <span class="fl-panel-desc">Tópicas, para alivio localizado. Reservá la tuya.</span>
            <span class="fl-panel-cta">Ver y reservar <span aria-hidden="true">→</span></span>
          </span>
        </a>

        <a class="fl-panel fl-panel-3" href="/extracciones/" role="listitem" aria-label="Extracciones">
          <img class="fl-panel-img" src="/img/prod-extracciones.jpg" alt="" loading="lazy" width="1003" height="1254" />
          <span class="fl-panel-icon" aria-hidden="true" set:html={productIconsSvg[2]} />
          <span class="fl-panel-body">
            <span class="fl-panel-title">Extracciones</span>
            <span class="fl-panel-desc">Cartuchos y baterías 510, discretos y dosificados.</span>
            <span class="fl-panel-cta">Ver y reservar <span aria-hidden="true">→</span></span>
          </span>
        </a>

        <a class="fl-panel fl-panel-4" href="/socios/carta/" role="listitem" aria-label="Flores">
          <img class="fl-panel-img" src="/img/prod-flores.jpg" alt="" loading="lazy" width="1400" height="1750" />
          <span class="fl-panel-icon" aria-hidden="true" set:html={productIconsSvg[3]} />
          <span class="fl-panel-body">
            <span class="fl-panel-title">Flores</span>
            <span class="fl-panel-desc">La carta del mes, con reserva por gramos y prerolls.</span>
            <span class="fl-panel-cta">Abrir la carta <span aria-hidden="true">→</span></span>
          </span>
        </a>
      </div>

      <p class="pt-foot">Portal exclusivo para personas asociadas · las reservas se abonan al retirar en el club.</p>
    </div>
  </main>

  <script src="https://accounts.google.com/gsi/client" async defer is:inline></script>
  <script define:vars={{ googleClientId }}>
    function esc(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]))
    }
    const fmt = (n) => '$ ' + Number(n).toLocaleString('es-AR')

    function showContent() {
      document.getElementById('pt-login').hidden = true
      document.getElementById('pt-content').hidden = false
    }

    function showLoginError(message) {
      const msg = document.getElementById('pt-login-msg')
      msg.textContent = message
      msg.hidden = false
    }

    async function loadPrecios() {
      const res = await fetch('/api/socios/precios', { credentials: 'include' })
      if (!res.ok) return false
      const data = await res.json()
      showContent()
      return true
    }

    window.handleGoogleCredential = async (response) => {
      try {
        const res = await fetch('/api/socios/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ credential: response.credential }),
        })
        const data = await res.json()
        if (!res.ok || !data.ok) {
          showLoginError(data.error || 'No se pudo verificar tu cuenta.')
          return
        }
        await loadPrecios()
      } catch (err) {
        showLoginError('Error de red al verificar con Google.')
      }
    }

    document.getElementById('pt-logout').addEventListener('click', async () => {
      await fetch('/api/socios/logout', { method: 'POST', credentials: 'include' })
      location.reload()
    })

    if (googleClientId) {
      window.onload = () => {
        google.accounts.id.initialize({
          client_id: googleClientId,
          callback: window.handleGoogleCredential,
        })
        google.accounts.id.renderButton(document.getElementById('g_id_button'), {
          theme: 'filled_black',
          size: 'large',
          shape: 'pill',
          text: 'signin_with',
          locale: 'es',
        })
      }
    } else {
      showLoginError('Falta configurar el Google Client ID del sitio.')
    }

    loadPrecios()
  </script>
</Layout>

<style is:global>
  /* ═══════════════════════════════════════════════
     PORTAL DE SOCIOS — Flora de noche
     Mismo sistema que la carta: violeta profundo,
     violeta claro al mando, verde bosque para datos
  ═══════════════════════════════════════════════ */
  html, body { background-color: #130d1c; }

  .pt-main {
    --pt-bg:     #130d1c;
    --pt-card:   #1b1326;
    --pt-line:   rgba(183, 157, 230, 0.16);
    --pt-cream:  #f4f1f7;
    --pt-muted:  rgba(244, 241, 247, 0.55);
    --pt-violet: #b79de6;
    --pt-green:  #3cb492;

    min-height: 100svh;
    background: var(--pt-bg);
    font-family: var(--font-ui);
    color: var(--pt-cream);
    position: relative;
  }
  .pt-main::before {
    content: '';
    position: fixed; inset: 0; pointer-events: none;
    background:
      radial-gradient(55% 40% at 85% 0%, rgba(56, 31, 86, 0.45), transparent 70%),
      radial-gradient(50% 35% at 5% 100%, rgba(10, 80, 60, 0.14), transparent 70%);
    z-index: 0;
  }
  .pt-main > * { position: relative; z-index: 1; }

  .pt-brand { display: inline-flex; align-items: center; gap: 0.55rem; color: var(--pt-violet); }
  .pt-brand-leaf { width: 30px; height: 30px; }
  .pt-brand-name { font-family: var(--font-display); font-size: 1.15rem; }
  .pt-brand-name em { font-style: italic; }

  .pt-title { font-family: var(--font-display); font-weight: 500; color: var(--pt-cream); font-size: clamp(2rem, 5vw, 2.9rem); line-height: 1.05; }
  .pt-title em { font-style: italic; color: var(--pt-violet); }
  .pt-sub { line-height: 1.6; color: var(--pt-muted); font-size: 0.95rem; margin: 0; }
  .pt-msg { color: var(--pt-violet); font-size: 0.9rem; }

  /* Login — experiencia de acceso premium: video de cultivo a pantalla completa.
     Dos bloques a los costados (marca+título a la izq., bajada+CTA a la der.)
     dejan entrever el video limpio en el centro de la pantalla. */
  .pt-login {
    position: relative; overflow: hidden; isolation: isolate;
    min-height: 100svh;
    padding: var(--space-m) var(--space-s);
  }
  .pt-login[hidden] { display: none; }
  .pt-login-video {
    position: absolute; inset: 0; z-index: 0;
    width: 100%; height: 100%; object-fit: cover;
    filter: saturate(1.05) brightness(0.9);
  }
  /* Scrim oscuro solo en los costados (donde vive cada bloque); el centro
     de la pantalla queda claro para que el video se vea sin filtro */
  .pt-login-scrim {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(90deg, rgba(9, 6, 14, 0.7) 0%, rgba(9, 6, 14, 0.1) 32%, rgba(9, 6, 14, 0) 50%, rgba(9, 6, 14, 0.1) 68%, rgba(9, 6, 14, 0.7) 100%),
      linear-gradient(180deg, rgba(9, 6, 14, 0.28) 0%, rgba(9, 6, 14, 0) 24%, rgba(9, 6, 14, 0) 76%, rgba(9, 6, 14, 0.35) 100%);
  }

  .pt-login-back {
    position: absolute; z-index: 3; top: var(--space-s); left: var(--space-s);
    color: rgba(244, 241, 247, 0.75); text-decoration: none; font-size: 0.85rem;
    text-shadow: 0 1px 12px rgba(0,0,0,0.6);
    transition: color 0.2s ease;
  }
  .pt-login-back:hover { color: var(--pt-cream); }

  .pt-login-split {
    position: relative; z-index: 2;
    min-height: 100svh;
    display: flex; align-items: center; justify-content: space-between;
    gap: clamp(24px, 6vw, 64px);
  }
  .pt-login-block {
    display: flex; flex-direction: column; gap: 0.85rem;
    max-width: 360px;
  }
  .pt-login-block-left { align-items: flex-start; text-align: left; }
  .pt-login-block-right { align-items: flex-start; text-align: left; }

  .pt-login-logo {
    height: clamp(26px, 3.2vw, 38px); width: auto;
    filter: drop-shadow(0 2px 18px rgba(0,0,0,0.55));
    margin-bottom: 0.4rem;
  }
  .pt-login-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--pt-cream);
    background: rgba(183, 157, 230, 0.16);
    -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
    border: 1px solid rgba(183, 157, 230, 0.4);
    border-radius: 999px; padding: 6px 16px;
    font-family: var(--font-ui); font-size: 0.72rem; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  .pt-login-block .pt-title { text-shadow: 0 3px 30px rgba(0,0,0,0.65); }
  .pt-login-block .pt-sub { text-shadow: 0 1px 16px rgba(0,0,0,0.6); }
  .pt-login-gbtn { margin-top: 0.2rem; filter: drop-shadow(0 10px 30px rgba(0,0,0,0.5)); }

  @media (max-width: 860px) {
    .pt-login-split { flex-direction: column; justify-content: center; align-items: center; text-align: center; gap: 1.75rem; }
    .pt-login-block-left, .pt-login-block-right { align-items: center; text-align: center; max-width: 440px; }
  }

  /* Portal */
  .pt-content { max-width: 1080px; margin: 0 auto; padding: clamp(28px, 4vw, 56px) clamp(18px, 3vw, 32px) clamp(40px, 5vw, 64px); }
  .pt-content[hidden] { display: none; }
  .pt-head { position: relative; margin-bottom: clamp(24px, 3.5vw, 40px); }
  .pt-head .pt-title { margin: 12px 0 8px; }
  .pt-sub-head { max-width: 52ch; }
  .pt-logout {
    position: absolute; top: 0; right: 0;
    background: none; border: 1px solid var(--pt-line); border-radius: 999px;
    color: var(--pt-muted); font-family: var(--font-ui); font-size: 0.85rem; font-weight: 600;
    padding: 8px 18px; cursor: pointer; transition: color 0.2s ease, border-color 0.2s ease;
  }
  .pt-logout:hover { color: var(--pt-cream); border-color: var(--pt-violet); }

  /* Gateway de la landing sobre fondo nocturno: solo margen propio */
  .pt-gw { margin-top: clamp(20px, 2.6vw, 32px); }

  .pt-foot { margin-top: clamp(20px, 3vw, 32px); font-size: 0.8rem; color: var(--pt-muted); text-align: center; }
</style>
