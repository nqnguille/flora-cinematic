---
import Layout from '../../layouts/Layout.astro'
import SociosLogin from '../../components/SociosLogin.astro'
import SociosTos from '../../components/SociosTos.astro'
import SociosGateway from '../../components/SociosGateway.astro'
import '../../styles/global.css'

const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || ''
---

<Layout
  title="Portal de socios | Flora ONG"
  description="Portal privado para socios verificados de Flora: precios y catálogo."
  noindex={true}
>
  <main class="pt-main">
    <SociosLogin title="Acceso exclusivo para<br /><em class='sl-accent-green'>miembros del club</em>" joinPrompt>
      <Fragment slot="note">Validamos tu identidad en nuestra base de pacientes.<br />No compartimos tus datos.</Fragment>
    </SociosLogin>
    <SociosTos />

    <!-- ── Portal ── -->
    <div id="pt-content" class="pt-content" hidden>
      <header class="pt-head">
        <a href="/" class="pt-head-logo-link" aria-label="Ir al sitio de Flora">
          <img class="pt-head-logo" src="/img/flora-logo-white.png" alt="Flora" width="1472" height="298" />
        </a>
        <h1 class="pt-title">Hola, <em id="pt-nombre">socio</em>.<br />¿Qué te llevás hoy?</h1>
        <p class="pt-sub pt-sub-head">Elegí una categoría para ver precios y reservar. Retirás en el club.</p>
        <button id="pt-logout" class="pt-logout" type="button">Salir</button>
      </header>

      <SociosGateway class="pt-gw" />

      <p class="pt-foot">Portal exclusivo para personas asociadas · las reservas se abonan al retirar en el club.</p>
    </div>
  </main>

  <script src="https://accounts.google.com/gsi/client" async defer is:inline></script>
  <script define:vars={{ googleClientId }}>
    function esc(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]))
    }
    const fmt = (n) => '$ ' + Number(n).toLocaleString('es-AR')

    function showContent() {
      document.getElementById('socios-login').hidden = true
      document.getElementById('pt-content').hidden = false
    }

    function showLoginError(message) {
      const msg = document.getElementById('socios-login-msg')
      if (message === '__NOSOCIO__') {
        const wa = 'https://wa.me/5492996375723?text=' + encodeURIComponent('Hola Flora, quiero conocer el club 🌿')
        msg.innerHTML = `Flora funciona por invitación: para entrar, primero conocé el club. Escribinos por <a href="${wa}" target="_blank" rel="noopener">WhatsApp</a> y coordinamos una visita.`
      } else {
        msg.textContent = message
      }
      msg.hidden = false
    }

    async function loadPrecios() {
      const res = await fetch('/api/socios/precios', { credentials: 'include' })
      if (!res.ok) return false
      const data = await res.json()
      showContent()
      // Nombre real en el saludo — si falla, se queda el "socio" genérico
      // del markup en vez de romper la carga del portal por esto.
      fetch('/api/socios/yo', { credentials: 'include' })
        .then((r) => r.ok ? r.json() : null)
        .then((yo) => {
          const primerNombre = (yo?.name || '').trim().split(/\s+/)[0]
          if (primerNombre) document.getElementById('pt-nombre').textContent = primerNombre
        })
        .catch(() => {})
      return true
    }

    async function submitLogin(credential, tosAccept) {
      try {
        const res = await fetch('/api/socios/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ credential, tosAccept: !!tosAccept }),
        })
        const data = await res.json()
        if (res.ok && data.ok) {
          window.hideSociosTos()
          await loadPrecios()
          return
        }
        if (data.needsTos) {
          window.showSociosTos({
            mode: 'accept',
            onAccept: () => submitLogin(credential, true),
          })
          return
        }
        if (res.status === 403) {
          showLoginError('__NOSOCIO__')
          return
        }
        showLoginError(data.error || 'No se pudo verificar tu cuenta.')
      } catch (err) {
        showLoginError('Error de red al verificar con Google.')
      }
    }

    window.handleGoogleCredential = (response) => submitLogin(response.credential, false)

    document.getElementById('pt-logout').addEventListener('click', async () => {
      await fetch('/api/socios/logout', { method: 'POST', credentials: 'include' })
      location.reload()
    })

    if (googleClientId) {
      window.onload = () => {
        google.accounts.id.initialize({
          client_id: googleClientId,
          callback: window.handleGoogleCredential,
        })
        google.accounts.id.renderButton(document.getElementById('g_id_button'), {
          theme: 'filled_black',
          size: 'large',
          shape: 'pill',
          text: 'signin_with',
          locale: 'es',
        })
      }
    } else {
      showLoginError('Falta configurar el Google Client ID del sitio.')
    }

    loadPrecios()
  </script>
</Layout>

<style is:global>
  /* ═══════════════════════════════════════════════
     PORTAL DE SOCIOS — Flora de noche
     Mismo sistema que la carta: violeta profundo,
     violeta claro al mando, verde bosque para datos
  ═══════════════════════════════════════════════ */
  html, body { background-color: #130d1c; }

  .pt-main {
    --pt-bg:     #130d1c;
    --pt-card:   #1b1326;
    --pt-line:   rgba(183, 157, 230, 0.16);
    --pt-cream:  #f4f1f7;
    --pt-muted:  rgba(244, 241, 247, 0.55);
    --pt-violet: #b79de6;
    --pt-green:  #3cb492;

    min-height: 100svh;
    background: var(--pt-bg);
    font-family: var(--font-ui);
    color: var(--pt-cream);
    position: relative;
    /* Centrado vertical: el portal (4 tarjetas + header) es más bajo que
       el viewport en la mayoría de las pantallas, y quedaba todo pegado
       arriba con un colchón de vacío suelto abajo. Con el login (que sí
       llena el 100svh solo) esto no cambia nada. */
    display: flex; flex-direction: column;
  }
  .pt-main::before {
    content: '';
    position: fixed; inset: 0; pointer-events: none;
    background:
      radial-gradient(55% 40% at 85% 0%, rgba(56, 31, 86, 0.45), transparent 70%),
      radial-gradient(50% 35% at 5% 100%, rgba(10, 80, 60, 0.14), transparent 70%);
    z-index: 0;
  }
  .pt-main > * { position: relative; z-index: 1; }

  .pt-title { font-family: var(--font-display); font-weight: 500; color: var(--pt-cream); font-size: clamp(2rem, 5vw, 2.9rem); line-height: 1.05; }
  .pt-title em { font-style: italic; color: var(--pt-violet); }
  .pt-sub { line-height: 1.6; color: var(--pt-muted); font-size: 0.95rem; margin: 0; }

  /* Portal */
  .pt-content {
    max-width: 1080px; margin: 0 auto; width: 100%; flex: 1;
    display: flex; flex-direction: column; justify-content: center;
    padding: clamp(28px, 4vw, 56px) clamp(18px, 3vw, 32px) clamp(40px, 5vw, 64px);
  }
  .pt-content[hidden] { display: none; }
  .pt-head { position: relative; margin-bottom: clamp(24px, 3.5vw, 40px); }
  .pt-head-logo-link { display: inline-block; opacity: 1; transition: opacity 0.2s ease; }
  .pt-head-logo-link:hover { opacity: 0.75; }
  .pt-head-logo { height: 26px; width: auto; margin-bottom: 14px; display: block; }
  .pt-head .pt-title { margin: 12px 0 8px; }
  .pt-sub-head { max-width: 52ch; }
  .pt-logout {
    position: absolute; top: 0; right: 0;
    background: none; border: 1px solid var(--pt-line); border-radius: 999px;
    color: var(--pt-muted); font-family: var(--font-ui); font-size: 0.85rem; font-weight: 600;
    padding: 8px 18px; cursor: pointer; transition: color 0.2s ease, border-color 0.2s ease;
  }
  .pt-logout:hover { color: var(--pt-cream); border-color: var(--pt-violet); }

  /* Gateway de la landing sobre fondo nocturno: solo margen propio */
  .pt-gw { margin-top: clamp(20px, 2.6vw, 32px); }

  .pt-foot { margin-top: clamp(20px, 3vw, 32px); font-size: 0.8rem; color: var(--pt-muted); text-align: center; }
</style>
